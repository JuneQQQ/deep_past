    print("\n🩺 Fold health check:")
    display_cols = [
        "fold", "n_samples", "mean_src_len", "mean_tgt_len",
        "mean_gap_ratio", "mean_num_ratio", "mean_entity_ratio", "doc_type_top3",
    ]
    print(fold_diagnostics_df[display_cols].to_string(index=False))

current_eval_metadata = eval_df.reset_index(drop=True).copy()
current_fold_eval_summary = summarize_split_dataframe(current_eval_metadata, f"fold{CURRENT_FOLD}")
print("\n🧪 Current eval fold summary:")
for key in ("n_samples", "n_groups", "mean_src_len", "mean_tgt_len", "mean_gap_ratio", "mean_num_ratio", "mean_entity_ratio", "mean_len_ratio_ref"):
    if key in current_fold_eval_summary:
        print(f"   {key}: {current_fold_eval_summary[key]}")
if "doc_type_top3" in current_fold_eval_summary:
    print(f"   doc_type_top3: {current_fold_eval_summary['doc_type_top3']}")
if "data_source_top3" in current_fold_eval_summary:
    print(f"   data_source_top3: {current_fold_eval_summary['data_source_top3']}")

# 多 fold 时更新输出目录
if config.num_folds > 1:
    OUTPUT_DIR = _planned_output_dir
    os.makedirs(OUTPUT_DIR, exist_ok=True)

    print(f"   📁 Fold 输出目录: {OUTPUT_DIR}")

if _resume_checkpoint_path:
    print(f"   ♻️ 自动续训: {_resume_checkpoint_path}")
else:
    print("   ℹ️ 未检测到可续训 checkpoint，将从当前 model_name 冷启动。")

# OOM 压测：按长度从长到短排序，并在 dataloader 中保持顺序
if config.use_desc_length_stress_test:
    if {"src_len_tok", "tgt_len_tok"}.issubset(train_df.columns):
        train_df["_stress_len"] = (
            train_df["src_len_tok"].fillna(0).astype(float)
            + train_df["tgt_len_tok"].fillna(0).astype(float)
        )
    else:
        train_df["_stress_len"] = (
            train_df["input_text"].astype(str).str.len()
            + train_df["target_text"].astype(str).str.len()
        )
    train_df = (
        train_df.sort_values(["_stress_len"], ascending=False, kind="mergesort")
        .reset_index(drop=True)
    )
    top_n = min(5, len(train_df))
    if top_n:
        head_lengths = ", ".join(str(int(x)) for x in train_df["_stress_len"].head(top_n).tolist())
        print(f"   🧨 Length stress test: train 按长度降序，前{top_n}条长度={head_lengths}")
    train_df = train_df.drop(columns=["_stress_len"])

# Curriculum Learning: 按长度排序（短→长）
if config.use_curriculum and not config.use_desc_length_stress_test:
    train_df['_length'] = train_df['input_text'].str.len() + train_df['target_text'].str.len()
    train_df = train_df.sort_values('_length').reset_index(drop=True)
    train_df = train_df.drop(columns=['_length'])
    print(f"   📚 Curriculum Learning: 按长度排序（短→长）")

# ============================================================
# RAG 索引构建（BM25 词级 + TF-IDF 字符级 + RRF 融合 + 离线预计算）
# ⚠️ 严禁使用 target 端检索，否则会导致逻辑性数据泄露
# ============================================================
_rag_index = None
_rag_cache = None  # 离线预计算的检索缓存

from train_utils import HybridRAGIndex

if config.use_rag:
    _rag_index = HybridRAGIndex(train_df, config)
    _rag_cache = _rag_index.precompute_cache(train_df)
else:
    _rag_index = None
    _rag_cache = None
    print("   📌 RAG 示例注入: 关闭")


def _find_aug_trace_example(df, apply_fn, *, max_rows: int = 800):
    """Return the first sample whose text changes after augmentation."""
    if df is None or len(df) == 0:
        return None
    n = min(len(df), max_rows)
    for idx in range(n):
        raw_input = str(df.iloc[idx]["input_text"])
        content = _strip_any_task_prefix(raw_input)
        try:
            augmented = apply_fn(content, df.iloc[idx])
        except Exception:
            continue
        if augmented and augmented != content:
            return {
                "content": content,
                "augmented": augmented,
                "row_index": idx,
            }
    return None


def _log_prompt_augmentation_status(train_df):
    trace_log_path = os.path.join(OUTPUT_DIR, "feature_trace.log")
    lines = []

    def _emit(line: str = ""):
        print(line)
        lines.append(line)

    _emit("\n🧩 Prompt Augmentation Status:")
    if config.name_handling_mode == "hint":
        _emit(
            f"   Hint: ON (ratio={config.hint_ratio}, max={config.max_hints_per_sample}, "
            f"lexicon={len(_calibrated_lexicon) if _calibrated_lexicon else len(_lexicon)})"
        )
    elif config.name_handling_mode == "placeholder":
        _emit(f"   Hint: OFF (placeholder mode, ratio={config.placeholder_ratio})")
    else:
        _emit(f"   Hint: OFF (name_handling_mode={config.name_handling_mode})")

    if _sumerogram_glossary:
        _emit(
            f"   Sumerogram glossary: ON ({len(_sumerogram_glossary)} entries, "
            f"max={config.max_sumerogram_hints})"
        )
    else:
        _emit("   Sumerogram glossary: OFF")

    if config.use_rag and _rag_cache:
        _emit(
            f"   RAG: ON (prob={config.rag_prob}, max_examples={config.rag_max_examples}, "
            f"cache={len(_rag_cache)})"
        )
    elif config.use_rag:
        _emit("   RAG: ON (cache unavailable)")
    else:
        _emit("   RAG: OFF")

    _emit("   Trace examples:")

    if config.name_handling_mode == "hint" and (_lexicon or _calibrated_lexicon):
        _hint_lex = _calibrated_lexicon if _calibrated_lexicon else _lexicon
        _hint_trace = _find_aug_trace_example(
            train_df,
            lambda content, row: _apply_hints(content, _hint_lex),
        )
        if _hint_trace:
            _emit("      Hint example:")
            _emit(f"         raw: {(_hint_trace['content'][:180])}")
            _emit(f"         out: {(_hint_trace['augmented'][:220])}")
        else:
            _emit("      Hint example: no matching sample found in scan window")
    else:
        _emit("      Hint example: disabled")

    if _sumerogram_glossary:
        _sg_trace = _find_aug_trace_example(
            train_df,
            lambda content, row: _inject_sumerogram_hints(
                content,
                _sumerogram_glossary,
                max_hints=config.max_sumerogram_hints,
            ),
        )
        if _sg_trace:
            _emit("      Sumerogram example:")
            _emit(f"         raw: {(_sg_trace['content'][:180])}")
            _emit(f"         out: {(_sg_trace['augmented'][:220])}")
        else:
            _emit("      Sumerogram example: no matching sample found in scan window")
    else:
        _emit("      Sumerogram example: disabled")

    if config.use_rag and _rag_cache:
        def _rag_apply(content, row):
            examples = _rag_cache.get(content)
            if not examples:
                return content
            prefix = " || ".join(f"{ex['source']} | {ex['target']}" for ex in examples) + " || "
            return prefix + content  # RAG 前缀直接拼接（content 已含 task_prefix）

        _rag_trace = _find_aug_trace_example(train_df, _rag_apply)
        if _rag_trace:
            _emit("      RAG example:")
            _emit(f"         raw: {(_rag_trace['content'][:160])}")
            _emit(f"         out: {(_rag_trace['augmented'][:260])}")
        else:
            _emit("      RAG example: no matching sample found in scan window")
    else:
        _emit("      RAG example: disabled")

    with open(trace_log_path, "a", encoding="utf-8") as f:
        f.write("\n".join(lines) + "\n")
    print(f"   📝 Feature trace saved: {trace_log_path}")


_log_prompt_augmentation_status(train_df)

# Convert to HuggingFace Dataset
_dataset_text_cols = ['input_text', 'target_text']
if config.data_source_col in train_df.columns and config.data_source_col in eval_df.columns:
    _dataset_text_cols.append(config.data_source_col)
train_dataset = Dataset.from_pandas(train_df[_dataset_text_cols].reset_index(drop=True))
eval_dataset = Dataset.from_pandas(eval_df[_dataset_text_cols].reset_index(drop=True))


def tokenize_function(examples):
    """Tokenize inputs and targets for ByT5 (动态 padding)."""
    # 不在此处 pad，让 collator 动态处理
    model_inputs = tokenizer(
        examples['input_text'],
        max_length=config.max_input_length,
        padding=False,  # 动态 padding
        truncation=True,
    )
    
    # Tokenize targets (也不 pad)
    labels = tokenizer(
        examples['target_text'],
        max_length=config.max_target_length,
        padding=False,  # 动态 padding
        truncation=True,
    )
    
    # 直接使用 label_ids，collator 会处理 -100 替换
    label_ids = labels['input_ids']
    
    model_inputs['labels'] = label_ids
    
    # 保留原始文本用于动态 simulate_damage 和占位符掩码
    model_inputs['raw_input'] = examples['input_text']
    model_inputs['raw_target'] = examples['target_text']
    if config.data_source_col in examples:
        model_inputs['raw_data_source'] = examples[config.data_source_col]
    return model_inputs


print("   Tokenizing datasets...")
train_dataset = train_dataset.map(tokenize_function, batched=True, remove_columns=_dataset_text_cols)
eval_dataset = eval_dataset.map(tokenize_function, batched=True, remove_columns=_dataset_text_cols)

print(f"   ✓ Train dataset: {len(train_dataset)} samples")
print(f"   ✓ Eval dataset: {len(eval_dataset)} samples")

train_probe_dataset = None
if TRAIN_PROBE_EVAL_SAMPLES > 0 and len(train_dataset) > 0:
    probe_size = min(TRAIN_PROBE_EVAL_SAMPLES, len(train_dataset))
    probe_rng = np.random.RandomState(config.random_seed)
    probe_indices = np.sort(probe_rng.choice(len(train_dataset), size=probe_size, replace=False)).tolist()
    train_probe_dataset = train_dataset.select(probe_indices)
    print(f"   🔬 Train probe dataset: {len(train_probe_dataset)} samples (teacher-forced eval loss only)")

# 截断统计
def compute_truncation_stats(dataset, max_input, max_target, name="Dataset"):
    """统计被截断的样本数量（基于截断前真实长度）"""
    input_truncated = 0
    target_truncated = 0
    input_at_cap = 0
    target_at_cap = 0
    input_lens = []
    target_lens = []
    raw_input_lens = []
    raw_target_lens = []
    
    for sample in dataset:
        input_len = len(sample['input_ids'])
        target_len = len(sample['labels'])
        input_lens.append(input_len)
        target_lens.append(target_len)
        
        # 命中上限（不等于被截断，仅表示 tokenized 长度达到 max_length）
        if input_len == max_input:
            input_at_cap += 1
        if target_len == max_target:
            target_at_cap += 1

        # 真实截断判断：用未截断 token 长度比较 > max_length
        raw_input = sample.get('raw_input')
        raw_target = sample.get('raw_target')

        if raw_input is not None:
            raw_input_len = len(tokenizer(raw_input, truncation=False, padding=False)['input_ids'])
            raw_input_lens.append(raw_input_len)
            if raw_input_len > max_input:
                input_truncated += 1
        else:
            raw_input_lens.append(input_len)

        if raw_target is not None:
            raw_target_len = len(tokenizer(raw_target, truncation=False, padding=False)['input_ids'])
            raw_target_lens.append(raw_target_len)
            if raw_target_len > max_target:
                target_truncated += 1
        else:
            raw_target_lens.append(target_len)
    
    total = len(dataset)
    print(f"\n📊 {name} 截断统计:")
    print(f"   输入原始长度: min={min(raw_input_lens)}, max={max(raw_input_lens)}, avg={sum(raw_input_lens)/len(raw_input_lens):.1f}")
    print(f"   目标原始长度: min={min(raw_target_lens)}, max={max(raw_target_lens)}, avg={sum(raw_target_lens)/len(raw_target_lens):.1f}")
    print(f"   输入截断后长度: min={min(input_lens)}, max={max(input_lens)}, avg={sum(input_lens)/len(input_lens):.1f}")
    print(f"   目标截断后长度: min={min(target_lens)}, max={max(target_lens)}, avg={sum(target_lens)/len(target_lens):.1f}")
    print(f"   输入截断: {input_truncated}/{total} ({100*input_truncated/total:.1f}%) @ max_length={max_input}")
    print(f"   目标截断: {target_truncated}/{total} ({100*target_truncated/total:.1f}%) @ max_length={max_target}")
    print(f"   输入命中上限(=max): {input_at_cap}/{total} ({100*input_at_cap/total:.1f}%)")
    print(f"   目标命中上限(=max): {target_at_cap}/{total} ({100*target_at_cap/total:.1f}%)")
    
    if input_truncated > 0 or target_truncated > 0:
        print(f"   ⚠️ 警告: 存在截断，可能影响模型性能！")


compute_truncation_stats(train_dataset, config.max_input_length, config.max_target_length, "Train")
if RUNTIME_EVAL_ENABLED and len(eval_dataset) > 0:
    compute_truncation_stats(eval_dataset, config.max_input_length, config.max_target_length, "Eval")
else:
    print(f"\n📊 Eval 截断统计: 跳过（早停关闭或 eval 集为空）")

# ============================================================
# CELL 6: LOAD MODEL
# ============================================================

from transformers import T5ForConditionalGeneration

print("\n🤖 Loading model...")
_model_load_path = _resume_checkpoint_path if _resume_checkpoint_path else _resolved_model_path
print(f"   Loading from: {_model_load_path}")
_model_use_safetensors = resolve_use_safetensors(_model_load_path)
print(f"   use_safetensors: {_model_use_safetensors}")

# DDP 多进程下 FP32 加载会导致 CPU RAM 爆炸（每进程 ~15GB × N 卡），
# 改为直接以 bf16 加载 + low_cpu_mem_usage 避免 2× 峰值。
# Trainer 的 bf16 参数仍然控制训练精度，加载 dtype 与训练 dtype 一致不影响收敛。
_load_dtype = torch.bfloat16 if config.use_bf16 else torch.float32
model = T5ForConditionalGeneration.from_pretrained(
    _model_load_path,
    torch_dtype=_load_dtype,
    local_files_only=True,
    use_safetensors=_model_use_safetensors,
)

# Ensure model is in training mode
model.train()

print(f"   Model dtype: {next(model.parameters()).dtype}")
print(f"   Training mode: {model.training}")

# 层冻结：冻结 encoder/decoder 底部 N 层
if config.freeze_encoder_layers > 0 or config.freeze_decoder_layers > 0:
    frozen_params = 0
    # 冻结 encoder 底部层
    if config.freeze_encoder_layers > 0:
        encoder_blocks = model.encoder.block
        n_freeze_enc = min(config.freeze_encoder_layers, len(encoder_blocks))
        for i in range(n_freeze_enc):
            for p in encoder_blocks[i].parameters():
                p.requires_grad = False
                frozen_params += p.numel()
        print(f"   🧊 冻结 encoder 底部 {n_freeze_enc}/{len(encoder_blocks)} 层")
    # 冻结 decoder 底部层
    if config.freeze_decoder_layers > 0:
        decoder_blocks = model.decoder.block
        n_freeze_dec = min(config.freeze_decoder_layers, len(decoder_blocks))
        for i in range(n_freeze_dec):
            for p in decoder_blocks[i].parameters():
                p.requires_grad = False
                frozen_params += p.numel()
        print(f"   🧊 冻结 decoder 底部 {n_freeze_dec}/{len(decoder_blocks)} 层")
    # 可选：冻结 shared embedding（通常不建议，除非数据极少）
    print(f"   🧊 冻结参数量: {frozen_params:,}")

# Boundary-aware Side Embedding (模型结构消融)
from model_ablation import (
    ABLATION_CFG as _ba_cfg, install_boundary_aware, save_side_embedding, load_side_embedding,
    BOTTLENECK_CFG as _bn_cfg, HYBRID_CFG as _ha_cfg, COVERAGE_CFG as _cov_cfg,
    install_encoder_patches, save_bottleneck_weights, load_bottleneck_weights,
    compute_coverage_loss,
)
_ba_cfg.enable              = config.use_boundary_aware
_ba_cfg.combine_mode        = config.boundary_combine_mode
_ba_cfg.use_punctuation     = config.boundary_use_punctuation
_ba_cfg.use_boundary        = config.boundary_use_boundary
_ba_cfg.use_damage          = config.boundary_use_damage
_ba_cfg.use_numeric         = config.boundary_use_numeric
_ba_cfg.freeze_base_embed   = config.boundary_freeze_base_embed
_ba_cfg.freeze_side_embed   = config.boundary_freeze_side_embed
_ba_cfg.side_embed_init_std = config.boundary_init_std
_ba_cfg.patch_decoder       = config.boundary_patch_decoder
_boundary_wrapper = install_boundary_aware(model, cfg=_ba_cfg)
# 续训时加载已有的 side embedding 权重
if _boundary_wrapper is not None and _resume_checkpoint_path:
    load_side_embedding(model, _resume_checkpoint_path, strict=False)

# Latent Bottleneck + Hybrid Attention (模型结构消融，统一安装)
_bn_cfg.enable                = config.use_latent_bottleneck
_bn_cfg.bottleneck_after_layer = config.bottleneck_after_layer
_bn_cfg.stride                = config.bottleneck_stride
_bn_cfg.kernel_size           = config.bottleneck_kernel_size
_bn_cfg.use_residual          = config.bottleneck_use_residual
_bn_cfg.use_layernorm         = config.bottleneck_use_layernorm
_bn_cfg.init_std              = config.bottleneck_init_std
_bn_cfg.freeze_bottleneck     = config.bottleneck_freeze
_ha_cfg.enable                = config.use_hybrid_attention
_ha_cfg.window_size           = config.hybrid_window_size
_ha_cfg.global_role_ids       = config.hybrid_global_roles
_ha_cfg.global_every_n        = config.hybrid_global_every_n
_bottleneck_layer, _hybrid_enabled = install_encoder_patches(
    model, bottleneck_cfg=_bn_cfg, hybrid_cfg=_ha_cfg, boundary_cfg=_ba_cfg,
)
# 续训时加载已有的 bottleneck 权重
if _bottleneck_layer is not None and _resume_checkpoint_path:
    load_bottleneck_weights(model, _resume_checkpoint_path, strict=False)

# Coverage Loss (训练正则化消融)
_cov_cfg.enable        = config.use_coverage_loss
_cov_cfg.alpha         = config.coverage_alpha
_cov_cfg.warmup_steps  = config.coverage_warmup_steps
_cov_cfg.layer_index   = config.coverage_layer_index
if _cov_cfg.enable:
    print(f"   ✅ Coverage loss: ENABLED (α={_cov_cfg.alpha}, warmup={_cov_cfg.warmup_steps})")
else:
    print(f"   ⬜ Coverage loss: DISABLED")

# Count parameters
total_params = sum(p.numel() for p in model.parameters())
trainable_params = sum(p.numel() for p in model.parameters() if p.requires_grad)
print(f"   Total params: {total_params:,}")
print(f"   Trainable: {trainable_params:,} ({trainable_params/total_params*100:.1f}%)")

# 关键：设置 generation_config，确保 Trainer.evaluate() 也使用这些参数
model.generation_config.max_length = config.max_target_length
model.generation_config.num_beams = config.num_beams
model.generation_config.repetition_penalty = config.repetition_penalty
model.generation_config.no_repeat_ngram_size = config.no_repeat_ngram_size
# early_stopping 和 length_penalty 仅在 beam search (num_beams>1) 时有效
# 设置它们在 num_beams=1 时会导致 transformers 保存 checkpoint 时报 ValueError
if config.num_beams > 1:
    model.generation_config.length_penalty = config.length_penalty
    model.generation_config.early_stopping = GENERATE_EARLY_STOPPING
else:
    # Greedy 模式：设为默认值以避免 transformers 校验报错
    model.generation_config.length_penalty = 1.0
    model.generation_config.early_stopping = False
print(f"   ✓ generation_config updated: num_beams={config.num_beams}, no_repeat_ngram_size={config.no_repeat_ngram_size}, repetition_penalty={config.repetition_penalty}")

# ============================================================
# CELL 7: EVALUATION METRICS
# ============================================================

from sacrebleu.metrics import BLEU as SacreBLEU, CHRF as SacreCHRF

bleu_scorer = SacreBLEU()
chrf_scorer = SacreCHRF(word_order=CHRF_WORD_ORDER)


def compute_bleu_chrf_scores(predictions: List[str], references: List[str]) -> Tuple[float, float]:
    """使用底层 sacrebleu 直接计算，减少 evaluate 包装层开销。"""
    if not predictions or not references or len(predictions) != len(references):
        return 0.0, 0.0
    try:
        bleu = float(bleu_scorer.corpus_score(predictions, [references]).score)
    except Exception:
        bleu = 0.0
    try:
        chrf = float(chrf_scorer.corpus_score(predictions, [references]).score)
    except Exception:
        chrf = 0.0
    return bleu, chrf

# ============================================================
# HELPER CLASSES
# ============================================================

class PredictionStore:
    """存储评估预测的所有阶段（raw + postprocessed）"""
    def __init__(self):
        self.model_inputs = []  # 模型实际输入文本（含 task_prefix + hint/placeholder）
        self.raw_preds = []     # 模型直接解码输出（未后处理）
        self.raw_labels = []    # 参考文本直接解码（未后处理，可能含占位符标签）
        self.predictions = []   # 后处理后的预测
        self.labels = []        # 后处理后的参考
        self.per_sample_scores = []
        self.pred_token_lens = []
        self.ref_token_lens = []
        self.len_ratios = []
        self.doc_types = []
        self.has_data = False
    
    def update(self, model_inputs, raw_preds, raw_labels, preds, labels):
        self.model_inputs = model_inputs
        self.raw_preds = raw_preds
        self.raw_labels = raw_labels
        self.predictions = preds
        self.labels = labels
        self.has_data = True
    
    def clear(self):
        self.model_inputs = []
        self.raw_preds = []
        self.raw_labels = []
        self.predictions = []
        self.labels = []
        self.per_sample_scores = []
        self.pred_token_lens = []
        self.ref_token_lens = []
        self.len_ratios = []
        self.doc_types = []
        self.has_data = False
    
    def get(self):
        return self.model_inputs, self.raw_preds, self.raw_labels, self.predictions, self.labels

# Instantiate global store
prediction_store = PredictionStore()
_eval_label_cache = {
    "signature": None,
    "decoded_labels": None,
    "normalized_labels": None,
    "ref_lens": None,
    "ref_number_sets": None,
    "ref_entity_sets": None,
}

def strip_input_artifacts(text: str) -> str:
    """剥离模型输出中可能回显的输入端标记（HINTS / RAG 前缀 / task prefix）"""
    if not isinstance(text, str):
        return text
    if '## HINTS:' in text:
        text = text[:text.index('## HINTS:')]
    if '## MONTH:' in text:
        text = text[:text.index('## MONTH:')]
    if text.startswith('Examples:\n') or text.startswith('Examples:'):
        lines = text.strip().split('\n')
        text = lines[-1] if lines else text
    prefix_marker = 'to English:'
    if prefix_marker in text:
        text = text[text.index(prefix_marker) + len(prefix_marker):]
    return text.strip()

def normalize_for_eval(text):
    """对预测和 ground truth 统一规范化（用于公平评估）"""
    if not isinstance(text, str):
        return ""
    return strip_input_artifacts(postprocess_output(text, _onomasticon))


# Vectorized postprocessor for boundary eval (much faster than per-string loops)
_vectorized_postprocessor = VectorizedPostprocessor()


def _boundary_eval_postprocess_batch(texts: List[str]) -> List[str]:
    """Vectorized postprocessing for boundary eval (pandas-based, ~10-50x faster)."""
    stripped = [strip_input_artifacts(t) for t in texts]
    return _vectorized_postprocessor.postprocess_batch(stripped)


def _array_signature(arr: np.ndarray) -> tuple:
    if not isinstance(arr, np.ndarray):
        return ("non_array",)
    if arr.size == 0:
        return (tuple(arr.shape), 0, 0, 0)
    if arr.ndim == 1:
        arr = arr[None, :]
    return (
        tuple(arr.shape),
        int(arr.sum(dtype=np.int64)),
        int(arr[0].sum(dtype=np.int64)),
        int(arr[-1].sum(dtype=np.int64)),
    )


def decode_sequences(
    sequences: np.ndarray,
    *,
    tokenizer,
) -> List[str]:
    return infer_decode_sequences(sequences, tokenizer=tokenizer)


def _token_len(text: str) -> int:
    return len(_tokenize_target(text))


def _exact_set_match_rate(ref_sets: List[set], pred_sets: List[set]) -> Tuple[float, float]:
    relevant = [i for i, ref in enumerate(ref_sets) if ref]
    if not relevant:
        return 1.0, 0.0
    matches = [pred_sets[i] == ref_sets[i] for i in relevant]
    return float(np.mean(matches)), float(len(relevant) / max(len(ref_sets), 1))


def _compute_doc_type_metrics(
    doc_types: List[str],
    predictions: List[str],
    references: List[str],
    len_ratios: np.ndarray,
) -> Dict[str, float]:
    metrics: Dict[str, float] = {}
    if not doc_types or len(doc_types) != len(predictions) or len(predictions) != len(references):
        return metrics

    doc_type_set = set(doc_types)
    present_doc_types = [doc for doc in _DOC_TYPES if doc in doc_type_set]
    extras = sorted(doc_type_set - set(present_doc_types))
    present_doc_types.extend(extras)
    grouped_indices: Dict[str, List[int]] = {}
    for idx, doc_type in enumerate(doc_types):
        grouped_indices.setdefault(doc_type, []).append(idx)

    for doc_type in present_doc_types:
        indices = grouped_indices.get(doc_type, [])
        if not indices:
            continue
        sub_preds = [predictions[i] for i in indices]
        sub_refs = [references[i] for i in indices]
        sub_bleu, sub_chrf = compute_bleu_chrf_scores(sub_preds, sub_refs)
        sub_geom = math.sqrt(max(sub_bleu, GEOM_MEAN_MIN) * max(sub_chrf, GEOM_MEAN_MIN)) if USE_GEOM_MEAN else 0.0
        sub_len_ratio = float(np.mean(len_ratios[indices])) if len(indices) else 0.0

        metrics[f"doc_{doc_type}_count"] = float(len(indices))
        metrics[f"doc_{doc_type}_bleu"] = sub_bleu
        metrics[f"doc_{doc_type}_chrf"] = sub_chrf
        metrics[f"doc_{doc_type}_geom"] = sub_geom
        metrics[f"doc_{doc_type}_len_ratio"] = sub_len_ratio
    return metrics


def _compute_source_metrics(
    data_sources: List[str],
    predictions: List[str],
    references: List[str],
    len_ratios: np.ndarray,
) -> Dict[str, float]:
    metrics: Dict[str, float] = {}
    if not data_sources or len(data_sources) != len(predictions) or len(predictions) != len(references):
        return metrics

    source_set = set(data_sources)
    present_sources = [src for src in _DATA_SOURCES if src in source_set]
    extras = sorted(source_set - set(present_sources))
    present_sources.extend(extras)
    grouped_indices: Dict[str, List[int]] = {}
    for idx, source_name in enumerate(data_sources):
        grouped_indices.setdefault(source_name, []).append(idx)

    for source_name in present_sources:
        indices = grouped_indices.get(source_name, [])
        if not indices:
            continue
        sub_preds = [predictions[i] for i in indices]
        sub_refs = [references[i] for i in indices]
        sub_bleu, sub_chrf = compute_bleu_chrf_scores(sub_preds, sub_refs)
        sub_geom = math.sqrt(max(sub_bleu, GEOM_MEAN_MIN) * max(sub_chrf, GEOM_MEAN_MIN)) if USE_GEOM_MEAN else 0.0
        sub_len_ratio = float(np.mean(len_ratios[indices])) if len(indices) else 0.0

        metrics[f"source_{source_name}_count"] = float(len(indices))
        metrics[f"source_{source_name}_bleu"] = sub_bleu
        metrics[f"source_{source_name}_chrf"] = sub_chrf
        metrics[f"source_{source_name}_geom"] = sub_geom
        metrics[f"source_{source_name}_len_ratio"] = sub_len_ratio
    return metrics

def compute_metrics(eval_preds):
    """Compute BLEU and chrF++ on evaluation set."""
    eval_timing = {}
    t_eval_start = time.perf_counter()
    if LOG_EVAL_TIMING and _is_main_process():
        print("   ⏱️ compute_metrics start")

    # 1. 解包数据 (EvalPrediction 可能包含 inputs 字段)
    predictions = eval_preds.predictions
    labels = eval_preds.label_ids
    
    import numpy as np

    def pad_to_numpy(obj):
        """将预测/标签统一为 [batch, seq_len] 的 int64 numpy。
        
        处理以下情况：
        - np.ndarray 2D [batch, seq]  → 直接返回
        - np.ndarray 1D [seq]         → 扩展为 [1, seq]
        - np.ndarray 3D [batch, beam, seq] → 取 beam 0 → [batch, seq]
        - tuple/list of np.ndarray    → 若元素均为 2D 同 batch 大小，说明是
                                        (token_ids_array, scores_array, ...) 格式，
                                        取第一个元素；否则按行 padding 拼接
        - list of list (不等长)       → padding 后拼接
        """
        # ---- ndarray ----
        if isinstance(obj, np.ndarray):
            if obj.ndim == 1:
                return obj[None, :].astype(np.int64, copy=False)
            if obj.ndim == 2:
                return obj.astype(np.int64, copy=False)
            if obj.ndim >= 3:
                # [batch, beam, seq] → 取 best beam (index 0)
                return obj[:, 0, :].astype(np.int64, copy=False)

        # ---- tuple/list ----
        if isinstance(obj, (tuple, list)):
            if len(obj) == 0:
                return np.zeros((0, 1), dtype=np.int64)

            first = obj[0]

            # Case A: tuple of ndarray — e.g. (token_ids [B,S], scores [B,S], ...)
            # tuple 默认按 Trainer 传统输出处理，只取第一个元素
            if isinstance(obj, tuple) and isinstance(first, np.ndarray) and first.ndim == 2:
                return first.astype(np.int64, copy=False)

            # Case B: list of 2D ndarray batches (eval_do_concat_batches=False)
            if isinstance(obj, list) and isinstance(first, np.ndarray) and first.ndim == 2:
                max_len = max(x.shape[1] for x in obj)
                padded = []
                for x in obj:
                    if x.shape[1] < max_len:
                        x = np.pad(
                            x,
                            ((0, 0), (0, max_len - x.shape[1])),
                            constant_values=tokenizer.pad_token_id,
                        )
                    padded.append(x)
                return np.concatenate(padded, axis=0).astype(np.int64, copy=False)

            # Case C: tuple/list of 1D ndarray (one per batch item, possibly unequal length)
            if isinstance(first, np.ndarray) and first.ndim == 1:
                max_len = max(x.shape[0] for x in obj)
                padded = [
                    np.pad(x, (0, max_len - x.shape[0]),
                           constant_values=tokenizer.pad_token_id)
                    for x in obj
                ]
                return np.stack(padded, axis=0).astype(np.int64, copy=False)

            # Case D: list of list (variable length int sequences)
            if isinstance(first, (list, tuple)) and (
                len(first) == 0 or not isinstance(first[0], (list, tuple, np.ndarray))
            ):
                max_len = max(len(s) for s in obj)
                padded = [
                    list(s) + [tokenizer.pad_token_id] * (max_len - len(s))
                    for s in obj
                ]
                return np.array(padded, dtype=np.int64)

            # Case E: nested structure — recurse on first element (e.g. beam candidates)
            return pad_to_numpy(first)

        # scalar fallback
        return np.array([[int(obj)]], dtype=np.int64)

    predictions = pad_to_numpy(predictions)
    labels = pad_to_numpy(labels)
        
    # 2. 批量解码
    predictions = np.where(predictions < 0, tokenizer.pad_token_id, predictions)
    predictions = np.where(predictions >= tokenizer.vocab_size, tokenizer.pad_token_id, predictions)
    labels = np.where(labels < 0, tokenizer.pad_token_id, labels)
    labels = np.where(labels >= tokenizer.vocab_size, tokenizer.pad_token_id, labels)

    t_decode_preds = time.perf_counter()
    decoded_preds = decode_sequences(
        predictions,
        tokenizer=tokenizer,
    )
    eval_timing["decode_preds_only"] = time.perf_counter() - t_decode_preds

    label_signature = _array_signature(labels)
    if _eval_label_cache["signature"] == label_signature:
        decoded_labels = _eval_label_cache["decoded_labels"]
        eval_timing["decode_labels_only"] = 0.0
        eval_timing["label_cache_hit"] = 1.0
    else:
        t_decode_labels = time.perf_counter()
        decoded_labels = decode_sequences(
            labels,
            tokenizer=tokenizer,
        )
        eval_timing["decode_labels_only"] = time.perf_counter() - t_decode_labels
        eval_timing["label_cache_hit"] = 0.0
        _eval_label_cache["signature"] = label_signature
        _eval_label_cache["decoded_labels"] = list(decoded_labels)
    
    # 从 EvalPrediction.inputs 解码模型实际输入（由 include_for_metrics=["inputs"] 提供）
    # 注意：不能用 data_collator.eval_inputs_buffer，因为 dataloader_num_workers>0 时
    # collator 在子进程运行，主进程的 buffer 始终为空
    need_decoded_inputs = bool(SAVE_EVAL_PREDICTIONS) or (len(current_eval_metadata) != len(decoded_preds))
    if need_decoded_inputs and hasattr(eval_preds, 'inputs') and eval_preds.inputs is not None:
        inputs = pad_to_numpy(eval_preds.inputs)
        inputs = np.where(inputs < 0, tokenizer.pad_token_id, inputs)
        inputs = np.where(inputs >= tokenizer.vocab_size, tokenizer.pad_token_id, inputs)
        decoded_inputs = decode_sequences(
            inputs,
            tokenizer=tokenizer,
        )
    else:
        decoded_inputs = [""] * len(decoded_preds)
    eval_timing["batch_decode"] = time.perf_counter() - t_eval_start
    
    # DDP padding 修正：DistributedSampler 会将 eval 集 pad 到 world_size×batch 的整数倍，
    # gather 后 decoded_preds 会比真实 eval 集多出几条重复样本。截断到真实长度，
    # 确保 metrics 只在真实样本上计算，同时使 current_eval_metadata 长度对齐。
    _meta_n = len(current_eval_metadata)
    if 0 < _meta_n < len(decoded_preds):
        if _is_main_process():
            print(f"   📐 DDP padding 截断: {len(decoded_preds)} → {_meta_n} (移除 {len(decoded_preds) - _meta_n} 条 padding)")
        decoded_preds = decoded_preds[:_meta_n]
        decoded_labels = decoded_labels[:_meta_n]
        decoded_inputs = decoded_inputs[:_meta_n]
    elif _is_main_process():
        print(f"   📐 compute_metrics: decoded_preds={len(decoded_preds)}, current_eval_metadata={_meta_n}")

    # 保存 raw 解码结果（后处理之前）
    raw_preds = list(decoded_preds)
    raw_labels = list(decoded_labels)
    
    # 3. 规范化
    # 仅对 predictions 做后处理（与 infer.py 一致）
    # labels 已在 prepare_data.py 中通过 preprocess_translation 清洗过，不再做 postprocess_output
    # 避免 remove_phrase_repeats / fuzzy_fix_proper_nouns 误改 labels 导致 eval 分数虚高
    t_norm = time.perf_counter()
    decoded_preds = [normalize_for_eval(p) or "." for p in decoded_preds]
    if _eval_label_cache["signature"] == label_signature and _eval_label_cache["normalized_labels"] is not None:
        decoded_labels = _eval_label_cache["normalized_labels"]
    else:
        decoded_labels = [l.strip() or "." for l in decoded_labels]
        _eval_label_cache["normalized_labels"] = list(decoded_labels)
    eval_timing["normalize"] = time.perf_counter() - t_norm

    # Compute BLEU / chrF++ early so fast path can return immediately.
    t_core_metrics = time.perf_counter()
    bleu, chrf = compute_bleu_chrf_scores(decoded_preds, decoded_labels)
    # Raw metrics: model output with only strip(), no postprocess_output
    raw_preds_stripped = [p.strip() or "." for p in raw_preds]
    _, raw_chrf = compute_bleu_chrf_scores(raw_preds_stripped, decoded_labels)
    eval_timing["core_metrics"] = time.perf_counter() - t_core_metrics
    if USE_GEOM_MEAN:
        geom_mean = math.sqrt(max(bleu, GEOM_MEAN_MIN) * max(chrf, GEOM_MEAN_MIN))
    else:
        geom_mean = 0.0

    if not COMPUTE_EXTENDED_EVAL_METRICS:
        if COMPUTE_BREAKDOWN_METRICS:
            pred_lens = np.array([_token_len(p) for p in decoded_preds], dtype=np.float64)
            ref_lens = np.array([_token_len(l) for l in decoded_labels], dtype=np.float64)
            len_ratios = pred_lens / np.maximum(ref_lens, 1.0)
            if len(current_eval_metadata) == len(decoded_preds):
                eval_doc_types = current_eval_metadata["doc_type"].astype(str).tolist()
                eval_data_sources = (
                    current_eval_metadata[config.data_source_col].fillna("official").astype(str).apply(normalize_data_source_label).tolist()
                    if config.data_source_col in current_eval_metadata.columns
                    else ["official"] * len(decoded_preds)
                )
            else:
                eval_doc_types = ["unknown"] * len(decoded_preds)
                eval_data_sources = ["unknown"] * len(decoded_preds)
            doc_type_metrics = _compute_doc_type_metrics(
                eval_doc_types,
                decoded_preds,
                decoded_labels,
                len_ratios,
            )
            source_metrics = _compute_source_metrics(
                eval_data_sources,
                decoded_preds,
                decoded_labels,
                len_ratios,
            )
        else:
            doc_type_metrics = {}
            source_metrics = {}
        result = {
            "bleu": bleu,
            "chrf": chrf,
            "raw_chrf": raw_chrf,
            "geom_mean": geom_mean,
        }
        result.update(doc_type_metrics)
        result.update(source_metrics)
        return result
    
    need_per_sample_scores = bool(SAVE_WORST_EVAL_SAMPLES)
    per_sample_scores = []
    if need_per_sample_scores:
        for p, l in zip(decoded_preds, decoded_labels):
            try:
                s = float(chrf_scorer.corpus_score([p], [[l]]).score)
            except Exception:
                s = 0.0
            per_sample_scores.append(s)

    t_extended = time.perf_counter()
    pred_lens = np.array([_token_len(p) for p in decoded_preds], dtype=np.float64)
    if _eval_label_cache["signature"] == label_signature and _eval_label_cache["ref_lens"] is not None:
        ref_lens = np.array(_eval_label_cache["ref_lens"], dtype=np.float64)
    else:
        ref_lens = np.array([_token_len(l) for l in decoded_labels], dtype=np.float64)
        _eval_label_cache["ref_lens"] = ref_lens.tolist()
    len_ratios = pred_lens / np.maximum(ref_lens, 1.0)
    under_translation_rate = float(np.mean(len_ratios < 0.8)) if len(len_ratios) else 0.0
    over_translation_rate = float(np.mean(len_ratios > 1.35)) if len(len_ratios) else 0.0
    empty_or_near_empty_rate = float(
        np.mean([(pred_lens[i] <= 1) or (len(decoded_preds[i].strip(" .,:;!?")) < 3) for i in range(len(decoded_preds))])
    ) if len(decoded_preds) else 0.0

    if _eval_label_cache["signature"] == label_signature and _eval_label_cache["ref_number_sets"] is not None:
        ref_number_sets = _eval_label_cache["ref_number_sets"]
    else:
        ref_number_sets = [set(extract_numbers(l)) for l in decoded_labels]
        _eval_label_cache["ref_number_sets"] = ref_number_sets
    pred_number_sets = [set(extract_numbers(p)) for p in decoded_preds]
    number_match_rate, number_case_rate = _exact_set_match_rate(ref_number_sets, pred_number_sets)

    if _eval_label_cache["signature"] == label_signature and _eval_label_cache["ref_entity_sets"] is not None:
        ref_entity_sets = _eval_label_cache["ref_entity_sets"]
    else:
        ref_entity_sets = [set(extract_entities(l)) for l in decoded_labels]
        _eval_label_cache["ref_entity_sets"] = ref_entity_sets
    pred_entity_sets = [set(extract_entities(p)) for p in decoded_preds]
    entity_match_rate, entity_case_rate = _exact_set_match_rate(ref_entity_sets, pred_entity_sets)

    if len(current_eval_metadata) == len(decoded_preds):
        gap_case_flags = current_eval_metadata["gap_count"].fillna(0).to_numpy() > 0
        eval_doc_types = current_eval_metadata["doc_type"].astype(str).tolist()
        eval_data_sources = (
            current_eval_metadata[config.data_source_col].fillna("official").astype(str).apply(normalize_data_source_label).tolist()
            if config.data_source_col in current_eval_metadata.columns
            else ["official"] * len(decoded_preds)
        )
    else:
        gap_case_flags = np.array(["<gap>" in inp.lower() for inp in decoded_inputs], dtype=bool)
        eval_doc_types = ["unknown"] * len(decoded_preds)
        eval_data_sources = ["unknown"] * len(decoded_preds)

    gap_case_count = int(np.sum(gap_case_flags))
    if gap_case_count:
        gap_preds = [decoded_preds[i] for i in range(len(decoded_preds)) if gap_case_flags[i]]
        gap_refs = [decoded_labels[i] for i in range(len(decoded_labels)) if gap_case_flags[i]]
        _, gap_case_chrf = compute_bleu_chrf_scores(gap_preds, gap_refs)
    else:
        _, gap_case_chrf = compute_bleu_chrf_scores(decoded_preds, decoded_labels)
    gap_case_len_ratio = float(np.mean(len_ratios[gap_case_flags])) if gap_case_count else float(np.mean(len_ratios)) if len(len_ratios) else 0.0
    eval_timing["extended_metrics"] = time.perf_counter() - t_extended
    
    # 保存预测详情供 CSV 导出（包含 inputs + raw + postprocessed + per-sample scores）
    if SAVE_EVAL_PREDICTIONS:
        prediction_store.update(decoded_inputs, raw_preds, raw_labels, decoded_preds, decoded_labels)
        prediction_store.per_sample_scores = per_sample_scores
        prediction_store.pred_token_lens = pred_lens.tolist()
        prediction_store.ref_token_lens = ref_lens.tolist()
        prediction_store.len_ratios = len_ratios.tolist()
        prediction_store.doc_types = eval_doc_types
        if _is_main_process():
            print(f"   💾 Captured {len(decoded_preds)} predictions (inputs + raw + postprocessed + scores) for export")

    if COMPUTE_BREAKDOWN_METRICS:
        t_breakdown = time.perf_counter()
        doc_type_metrics = _compute_doc_type_metrics(
            eval_doc_types,
            decoded_preds,
            decoded_labels,
            len_ratios,
        )
        source_metrics = _compute_source_metrics(
            eval_data_sources,
            decoded_preds,
            decoded_labels,
            len_ratios,
        )
        eval_timing["breakdown_metrics"] = time.perf_counter() - t_breakdown
    else:
        doc_type_metrics = {}
        source_metrics = {}

    result = {
        "bleu": bleu,
        "chrf": chrf,
        "raw_chrf": raw_chrf,
        "geom_mean": geom_mean,
        "mean_pred_len": float(pred_lens.mean()) if len(pred_lens) else 0.0,
        "mean_ref_len": float(ref_lens.mean()) if len(ref_lens) else 0.0,
        "mean_len_ratio": float(len_ratios.mean()) if len(len_ratios) else 0.0,
        "under_translation_rate": under_translation_rate,
        "over_translation_rate": over_translation_rate,
        "empty_or_near_empty_rate": empty_or_near_empty_rate,
        "number_match_rate": number_match_rate,
        "number_case_rate": number_case_rate,
        "entity_match_rate": entity_match_rate,
        "entity_case_rate": entity_case_rate,
        "gap_case_count": float(gap_case_count),
        "gap_case_chrf": gap_case_chrf,
        "gap_case_len_ratio": gap_case_len_ratio,
    }
    result.update(doc_type_metrics)
    result.update(source_metrics)
    eval_timing["total"] = time.perf_counter() - t_eval_start
    if LOG_EVAL_TIMING:
        timing_parts = ", ".join(
            f"{k}={v:.2f}s" for k, v in eval_timing.items()
            if k in {
                "decode_preds_only",
                "decode_labels_only",
                "batch_decode",
                "normalize",
                "core_metrics",
                "extended_metrics",
                "breakdown_metrics",
                "total",
            }
        )
        if _is_main_process():
            print(f"   ⏱️ compute_metrics timing: {timing_parts}")
    return result


def compute_text_metrics_from_strings(
    decoded_preds: List[str],
    decoded_labels: List[str],
    decoded_inputs: List[str] | None = None,
    *,
    save_predictions: bool = False,
) -> Dict[str, float]:
    decoded_inputs = decoded_inputs or [""] * len(decoded_preds)
    raw_preds = list(decoded_preds)
    raw_labels = list(decoded_labels)
    decoded_preds = [normalize_for_eval(p) or "." for p in decoded_preds]
    decoded_labels = [(l.strip() if isinstance(l, str) else "") or "." for l in decoded_labels]

    bleu, chrf = compute_bleu_chrf_scores(decoded_preds, decoded_labels)
    raw_preds_stripped = [p.strip() or "." for p in raw_preds]
    _, raw_chrf = compute_bleu_chrf_scores(raw_preds_stripped, decoded_labels)
    geom_mean = math.sqrt(max(bleu, GEOM_MEAN_MIN) * max(chrf, GEOM_MEAN_MIN)) if USE_GEOM_MEAN else 0.0

    pred_lens = np.array([_token_len(p) for p in decoded_preds], dtype=np.float64)
    ref_lens = np.array([_token_len(l) for l in decoded_labels], dtype=np.float64)
    len_ratios = pred_lens / np.maximum(ref_lens, 1.0)
    under_translation_rate = float(np.mean(len_ratios < 0.8)) if len(len_ratios) else 0.0
    over_translation_rate = float(np.mean(len_ratios > 1.35)) if len(len_ratios) else 0.0
    empty_or_near_empty_rate = float(
        np.mean([(pred_lens[i] <= 1) or (len(decoded_preds[i].strip(" .,:;!?")) < 3) for i in range(len(decoded_preds))])
    ) if len(decoded_preds) else 0.0

    ref_number_sets = [set(extract_numbers(l)) for l in decoded_labels]
    pred_number_sets = [set(extract_numbers(p)) for p in decoded_preds]
    number_match_rate, number_case_rate = _exact_set_match_rate(ref_number_sets, pred_number_sets)

    ref_entity_sets = [set(extract_entities(l)) for l in decoded_labels]
    pred_entity_sets = [set(extract_entities(p)) for p in decoded_preds]
    entity_match_rate, entity_case_rate = _exact_set_match_rate(ref_entity_sets, pred_entity_sets)

    if len(current_eval_metadata) == len(decoded_preds):
        gap_case_flags = current_eval_metadata["gap_count"].fillna(0).to_numpy() > 0
        eval_doc_types = current_eval_metadata["doc_type"].astype(str).tolist()
        eval_data_sources = (
            current_eval_metadata[config.data_source_col].fillna("official").astype(str).apply(normalize_data_source_label).tolist()
            if config.data_source_col in current_eval_metadata.columns
            else ["official"] * len(decoded_preds)
        )
    else:
        gap_case_flags = np.array(["<gap>" in inp.lower() for inp in decoded_inputs], dtype=bool)
        eval_doc_types = ["unknown"] * len(decoded_preds)
        eval_data_sources = ["unknown"] * len(decoded_preds)

    gap_case_count = int(np.sum(gap_case_flags))
    if gap_case_count:
        gap_preds = [decoded_preds[i] for i in range(len(decoded_preds)) if gap_case_flags[i]]
        gap_refs = [decoded_labels[i] for i in range(len(decoded_labels)) if gap_case_flags[i]]
        _, gap_case_chrf = compute_bleu_chrf_scores(gap_preds, gap_refs)
    else:
        _, gap_case_chrf = compute_bleu_chrf_scores(decoded_preds, decoded_labels)
    gap_case_len_ratio = float(np.mean(len_ratios[gap_case_flags])) if gap_case_count else float(np.mean(len_ratios)) if len(len_ratios) else 0.0

    if save_predictions:
        prediction_store.update(decoded_inputs, raw_preds, raw_labels, decoded_preds, decoded_labels)
        prediction_store.per_sample_scores = []
        prediction_store.pred_token_lens = pred_lens.tolist()
        prediction_store.ref_token_lens = ref_lens.tolist()
        prediction_store.len_ratios = len_ratios.tolist()
        prediction_store.doc_types = eval_doc_types

    doc_type_metrics = _compute_doc_type_metrics(
        eval_doc_types,
        decoded_preds,
        decoded_labels,
        len_ratios,
    ) if COMPUTE_BREAKDOWN_METRICS else {}
    source_metrics = _compute_source_metrics(
        eval_data_sources,
        decoded_preds,
        decoded_labels,
        len_ratios,
    ) if COMPUTE_BREAKDOWN_METRICS else {}

    result = {
        "bleu": bleu,
        "chrf": chrf,
        "raw_chrf": raw_chrf,
        "geom_mean": geom_mean,
        "mean_pred_len": float(pred_lens.mean()) if len(pred_lens) else 0.0,
        "mean_ref_len": float(ref_lens.mean()) if len(ref_lens) else 0.0,
        "mean_len_ratio": float(len_ratios.mean()) if len(len_ratios) else 0.0,
        "under_translation_rate": under_translation_rate,
        "over_translation_rate": over_translation_rate,
        "empty_or_near_empty_rate": empty_or_near_empty_rate,
        "number_match_rate": number_match_rate,
        "number_case_rate": number_case_rate,
        "entity_match_rate": entity_match_rate,
        "entity_case_rate": entity_case_rate,
        "gap_case_count": float(gap_case_count),
        "gap_case_chrf": gap_case_chrf,
        "gap_case_len_ratio": gap_case_len_ratio,
    }
    result.update(doc_type_metrics)
    result.update(source_metrics)
    return result


def _boundary_eval_mbr_select(candidates: List[str]) -> tuple[str, float]:
    return infer_mbr_select(candidates, metric="chrf")


def run_simple_eval(
    stage_label: str,
    eval_frame: pd.DataFrame,
    *,
    num_beams: int = 1,
    decode_label: str = "greedy",
) -> Dict[str, float]:
    """Simple greedy/beam eval (no MBR). DDP 多卡并行：各 rank 分片推理后 gather。
    Returns eval_-prefixed metrics dict."""
    rank, world_size = _dist_eval_info()

    effective_eval_frame = eval_frame.reset_index(drop=True)
    batch_size = BOUNDARY_EVAL_BATCH_SIZE
    max_new_tokens = BOUNDARY_EVAL_MAX_NEW_TOKENS

    if _is_main_process():
        print(f"\n🔎 {stage_label} ({decode_label}, num_beams={num_beams}, batch={batch_size}, world={world_size})")
    _raw_model = _unwrap_model_for_eval(model)
    _raw_model.eval()
    device = next(_raw_model.parameters()).device

    _saved_gc_ml = _raw_model.generation_config.max_length
    _saved_gc_mnt = _raw_model.generation_config.max_new_tokens
    _raw_model.generation_config.max_length = None
    _raw_model.generation_config.max_new_tokens = max_new_tokens

    input_texts = effective_eval_frame["input_text"].astype(str).tolist()
    target_texts = effective_eval_frame["target_text"].astype(str).tolist()
    
    # Truncate reference targets to match training eval (max_target_length=512)
    tokenized_targets = tokenizer(
        target_texts,
        max_length=config.max_target_length,
        truncation=True,
        padding=False,
    )
    target_texts = decode_sequences(tokenized_targets["input_ids"], tokenizer=tokenizer)

    # DDP 分片：各 rank 处理自己的分片
    local_inputs, _ = _dist_eval_shard(input_texts, rank, world_size)
    local_preds = []

    t0 = time.perf_counter()
    with optimized_generation_context(_raw_model):
        for start in range(0, len(local_inputs), batch_size):
            batch_inputs = local_inputs[start:start + batch_size]
            token_kwargs = dict(return_tensors="pt", padding=True,
                                truncation=BOUNDARY_EVAL_MAX_INPUT_LENGTH is not None)
            if BOUNDARY_EVAL_MAX_INPUT_LENGTH is not None:
                token_kwargs["max_length"] = BOUNDARY_EVAL_MAX_INPUT_LENGTH
            tokens = tokenizer(batch_inputs, **token_kwargs)
            tokens = {k: v.to(device) for k, v in tokens.items()}

            gen_kwargs = {
                **tokens,
                "max_new_tokens": max_new_tokens,
                "do_sample": False,
                "num_beams": num_beams,
                "num_return_sequences": 1,
                "repetition_penalty": BOUNDARY_EVAL_REPETITION_PENALTY,
            }
            if num_beams > 1:
                gen_kwargs["length_penalty"] = BOUNDARY_EVAL_LENGTH_PENALTY
                gen_kwargs["early_stopping"] = True

            with torch.inference_mode():
                outputs = _raw_model.generate(**gen_kwargs)

            decoded = decode_sequences(outputs, tokenizer=tokenizer)
            decoded = _boundary_eval_postprocess_batch(decoded)
            local_preds.extend(decoded)

    # Gather 所有 rank 的 predictions
    predictions = _dist_eval_gather_predictions(local_preds, world_size)
    # 截断到实际数据长度（末尾 rank 可能有 padding）
    predictions = predictions[:len(input_texts)]

    elapsed = time.perf_counter() - t0
    prefixed = {}
    if _is_main_process():
        metrics = compute_text_metrics_from_strings(
            predictions, target_texts, decoded_inputs=input_texts, save_predictions=False,
        )
        prefixed = {f"eval_{k}": v for k, v in metrics.items()}
        print(
            f"[Eval:{stage_label.lower()}] decode={decode_label}  "
            f"BLEU={metrics['bleu']:.2f}  chrF++={metrics['chrf']:.2f}  "
            f"geom={metrics['geom_mean']:.2f}  len_ratio={metrics['mean_len_ratio']:.2f}  "
            f"({elapsed:.1f}s)"
        )

    _raw_model.generation_config.max_length = _saved_gc_ml
    _raw_model.generation_config.max_new_tokens = _saved_gc_mnt
    return prefixed


def run_sample_mbr_eval(
    stage_label: str,
    eval_frame: pd.DataFrame,
    *,
    num_samples: int = 10,
    decode_label: str = "sample_mbr",
) -> Dict[str, float]:
    """Sample N candidates per input, MBR select best. DDP 多卡并行：各 rank 分片推理后 gather。
    Returns eval_-prefixed metrics dict."""
    rank, world_size = _dist_eval_info()

    effective_eval_frame = eval_frame.reset_index(drop=True)
    batch_size = BOUNDARY_EVAL_BATCH_SIZE
    max_new_tokens = BOUNDARY_EVAL_MAX_NEW_TOKENS

    if _is_main_process():
        print(f"\n🔎 {stage_label} ({decode_label}, samples={num_samples}, batch={batch_size}, world={world_size})")
    _raw_model = _unwrap_model_for_eval(model)
    _raw_model.eval()
    device = next(_raw_model.parameters()).device

    _saved_gc_ml = _raw_model.generation_config.max_length
    _saved_gc_mnt = _raw_model.generation_config.max_new_tokens
    _raw_model.generation_config.max_length = None
    _raw_model.generation_config.max_new_tokens = max_new_tokens

    input_texts = effective_eval_frame["input_text"].astype(str).tolist()
    target_texts = effective_eval_frame["target_text"].astype(str).tolist()
    
    # Truncate reference targets to match training eval (max_target_length=512)
    tokenized_targets = tokenizer(
        target_texts,
        max_length=config.max_target_length,
        truncation=True,
        padding=False,
    )
    target_texts = decode_sequences(tokenized_targets["input_ids"], tokenizer=tokenizer)

    # DDP 分片：各 rank 处理自己的分片
    local_inputs, _ = _dist_eval_shard(input_texts, rank, world_size)
    local_preds = []

    t0 = time.perf_counter()
    with optimized_generation_context(_raw_model):
        for start in range(0, len(local_inputs), batch_size):
            batch_inputs = local_inputs[start:start + batch_size]
            token_kwargs = dict(return_tensors="pt", padding=True,
                                truncation=BOUNDARY_EVAL_MAX_INPUT_LENGTH is not None)
            if BOUNDARY_EVAL_MAX_INPUT_LENGTH is not None:
                token_kwargs["max_length"] = BOUNDARY_EVAL_MAX_INPUT_LENGTH
            tokens = tokenizer(batch_inputs, **token_kwargs)
            tokens = {k: v.to(device) for k, v in tokens.items()}

            sample_kwargs = {
                **tokens,
                "max_new_tokens": max_new_tokens,
                "do_sample": True,
                "top_p": BOUNDARY_EVAL_HYBRID_TOP_P,
                "temperature": BOUNDARY_EVAL_HYBRID_TEMPERATURE,
                "num_return_sequences": num_samples,
                "num_beams": 1,
                "repetition_penalty": BOUNDARY_EVAL_REPETITION_PENALTY,
            }

            with torch.inference_mode():
                outputs = _raw_model.generate(**sample_kwargs)

            decoded = decode_sequences(outputs, tokenizer=tokenizer)
            decoded = _boundary_eval_postprocess_batch(decoded)

            n_inputs = len(batch_inputs)
            for i in range(n_inputs):
                cand_set = decoded[i * num_samples : (i + 1) * num_samples]
                best_text, _ = _boundary_eval_mbr_select(cand_set)
                local_preds.append(best_text)

    # Gather 所有 rank 的 predictions
    predictions = _dist_eval_gather_predictions(local_preds, world_size)
    predictions = predictions[:len(input_texts)]

    elapsed = time.perf_counter() - t0
    prefixed = {}
    if _is_main_process():
        metrics = compute_text_metrics_from_strings(
            predictions, target_texts, decoded_inputs=input_texts, save_predictions=False,
        )
        prefixed = {f"eval_{k}": v for k, v in metrics.items()}
        print(
            f"[Eval:{stage_label.lower()}] decode={decode_label}  "
            f"BLEU={metrics['bleu']:.2f}  chrF++={metrics['chrf']:.2f}  "
            f"geom={metrics['geom_mean']:.2f}  len_ratio={metrics['mean_len_ratio']:.2f}  "
            f"({elapsed:.1f}s)"
        )

    _raw_model.generation_config.max_length = _saved_gc_ml
    _raw_model.generation_config.max_new_tokens = _saved_gc_mnt
    return prefixed


def _reset_eval_seed():
    """Reset all RNG states for reproducible eval."""
    seed = config.random_seed
    random.seed(seed)
    np.random.seed(seed)
    torch.manual_seed(seed)
    if torch.cuda.is_available():
        torch.cuda.manual_seed_all(seed)


def run_multi_mode_eval(stage_label: str, eval_frame: pd.DataFrame) -> Dict[str, float]:
    """Run greedy, beam4, sample_mbr, hybrid_mbr and print comparison table.
    Returns hybrid_mbr results as the primary metrics dict."""
    results = {}
    modes = [
        ("greedy", lambda: run_simple_eval(stage_label, eval_frame, num_beams=1, decode_label="greedy")),
        ("beam4", lambda: run_simple_eval(stage_label, eval_frame, num_beams=4, decode_label="beam4")),
        ("sample_mbr", lambda: run_sample_mbr_eval(stage_label, eval_frame, num_samples=10, decode_label="sample_mbr")),
        ("hybrid_mbr", lambda: run_boundary_eval(stage_label, eval_frame)),
    ]
    for mode_name, run_fn in modes:
        _reset_eval_seed()
        try:
            results[mode_name] = run_fn()
        except Exception as e:
            if _is_main_process():
                print(f"   ⚠️ {mode_name} failed: {e}")
            results[mode_name] = {}

    # Print comparison table (rank 0 only)
    if _is_main_process():
        print(f"\n{'─'*72}")
        print(f"{'📊 DECODE MODE COMPARISON':^72}")
        print(f"{'─'*72}")
        print(f"  {'Mode':<14} {'BLEU':>8} {'chrF++':>8} {'geom':>8} {'len_ratio':>10}")
        print(f"  {'─'*48}")
        for mode_name in ["greedy", "beam4", "sample_mbr", "hybrid_mbr"]:
            m = results.get(mode_name, {})
            bleu = m.get("eval_bleu", 0)
            chrf = m.get("eval_chrf", 0)
            geom = m.get("eval_geom_mean", 0)
            lr = m.get("eval_mean_len_ratio", 0)
            print(f"  {mode_name:<14} {bleu:>8.2f} {chrf:>8.2f} {geom:>8.2f} {lr:>10.4f}")
        print(f"{'─'*72}")

    return results.get("hybrid_mbr", results.get("greedy", {}))


def run_boundary_eval(stage_label: str, eval_frame: pd.DataFrame) -> Dict[str, float]:
    """Hybrid MBR boundary eval. DDP 多卡并行：各 rank 分片推理后 gather。"""
    from concurrent.futures import ThreadPoolExecutor
    rank, world_size = _dist_eval_info()

    effective_eval_frame = eval_frame.reset_index(drop=True)
    batch_size = BOUNDARY_EVAL_BATCH_SIZE
    max_new_tokens = BOUNDARY_EVAL_MAX_NEW_TOKENS
    beam_cands = BOUNDARY_EVAL_HYBRID_BEAM_CANDS
    sample_cands = BOUNDARY_EVAL_HYBRID_SAMPLE_CANDS

    if _is_main_process():
        print(
            f"\n🔎 {stage_label} (hybrid_mbr, full-context={BOUNDARY_EVAL_MAX_INPUT_LENGTH is None}, "
            f"batch={batch_size}, world={world_size})"
        )
    # DDP 兼容：unwrap DDP wrapper 以避免 generate() 跨 rank 同步死锁
    _raw_model = _unwrap_model_for_eval(model)
    _raw_model.eval()
    device = next(_raw_model.parameters()).device

    # Ensure generation_config won't override our kwargs
    _saved_gc_max_length = _raw_model.generation_config.max_length
    _saved_gc_max_new_tokens = _raw_model.generation_config.max_new_tokens
    _raw_model.generation_config.max_length = None
    _raw_model.generation_config.max_new_tokens = max_new_tokens

    input_texts = effective_eval_frame["input_text"].astype(str).tolist()
    target_texts = effective_eval_frame["target_text"].astype(str).tolist()
    
    # Truncate reference targets to match training eval (max_target_length=512)
    tokenized_targets = tokenizer(
        target_texts,
        max_length=config.max_target_length,
        truncation=True,
        padding=False,
    )
    target_texts = decode_sequences(tokenized_targets["input_ids"], tokenizer=tokenizer)

    # DDP 分片：各 rank 处理自己的分片
    local_inputs, _ = _dist_eval_shard(input_texts, rank, world_size)

    local_preds = [None] * len(local_inputs)
    total_batches = max(1, math.ceil(len(local_inputs) / max(batch_size, 1)))
    boundary_t0 = time.perf_counter()
    timing_totals = {
        "tokenize": 0.0,
        "beam_generate": 0.0,
        "sample_generate": 0.0,
        "cpu_copy": 0.0,
        "decode": 0.0,
        "postprocess": 0.0,
        "mbr": 0.0,
        "finalize_wait": 0.0,
        "metrics": 0.0,
    }
    pending_result_jobs = []

    def _sync_device() -> None:
        if device.type == "cuda":
            torch.cuda.synchronize(device)

    def _drain_result_jobs(*, block: bool = False) -> None:
        remaining = []
        for job in pending_result_jobs:
            if not block and not job["future"].done():
                remaining.append(job)
                continue

            wait_t0 = time.perf_counter()
            decoded_batch, _, _, finalize_timings = job["future"].result()
            wait_elapsed = time.perf_counter() - wait_t0
            timing_totals["decode"] += finalize_timings.get("decode", 0.0)
            timing_totals["postprocess"] += finalize_timings.get("postprocess", 0.0)
            timing_totals["mbr"] += finalize_timings.get("mbr", 0.0)
            timing_totals["finalize_wait"] += wait_elapsed
            local_preds[job["start"]:job["start"] + job["count"]] = decoded_batch

            if LOG_EVAL_TIMING:
                print(
                    f"   [BoundaryEval:{stage_label.lower()}] rank={rank} batch {job['batch_idx']}/{total_batches} "
                    f"(n={job['count']}, beam={job['beam_width']}x{beam_cands}, sample={sample_cands}) "
                    f"tok={job['tokenize_elapsed']:.2f}s beam={job['beam_elapsed']:.2f}s "
                    f"sample={job['sample_elapsed']:.2f}s cpu={job['cpu_copy_elapsed']:.2f}s "
                    f"decode={finalize_timings.get('decode', 0.0):.2f}s "
                    f"post={finalize_timings.get('postprocess', 0.0):.2f}s "
                    f"mbr={finalize_timings.get('mbr', 0.0):.2f}s wait={wait_elapsed:.2f}s"
                )
        pending_result_jobs[:] = remaining

    with optimized_generation_context(_raw_model):
        with ThreadPoolExecutor(max_workers=4) as finalize_pool:
            for batch_idx, start in enumerate(range(0, len(local_inputs), batch_size), start=1):
                batch_inputs = local_inputs[start:start + batch_size]
                token_kwargs = dict(return_tensors="pt", padding=True, truncation=BOUNDARY_EVAL_MAX_INPUT_LENGTH is not None)
                if BOUNDARY_EVAL_MAX_INPUT_LENGTH is not None:
                    token_kwargs["max_length"] = BOUNDARY_EVAL_MAX_INPUT_LENGTH
                tokenize_t0 = time.perf_counter()
                tokens = tokenizer(batch_inputs, **token_kwargs)
                tokens = {k: v.to(device) for k, v in tokens.items()}
                _sync_device()
                tokenize_elapsed = time.perf_counter() - tokenize_t0
                timing_totals["tokenize"] += tokenize_elapsed

                base_beam_width = max(beam_cands, 1)
                beam_width = base_beam_width
                if BOUNDARY_EVAL_USE_ADAPTIVE_BEAMS and base_beam_width > beam_cands:
                    median_input_len = float(tokens["attention_mask"].sum(dim=1).float().median().item())
                    short_beam_width = max(beam_cands, max(1, base_beam_width // 2))
                    if median_input_len < BOUNDARY_EVAL_ADAPTIVE_BEAM_LEN_THRESHOLD:
                        beam_width = short_beam_width

                beam_kwargs = {
                    **tokens,
                    "max_new_tokens": max_new_tokens,
                    "do_sample": False,
                    "num_beams": beam_width,
                    "num_return_sequences": beam_cands,
                    "length_penalty": BOUNDARY_EVAL_LENGTH_PENALTY,
                    "repetition_penalty": BOUNDARY_EVAL_REPETITION_PENALTY,
                    "early_stopping": True,
                }
                sample_kwargs = {
                    **tokens,
                    "max_new_tokens": max_new_tokens,
                    "do_sample": True,
                    "top_p": BOUNDARY_EVAL_HYBRID_TOP_P,
                    "temperature": BOUNDARY_EVAL_HYBRID_TEMPERATURE,
                    "num_return_sequences": sample_cands,
                    "num_beams": 1,
                    "length_penalty": 1.0,
                    "repetition_penalty": BOUNDARY_EVAL_REPETITION_PENALTY,
                    "early_stopping": False,
                }

                with torch.inference_mode():
                    _sync_device()
                    beam_t0 = time.perf_counter()
                    out_beam = _raw_model.generate(**beam_kwargs)
                    _sync_device()
                    beam_elapsed = time.perf_counter() - beam_t0
                    timing_totals["beam_generate"] += beam_elapsed

                    _sync_device()
                    sample_t0 = time.perf_counter()
                    out_sample = _raw_model.generate(**sample_kwargs)
                    _sync_device()
                    sample_elapsed = time.perf_counter() - sample_t0
                    timing_totals["sample_generate"] += sample_elapsed

                cpu_copy_t0 = time.perf_counter()
                out_beam_cpu = out_beam.detach().cpu().numpy()
                out_sample_cpu = out_sample.detach().cpu().numpy()
                cpu_copy_elapsed = time.perf_counter() - cpu_copy_t0
                timing_totals["cpu_copy"] += cpu_copy_elapsed

                future = finalize_pool.submit(
                    infer_finalize_hybrid_candidate_batch,
                    out_beam_cpu,
                    out_sample_cpu,
                    tokenizer=tokenizer,
                    beam_cands=beam_cands,
                    sample_cands=sample_cands,
                    postprocess_batch=_boundary_eval_postprocess_batch,
                    mbr_selector=_boundary_eval_mbr_select,
                )
                pending_result_jobs.append(
                    {
                        "batch_idx": batch_idx,
                        "start": start,
                        "count": len(batch_inputs),
                        "beam_width": beam_width,
                        "tokenize_elapsed": tokenize_elapsed,
                        "beam_elapsed": beam_elapsed,
                        "sample_elapsed": sample_elapsed,
                        "cpu_copy_elapsed": cpu_copy_elapsed,
                        "future": future,
                    }
                )
                _drain_result_jobs(block=False)

            _drain_result_jobs(block=True)

    local_preds = [pred if pred is not None else "." for pred in local_preds]

    # Gather 所有 rank 的 predictions
    predictions = _dist_eval_gather_predictions(local_preds, world_size)
    predictions = predictions[:len(input_texts)]

    prefixed = {}
    if _is_main_process():
        metrics_t0 = time.perf_counter()
        metrics = compute_text_metrics_from_strings(
            predictions,
            target_texts,
            decoded_inputs=input_texts,
            save_predictions=False,
        )
        timing_totals["metrics"] += time.perf_counter() - metrics_t0
        prefixed = {f"eval_{k}": v for k, v in metrics.items()}
        if LOG_EVAL_TIMING:
            boundary_total_elapsed = time.perf_counter() - boundary_t0
            print(
                "   ⏱️ boundary_eval timing: "
                f"tokenize={timing_totals['tokenize']:.2f}s, "
                f"beam_generate={timing_totals['beam_generate']:.2f}s, "
                f"sample_generate={timing_totals['sample_generate']:.2f}s, "
                f"cpu_copy={timing_totals['cpu_copy']:.2f}s, "
                f"decode={timing_totals['decode']:.2f}s, "
                f"postprocess={timing_totals['postprocess']:.2f}s, "
                f"mbr={timing_totals['mbr']:.2f}s, "
                f"finalize_wait={timing_totals['finalize_wait']:.2f}s, "
                f"metrics={timing_totals['metrics']:.2f}s, "
                f"total={boundary_total_elapsed:.2f}s"
            )
        print(
            f"[Eval:{stage_label.lower()}] step={'0' if stage_label.lower() == 'initial' else 'final'}  "
            f"decode=hybrid_mbr  BLEU={metrics['bleu']:.2f}  chrF++={metrics['chrf']:.2f}  "
            f"geom={metrics['geom_mean']:.2f}  len_ratio={metrics['mean_len_ratio']:.2f}"
        )
    # Restore generation_config
    _raw_model.generation_config.max_length = _saved_gc_max_length
    _raw_model.generation_config.max_new_tokens = _saved_gc_max_new_tokens
    return prefixed


def print_eval_breakdown(metrics: Dict[str, float]) -> None:
    doc_type_rows = []
    for doc_type in _DOC_TYPES:
        count_key = f"eval_doc_{doc_type}_count"
        if count_key in metrics and metrics[count_key] > 0:
            doc_type_rows.append(
                (
                    doc_type,
                    int(metrics[count_key]),
                    metrics.get(f"eval_doc_{doc_type}_bleu", 0.0),
                    metrics.get(f"eval_doc_{doc_type}_chrf", 0.0),
                    metrics.get(f"eval_doc_{doc_type}_geom", 0.0),
                    metrics.get(f"eval_doc_{doc_type}_len_ratio", 0.0),
                )
            )
    if doc_type_rows:
        print("   Category metrics:")
        for doc_type, count, bleu_v, chrf_v, geom_v, len_ratio_v in doc_type_rows:
            print(
                f"   - {doc_type:<11} n={count:>4}  "
                f"BLEU={bleu_v:>6.2f}  chrF++={chrf_v:>6.2f}  "
                f"geom={geom_v:>6.2f}  len={len_ratio_v:>5.2f}"
            )

    source_rows = []
    for source_name in _DATA_SOURCES:
        count_key = f"eval_source_{source_name}_count"
        if count_key in metrics and metrics[count_key] > 0:
            source_rows.append(
                (
                    source_name,
                    int(metrics[count_key]),
                    metrics.get(f"eval_source_{source_name}_bleu", 0.0),
                    metrics.get(f"eval_source_{source_name}_chrf", 0.0),
                    metrics.get(f"eval_source_{source_name}_geom", 0.0),
                    metrics.get(f"eval_source_{source_name}_len_ratio", 0.0),
                )
            )
    if source_rows:
        print("   Source metrics:")
        for source_name, count, bleu_v, chrf_v, geom_v, len_ratio_v in source_rows:
            print(
                f"   - {source_name:<11} n={count:>4}  "
                f"BLEU={bleu_v:>6.2f}  chrF++={chrf_v:>6.2f}  "
                f"geom={geom_v:>6.2f}  len={len_ratio_v:>5.2f}"
            )
