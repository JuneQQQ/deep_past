def aggregate_cv_fold_summaries(output_dir: str, expected_folds: int) -> None:
    """聚合多折训练结果，输出 CV 均值/方差/最差折摘要。"""
    fold_records = []
    for fold_idx in range(expected_folds):
        summary_path = os.path.join(output_dir, f"fold{fold_idx}", "fold_summary.json")
        if not os.path.exists(summary_path):
            continue
        try:
            with open(summary_path, "r", encoding="utf-8") as f:
                rec = json.load(f)
            fold_records.append(rec)
        except Exception as e:
            print(f"⚠️ 读取 fold 汇总失败: {summary_path} ({e})")

    if not fold_records:
        print("⚠️ 未找到任何 fold_summary.json，跳过 CV 汇总。")
        return

    df = pd.DataFrame(fold_records).sort_values("fold").reset_index(drop=True)
    fold_csv = os.path.join(output_dir, "cv_fold_results.csv")
    df.to_csv(fold_csv, index=False)

    metrics_to_aggregate = [
        "bleu",
        "chrf",
        "geom_mean",
        "mean_len_ratio",
        "under_translation_rate",
        "over_translation_rate",
        "empty_or_near_empty_rate",
        "number_match_rate",
        "entity_match_rate",
        "gap_case_chrf",
    ]

    cv_summary = {
        "num_completed_folds": int(len(df)),
        "expected_folds": int(expected_folds),
    }
    for metric in metrics_to_aggregate:
        if metric not in df.columns:
            continue
        vals = pd.to_numeric(df[metric], errors="coerce").dropna().astype(float)
        if len(vals) == 0:
            continue
        cv_summary[f"{metric}_mean"] = float(vals.mean())
        cv_summary[f"{metric}_std"] = float(vals.std(ddof=0))
        cv_summary[f"{metric}_median"] = float(vals.median())
        cv_summary[f"{metric}_worst"] = float(vals.min())
        cv_summary[f"{metric}_best"] = float(vals.max())
        cv_summary[f"{metric}_best_minus_worst"] = float(vals.max() - vals.min())

    summary_path = os.path.join(output_dir, "cv_summary.json")
    with open(summary_path, "w", encoding="utf-8") as f:
        json.dump(cv_summary, f, indent=2, ensure_ascii=False)

    print("\n📊 CV 汇总:")
    print(f"   Fold results: {fold_csv}")
    print(f"   Summary:      {summary_path}")
    for metric in ("chrf", "bleu", "geom_mean"):
        if f"{metric}_mean" in cv_summary:
            print(
                f"   {metric}: mean={cv_summary[f'{metric}_mean']:.4f} "
                f"std={cv_summary[f'{metric}_std']:.4f} "
                f"worst={cv_summary[f'{metric}_worst']:.4f} "
                f"best={cv_summary[f'{metric}_best']:.4f}"
            )


def _checkpoint_step(path: str) -> int:
    name = os.path.basename(path.rstrip("/"))
    try:
        return int(name.split("checkpoint-")[-1])
    except Exception:
        return -1


def _is_resumable_trainer_checkpoint(path: str) -> bool:
    if not os.path.isdir(path):
        return False
    trainer_state = os.path.join(path, "trainer_state.json")
    optimizer_state = os.path.join(path, "optimizer.pt")
    return os.path.exists(trainer_state) and os.path.exists(optimizer_state)


def _find_latest_resumable_trainer_checkpoint(search_dir: str) -> str | None:
    if not search_dir or not os.path.isdir(search_dir):
        return None
    candidates = [
        p for p in glob.glob(os.path.join(search_dir, "checkpoint-*"))
        if _is_resumable_trainer_checkpoint(p)
    ]
    if not candidates:
        return None
    candidates.sort(key=lambda p: (_checkpoint_step(p), os.path.getmtime(p)))
    return candidates[-1]


def resolve_trainer_resume_checkpoint(output_dir: str, requested: str | None = None) -> str | None:
    if requested and requested.lower() not in {"auto", "latest", "last"}:
        candidate = requested
        if not os.path.isabs(candidate):
            candidate = os.path.abspath(candidate)
        if _is_resumable_trainer_checkpoint(candidate):
            return candidate
        latest = _find_latest_resumable_trainer_checkpoint(candidate)
        if latest:
            return latest
        raise FileNotFoundError(
            f"Requested resume checkpoint is not resumable: {requested}"
        )
    return _find_latest_resumable_trainer_checkpoint(output_dir)


def resolve_run_output_dir(config) -> str:
    if getattr(config, "num_folds", 1) > 1:
        return os.path.join(OUTPUT_ROOT_DIR, f"fold{CURRENT_FOLD}")
    return OUTPUT_DIR


def _metric_name_for_best_model(training_args) -> str:
    metric_name = getattr(training_args, "metric_for_best_model", None) or "bleu"
    if metric_name.startswith("eval_"):
        metric_name = metric_name[len("eval_"):]
    return metric_name


def _extract_metric_value(metrics: dict, metric_name: str, default: float = 0.0) -> float:
    if metric_name in metrics:
        return float(metrics[metric_name])
    prefixed = f"eval_{metric_name}"
    if prefixed in metrics:
        return float(metrics[prefixed])
    return float(default)


def _metric_greater_is_better(training_args) -> bool:
    greater_is_better = getattr(training_args, "greater_is_better", None)
    if greater_is_better is None:
        return _metric_name_for_best_model(training_args) != "loss"
    return bool(greater_is_better)


def _is_better_metric(current_value: float, best_value: float, training_args) -> bool:
    if best_value is None:
        return True
    if _metric_greater_is_better(training_args):
        return current_value > best_value
    return current_value < best_value


def _metric_direction_label(training_args) -> str:
    return "higher" if _metric_greater_is_better(training_args) else "lower"


def resolve_use_safetensors(load_path: str) -> bool:
    """Avoid hub-side auto conversion threads; only prefer safetensors for local dirs that already have them."""
    if not load_path or not os.path.isdir(load_path):
        return False
    safe_names = ("model.safetensors", "model.safetensors.index.json")
    if any(os.path.exists(os.path.join(load_path, name)) for name in safe_names):
        return True
    return False


def build_generate_kwargs(
    *,
    max_new_tokens: int,
    num_beams: int,
    repetition_penalty: float,
    no_repeat_ngram_size: int,
    length_penalty: float,
    early_stopping: bool,
) -> dict:
    kwargs = {
        "max_new_tokens": max_new_tokens,
        # 显式清空旧 generation_config/max_length，避免 transformers 提示
        # "Both `max_new_tokens` and `max_length` seem to have been set"
        "max_length": None,
        "num_beams": num_beams,
        "repetition_penalty": repetition_penalty,
        "no_repeat_ngram_size": no_repeat_ngram_size,
    }
    if num_beams > 1:
        kwargs["length_penalty"] = length_penalty
        kwargs["early_stopping"] = early_stopping
    return kwargs


def build_standard_eval_generate_kwargs(*, max_new_tokens: int | None = None) -> dict:
    """统一普通 generate 路径，和 Trainer.evaluate() 保持同一套基础参数。"""
    return build_generate_kwargs(
        max_new_tokens=config.max_target_length if max_new_tokens is None else int(max_new_tokens),
        num_beams=TRAIN_EVAL_NUM_BEAMS,
        repetition_penalty=config.repetition_penalty,
        no_repeat_ngram_size=config.no_repeat_ngram_size,
        length_penalty=config.length_penalty,
        early_stopping=GENERATE_EARLY_STOPPING,
    )


@contextmanager
def optimized_generation_context(model):
    """在评估/推理期间显式开启 KV cache，避免 gradient checkpointing 场景下生成退化。"""
    cfg = getattr(model, "config", None)
    gen_cfg = getattr(model, "generation_config", None)
    prev_model_use_cache = getattr(cfg, "use_cache", None) if cfg is not None else None
    prev_gen_use_cache = getattr(gen_cfg, "use_cache", None) if gen_cfg is not None else None

    if config.eval_enable_generation_cache:
        if cfg is not None and prev_model_use_cache is not None:
            cfg.use_cache = True
        if gen_cfg is not None and prev_gen_use_cache is not None:
            gen_cfg.use_cache = True

    try:
        yield
    finally:
        if cfg is not None and prev_model_use_cache is not None:
            cfg.use_cache = prev_model_use_cache
        if gen_cfg is not None and prev_gen_use_cache is not None:
            gen_cfg.use_cache = prev_gen_use_cache

RUN_TIMESTAMP = args.timestamp if args.timestamp else datetime.now().strftime("%Y%m%d_%H%M%S")
CURRENT_FOLD = args.fold if args.fold != -1 else 0
OUTPUT_ROOT_DIR = os.path.join(config.root_dir, "output", f"model_{RUN_TIMESTAMP}")
OUTPUT_DIR = OUTPUT_ROOT_DIR
RESUME_FROM_CHECKPOINT = args.resume_from_checkpoint
RUN_INITIAL_EVAL = not args.skip_initial_eval
if args.skip_initial_eval:
    print(f"   ⏭️ --skip_initial_eval: 跳过初始评估 (RUN_INITIAL_EVAL={RUN_INITIAL_EVAL})")
INITIAL_EVAL_NUM_BEAMS = config.num_beams
INITIAL_EVAL_MAX_TARGET_LENGTH = config.max_target_length
if config.use_desc_length_stress_test:
    print("🧨 Length stress test mode: ON (train longest samples first, no shuffle)")

if args.fold == -1 or args.fold == config.num_folds:
    if config.num_folds <= 1:
        print("⚠️ config.num_folds <= 1，将只进行一次训练。")
        args.fold = 0
    else:
        import subprocess
        import sys
        import shutil

        print(f"\n{'='*60}")
        print(f"🚀 自动启动 {config.num_folds} 折训练 (Timestamp: {RUN_TIMESTAMP})")
        print(f"{'='*60}\n")

        # ⚠️ 防止由于中途修改训练数据导致多折数据不一致，提前制作一个数据快照
        output_dir = OUTPUT_ROOT_DIR
        os.makedirs(output_dir, exist_ok=True)
        snapshot_csv = os.path.join(output_dir, "train_snapshot.csv")
        try:
            shutil.copy2(config.train_csv, snapshot_csv)
            print(f"📦 已创建训练数据快照: {snapshot_csv} (多折共用，防中途修改)")
        except Exception as e:
            print(f"⚠️ 创建数据快照失败 ({e})，将回退使用原文件。")
            snapshot_csv = config.train_csv
        
        for f in range(config.num_folds):
            print(f"\n{'='*50}")
            print(f"🚀 开始训练 Fold {f}/{config.num_folds-1}...")
            print(f"{'='*50}")
            
            cmd = [sys.executable, sys.argv[0], "--fold", str(f), "--timestamp", RUN_TIMESTAMP, "--train_csv", snapshot_csv]
            # 传递其他可能存在的参数
            for arg in sys.argv[1:]:
                if not arg.startswith("--fold") and not arg.startswith("--timestamp") and not arg.startswith("--train_csv"):
                    cmd.append(arg)
                    
            try:
                subprocess.run(cmd, check=True)
            except subprocess.CalledProcessError as e:
                print(f"\n❌ Fold {f} 训练失败，退出整个流程。")
                sys.exit(e.returncode)

        aggregate_cv_fold_summaries(output_dir, config.num_folds)
        print("\n🎉 所有 Fold 训练完成！")
        sys.exit(0)

