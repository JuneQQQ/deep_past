_TARGET_TOKEN_RE = re.compile(r"[A-Za-z0-9]+(?:[-'][A-Za-z0-9]+)?")
_SOURCE_NUM_RE = re.compile(r'^(?:\d+(?:/\d+)?|\d+\.\d+)$')
_TARGET_NUMBER_RE = re.compile(r'^\d+(?:/\d+)?(?:\.\d+)?$')
_ENTITY_RE = re.compile(r'\b[A-ZŠṢṬḪ][A-Za-zāēīūšṣṭḫĀĒĪŪŠṢṬḪ]+(?:-[A-Za-zāēīūšṣṭḫĀĒĪŪŠṢṬḪ]+)*\b')
_ENTITY_STOPWORDS = {
    "The", "From", "To", "And", "Or", "If", "Then", "Month", "Year", "Witness", "Witnessed",
    "Seal", "Silver", "Copper", "Gold", "Before", "Concerning", "Total",
}
_NUMBER_WORDS = {
    "one", "two", "three", "four", "five", "six", "seven", "eight", "nine", "ten",
    "mina", "minas", "shekel", "shekels", "talent", "talents", "kor", "gur",
    "liters", "litres", "measure", "measures", "ban", "jar", "jars", "silver",
    "copper", "gold", "interest", "principal",
}
_PAYMENT_KEYWORDS = ("owe", "owes", "owed", "pay", "pays", "paid", "repay", "payment", "deliver", "delivered")
_WITNESS_KEYWORDS = ("witnessed by", "witnesses", "seal of", "sealed by")
_LETTER_KEYWORDS = (" to ", " from ", "speak to", "say to", "message")
_LEGAL_KEYWORDS = ("contract", "lawsuit", "judge", "verdict", "claim", "dispute", "sworn", "testimony")
_ACCOUNT_KEYWORDS = ("total", "balance", "list of", "account", "accounts", "received", "expenditure")
_LOAN_KEYWORDS = ("interest", "owes", "silver", "will pay", "debt", "principal")
_SOURCE_ACCOUNT_KEYWORDS = ("ma-na", "gín", "kù.babbar", "ku.babbar", "an.na", "túg", "silver", "tin")
_OATH_KEYWORDS_TGT = ("swore", "oath", "swear", "swearing")
_OATH_KEYWORDS_SRC = ("gír ša", "it-ma-ma", "it-mu-ú", "ma-mi-tam", "ta-mu-ú")
_DATE_KEYWORDS_TGT = ("eponym", "eponymy")
_DATE_KEYWORDS_SRC = ("itu.kam", "li-mu-um", "li-mu-um-ma")
_DOC_TYPES = ["fragmentary", "witness", "loan", "letter", "account", "legal", "oath", "date", "other"]
_DATA_SOURCES = ["official", "ocr"]
_FOLD_NUMERIC_COLUMNS = ["src_len_tok", "tgt_len_tok", "gap_ratio", "num_ratio", "entity_ratio", "len_ratio_ref"]
current_eval_metadata = pd.DataFrame()
fold_diagnostics_df = pd.DataFrame()
fold_split_records: List[Tuple[np.ndarray, np.ndarray]] = []
current_fold_eval_summary: Dict[str, float] = {}


def format_data_source_stats(frame: pd.DataFrame, source_col: str) -> str:
    if source_col not in frame.columns or len(frame) == 0:
        return "official=0 (0.0%), ocr=0 (0.0%)"
    counts = (
        frame[source_col]
        .fillna("official")
        .astype(str)
        .apply(normalize_data_source_label)
        .value_counts()
    )
    total = max(int(len(frame)), 1)
    parts = []
    for source_name in _DATA_SOURCES:
        count = int(counts.get(source_name, 0))
        parts.append(f"{source_name}={count} ({count / total:.1%})")
    extras = sorted(set(counts.index) - set(_DATA_SOURCES))
    for source_name in extras:
        count = int(counts.get(source_name, 0))
        parts.append(f"{source_name}={count} ({count / total:.1%})")
    return ", ".join(parts)


def print_data_source_stats(frame: pd.DataFrame, split_name: str, source_col: str) -> None:
    print(f"   {split_name} data_source: {format_data_source_stats(frame, source_col)}")


def _tokenize_source(text: str) -> List[str]:
    if not isinstance(text, str):
        return []
    return [tok for tok in str(text).strip().split() if tok]


def _tokenize_target(text: str) -> List[str]:
    if not isinstance(text, str):
        return []
    return _TARGET_TOKEN_RE.findall(str(text))


def extract_numbers(text: str) -> List[str]:
    tokens = _tokenize_target(text)
    results = []
    for tok in tokens:
        low = tok.lower()
        if _TARGET_NUMBER_RE.match(low) or low in _NUMBER_WORDS:
            results.append(low)
    return results


def extract_entities(text: str) -> List[str]:
    if not isinstance(text, str):
        return []
    entities = []
    for ent in _ENTITY_RE.findall(text):
        if ent in _ENTITY_STOPWORDS:
            continue
        entities.append(ent)
    return entities


def infer_doc_type(source_text: str, reference_text: str) -> str:
    src = str(source_text).strip()
    src_low = src.lower()
    text = str(reference_text).strip()
    low = text.lower()

    # 显式保留破损类，避免验证集被纯公式文本主导
    if (
        src_low.count("<gap>") + low.count("<gap>") >= 2
        or src.count("...") + text.count("...") >= 2
        or src.count("…") + text.count("…") >= 2
    ):
        return "fragmentary"

    if any(key in low for key in _WITNESS_KEYWORDS):
        return "witness"
    if any(key in low for key in _LOAN_KEYWORDS):
        return "loan"
    if (
        src_low.startswith("a-na ")
        and ("qí-bi-ma" in src_low or "qi-bi-ma" in src_low or "um-ma" in src_low)
    ) or (
        "um-ma" in src_low and ("qí-bi-ma" in src_low or "qi-bi-ma" in src_low or "qí-bi4-ma" in src_low)
    ) or text.startswith("To ") or text.startswith("From ") or (
        any(key in low for key in _LETTER_KEYWORDS) and "to " in low and " from " in low
    ):
        return "letter"
    if any(key in low for key in _ACCOUNT_KEYWORDS) or any(key in src_low for key in _SOURCE_ACCOUNT_KEYWORDS):
        return "account"
    if any(key in low for key in _LEGAL_KEYWORDS):
        return "legal"
    if any(key in low for key in _OATH_KEYWORDS_TGT) or any(key in src_low for key in _OATH_KEYWORDS_SRC):
        return "oath"
    if any(key in low for key in _DATE_KEYWORDS_TGT) or any(key in src_low for key in _DATE_KEYWORDS_SRC):
        return "date"
    return "other"


def bucketize_series(series: pd.Series, n_bins: int, prefix: str) -> pd.Series:
    values = pd.to_numeric(series, errors="coerce").fillna(0.0)
    unique_vals = int(values.nunique())
    if unique_vals <= 1 or n_bins <= 1:
        return pd.Series([f"{prefix}_0"] * len(values), index=series.index)

    actual_bins = min(n_bins, unique_vals)
    ranked = values.rank(method="first")
    try:
        codes = pd.qcut(ranked, q=actual_bins, labels=False, duplicates="drop")
    except Exception:
        codes = pd.cut(ranked, bins=actual_bins, labels=False, include_lowest=True, duplicates="drop")
    codes = pd.Series(codes, index=series.index).fillna(0).astype(int)
    return codes.map(lambda x: f"{prefix}_{int(x)}")


def build_sample_metadata(frame: pd.DataFrame) -> pd.DataFrame:
    meta = frame.copy().reset_index(drop=True)
    meta["transliteration"] = meta["transliteration"].fillna("").astype(str)
    meta["target_text"] = meta["target_text"].fillna("").astype(str)
    if config.data_source_col in meta.columns:
        meta["data_source"] = meta[config.data_source_col].apply(normalize_data_source_label)
    else:
        meta["data_source"] = "official"

    src_tokens = meta["transliteration"].apply(_tokenize_source)
    tgt_tokens = meta["target_text"].apply(_tokenize_target)
    entity_lists = meta["target_text"].apply(extract_entities)
    number_lists = meta["target_text"].apply(extract_numbers)

    meta["src_len_char"] = meta["transliteration"].str.len()
    meta["src_len_tok"] = src_tokens.apply(len)
    meta["tgt_len_tok"] = tgt_tokens.apply(len)
    meta["len_ratio_ref"] = meta["tgt_len_tok"] / meta["src_len_tok"].clip(lower=1)
    meta["gap_count"] = src_tokens.apply(lambda toks: sum(tok.lower() == "<gap>" for tok in toks))
    meta["gap_ratio"] = meta["gap_count"] / meta["src_len_tok"].clip(lower=1)
    meta["num_count"] = number_lists.apply(len)
    meta["num_ratio"] = meta["num_count"] / meta["tgt_len_tok"].clip(lower=1)
    meta["entity_count"] = entity_lists.apply(len)
    meta["entity_ratio"] = meta["entity_count"] / meta["tgt_len_tok"].clip(lower=1)
    meta["doc_type"] = meta.apply(
        lambda row: infer_doc_type(row["transliteration"], row["target_text"]),
        axis=1,
    )
    meta["avg_word_len"] = tgt_tokens.apply(lambda toks: float(np.mean([len(t) for t in toks])) if toks else 0.0)
    meta["has_interest_formula"] = meta["target_text"].str.lower().str.contains("interest", regex=False)
    meta["has_witness_formula"] = meta["target_text"].str.lower().apply(lambda x: any(k in x for k in _WITNESS_KEYWORDS))
    meta["has_payment_formula"] = meta["target_text"].str.lower().apply(lambda x: any(k in x for k in _PAYMENT_KEYWORDS))

    token_freq = Counter(tok.lower() for toks in tgt_tokens for tok in toks)
    meta["rare_token_ratio"] = tgt_tokens.apply(
        lambda toks: (sum(token_freq[t.lower()] <= 2 for t in toks) / max(len(toks), 1)) if toks else 0.0
    )

    meta["src_len_bucket"] = bucketize_series(meta["src_len_tok"], FOLD_STRATIFY_SRC_BINS, "src")
    meta["gap_ratio_bucket"] = bucketize_series(meta["gap_ratio"], FOLD_STRATIFY_GAP_BINS, "gap")
    meta["num_ratio_bucket"] = bucketize_series(meta["num_ratio"], FOLD_STRATIFY_NUM_BINS, "num")
    meta["entity_ratio_bucket"] = bucketize_series(meta["entity_ratio"], FOLD_STRATIFY_ENTITY_BINS, "ent")
    meta["stratify_label"] = meta.apply(
        lambda row: "|".join([
            f"doc={row['doc_type']}",
            str(row["src_len_bucket"]),
            str(row["gap_ratio_bucket"]),
            str(row["num_ratio_bucket"]),
            str(row["entity_ratio_bucket"]),
        ]),
        axis=1,
    )
    return meta


def build_group_stratified_splits(
    frame: pd.DataFrame,
    group_col: str,
    n_splits: int,
    random_seed: int,
) -> List[Tuple[np.ndarray, np.ndarray]]:
    if group_col not in frame.columns:
        from sklearn.model_selection import KFold
        kf = KFold(n_splits=n_splits, shuffle=True, random_state=random_seed)
        return [(train_idx, eval_idx) for train_idx, eval_idx in kf.split(frame)]

    label_vocab = sorted(frame["stratify_label"].unique())
    label_to_idx = {label: idx for idx, label in enumerate(label_vocab)}
    total_label_counts = np.zeros(len(label_vocab), dtype=np.float64)
    for label, count in frame["stratify_label"].value_counts().items():
        total_label_counts[label_to_idx[label]] = float(count)

    total_numeric_sums = frame[_FOLD_NUMERIC_COLUMNS].sum(axis=0).to_numpy(dtype=np.float64)
    group_infos = []
    for group_id, grp in frame.groupby(group_col, sort=False):
        label_counts = np.zeros(len(label_vocab), dtype=np.float64)
        for label, count in grp["stratify_label"].value_counts().items():
            label_counts[label_to_idx[label]] = float(count)
        rarity_score = float(np.sum(label_counts / np.maximum(total_label_counts, 1.0)))
        group_infos.append(
            {
                "group_id": group_id,
                "sample_count": int(len(grp)),
                "label_counts": label_counts,
                "numeric_sums": grp[_FOLD_NUMERIC_COLUMNS].sum(axis=0).to_numpy(dtype=np.float64),
                "rarity_score": rarity_score,
            }
        )

    rng = np.random.RandomState(random_seed)
    rng.shuffle(group_infos)
    group_infos.sort(
        key=lambda item: (
            item["sample_count"],
            item["rarity_score"],
            float(np.count_nonzero(item["label_counts"])),
        ),
        reverse=True,
    )

    ideal_label_counts = total_label_counts / float(n_splits)
    ideal_numeric_sums = total_numeric_sums / float(n_splits)
    ideal_size = len(frame) / float(n_splits)

    fold_label_counts = np.zeros((n_splits, len(label_vocab)), dtype=np.float64)
    fold_numeric_sums = np.zeros((n_splits, len(_FOLD_NUMERIC_COLUMNS)), dtype=np.float64)
    fold_sizes = np.zeros(n_splits, dtype=np.float64)
    group_to_fold = {}

    for group in group_infos:
        best_fold = None
        best_cost = None
        for fold_idx in range(n_splits):
            candidate_label = fold_label_counts.copy()
            candidate_numeric = fold_numeric_sums.copy()
            candidate_sizes = fold_sizes.copy()

            candidate_label[fold_idx] += group["label_counts"]
            candidate_numeric[fold_idx] += group["numeric_sums"]
            candidate_sizes[fold_idx] += group["sample_count"]

            label_cost = float(
                np.sum((candidate_label - ideal_label_counts) ** 2 / np.maximum(ideal_label_counts, 1.0))
            )
            size_cost = float(
                np.sum((candidate_sizes - ideal_size) ** 2 / max(ideal_size, 1.0))
            ) * FOLD_BALANCE_SIZE_WEIGHT
            numeric_cost = float(
                np.sum((candidate_numeric - ideal_numeric_sums) ** 2 / np.maximum(np.abs(ideal_numeric_sums), 1.0))
            ) * FOLD_BALANCE_NUMERIC_WEIGHT
            cost = label_cost + size_cost + numeric_cost
            if best_cost is None or cost < best_cost - 1e-9 or (
                abs(cost - best_cost) <= 1e-9 and candidate_sizes[fold_idx] < candidate_sizes[best_fold]
            ):
                best_cost = cost
                best_fold = fold_idx

        group_to_fold[group["group_id"]] = int(best_fold)
        fold_label_counts[best_fold] += group["label_counts"]
        fold_numeric_sums[best_fold] += group["numeric_sums"]
        fold_sizes[best_fold] += group["sample_count"]

    splits = []
    group_assignments = frame[group_col].map(group_to_fold)
    for fold_idx in range(n_splits):
        eval_idx = np.where(group_assignments.to_numpy() == fold_idx)[0]
        train_idx = np.where(group_assignments.to_numpy() != fold_idx)[0]
        splits.append((train_idx, eval_idx))
    return splits


def build_group_stratified_holdout(
    frame: pd.DataFrame,
    group_col: str,
    test_size: float,
    random_seed: int,
) -> Tuple[np.ndarray, np.ndarray, int, int]:
    if group_col not in frame.columns:
        from sklearn.model_selection import train_test_split
        all_idx = np.arange(len(frame))
        train_idx, eval_idx = train_test_split(
            all_idx,
            test_size=test_size,
            random_state=random_seed,
            shuffle=True,
        )
        return np.array(train_idx), np.array(eval_idx), 0, 1

    n_groups = int(frame[group_col].nunique())
    if n_groups < 2:
        return np.arange(len(frame)), np.arange(min(1, len(frame))), 0, 1

    approx_splits = int(round(1.0 / max(float(test_size), 1e-6)))
    n_splits = max(2, min(n_groups, approx_splits))
    splits = build_group_stratified_splits(
        frame,
        group_col=group_col,
        n_splits=n_splits,
        random_seed=random_seed,
    )
    target_eval_size = len(frame) * float(test_size)
    chosen_fold_idx = min(
        range(len(splits)),
        key=lambda idx: (
            abs(len(splits[idx][1]) - target_eval_size),
            len(splits[idx][1]),
        ),
    )
    train_idx, eval_idx = splits[chosen_fold_idx]
    return train_idx, eval_idx, chosen_fold_idx, n_splits


def split_subset_holdout_exact(
    frame: pd.DataFrame,
    group_col: str,
    desired_eval_count: int,
    random_seed: int,
) -> Tuple[np.ndarray, np.ndarray, int, int]:
    subset = frame.copy()
    if len(subset) == 0 or desired_eval_count <= 0:
        return subset.index.to_numpy(dtype=int), np.array([], dtype=int), -1, 1
    if desired_eval_count >= len(subset):
        return np.array([], dtype=int), subset.index.to_numpy(dtype=int), 0, 1

    if group_col not in subset.columns:
        all_idx = subset.index.to_numpy(dtype=int)
        rng = np.random.RandomState(random_seed)
        perm = rng.permutation(all_idx)
        eval_idx = np.sort(perm[:desired_eval_count])
        train_idx = np.sort(perm[desired_eval_count:])
        return train_idx, eval_idx, 0, 1

    n_groups = int(subset[group_col].nunique())
    if n_groups < 2:
        # 只有一个 group 时无法无泄漏拆分，择其更接近目标的一侧。
        all_idx = subset.index.to_numpy(dtype=int)
        if abs(len(subset) - desired_eval_count) <= desired_eval_count:
            return np.array([], dtype=int), all_idx, 0, 1
        return all_idx, np.array([], dtype=int), -1, 1

    subset_test_size = max(min(desired_eval_count / max(len(subset), 1), 0.95), 1.0 / max(len(subset), 1))
    train_local, eval_local, chosen_fold_idx, n_splits = build_group_stratified_holdout(
        subset.reset_index(drop=True),
        group_col=group_col,
        test_size=subset_test_size,
        random_seed=random_seed,
    )
    orig_indices = subset.index.to_numpy(dtype=int)
    return (
        np.sort(orig_indices[train_local]),
        np.sort(orig_indices[eval_local]),
        chosen_fold_idx,
        n_splits,
    )


def build_source_balanced_holdout(
    frame: pd.DataFrame,
    group_col: str,
    source_col: str,
    test_size: float,
    target_ocr_ratio: float,
    random_seed: int,
) -> Tuple[np.ndarray, np.ndarray, Dict[str, float]]:
    if source_col not in frame.columns:
        train_idx, eval_idx, chosen_fold_idx, holdout_folds = build_group_stratified_holdout(
            frame,
            group_col=group_col,
            test_size=test_size,
            random_seed=random_seed,
        )
        details = {
            "used_balance": 0.0,
            "target_ocr_ratio": float(target_ocr_ratio),
            "actual_ocr_ratio": float(
                frame.iloc[eval_idx][source_col].apply(normalize_data_source_label).eq("ocr").mean()
            ) if len(eval_idx) and source_col in frame.columns else 0.0,
            "chosen_fold_idx": float(chosen_fold_idx),
            "holdout_folds": float(holdout_folds),
        }
        return train_idx, eval_idx, details

    source_series = frame[source_col].fillna("official").astype(str).apply(normalize_data_source_label)
    ocr_mask = source_series.eq("ocr")
    official_mask = ~ocr_mask
    ocr_count = int(ocr_mask.sum())
    official_count = int(official_mask.sum())
    total_eval_count = max(1, int(round(len(frame) * float(test_size))))

    if ocr_count == 0 or official_count == 0:
        train_idx, eval_idx, chosen_fold_idx, holdout_folds = build_group_stratified_holdout(
            frame,
            group_col=group_col,
            test_size=test_size,
            random_seed=random_seed,
        )
        details = {
            "used_balance": 0.0,
            "target_ocr_ratio": float(target_ocr_ratio),
            "actual_ocr_ratio": float(source_series.iloc[eval_idx].eq("ocr").mean()) if len(eval_idx) else 0.0,
            "chosen_fold_idx": float(chosen_fold_idx),
            "holdout_folds": float(holdout_folds),
        }
        return train_idx, eval_idx, details

    desired_ocr_eval = int(round(total_eval_count * float(target_ocr_ratio)))
    if total_eval_count >= 2:
        desired_ocr_eval = max(1, min(desired_ocr_eval, total_eval_count - 1))
    desired_ocr_eval = min(desired_ocr_eval, ocr_count)
    desired_official_eval = total_eval_count - desired_ocr_eval

    if desired_official_eval > official_count:
        overflow = desired_official_eval - official_count
        desired_official_eval = official_count
        desired_ocr_eval = min(ocr_count, desired_ocr_eval + overflow)
    if desired_ocr_eval > ocr_count:
        overflow = desired_ocr_eval - ocr_count
        desired_ocr_eval = ocr_count
        desired_official_eval = min(official_count, desired_official_eval + overflow)

    ocr_train_idx, ocr_eval_idx, ocr_fold_idx, ocr_splits = split_subset_holdout_exact(
        frame.loc[ocr_mask],
        group_col=group_col,
        desired_eval_count=desired_ocr_eval,
        random_seed=random_seed + 101,
    )
    official_train_idx, official_eval_idx, official_fold_idx, official_splits = split_subset_holdout_exact(
        frame.loc[official_mask],
        group_col=group_col,
        desired_eval_count=desired_official_eval,
        random_seed=random_seed + 202,
    )

    train_idx = np.sort(np.concatenate([ocr_train_idx, official_train_idx])).astype(int)
    eval_idx = np.sort(np.concatenate([ocr_eval_idx, official_eval_idx])).astype(int)
    actual_ocr_ratio = float(source_series.iloc[eval_idx].eq("ocr").mean()) if len(eval_idx) else 0.0
    details = {
        "used_balance": 1.0,
        "target_ocr_ratio": float(target_ocr_ratio),
        "actual_ocr_ratio": actual_ocr_ratio,
        "desired_ocr_eval": float(desired_ocr_eval),
        "desired_official_eval": float(desired_official_eval),
        "ocr_fold_idx": float(ocr_fold_idx),
        "ocr_holdout_folds": float(ocr_splits),
        "official_fold_idx": float(official_fold_idx),
        "official_holdout_folds": float(official_splits),
    }
    return train_idx, eval_idx, details


def summarize_split_dataframe(frame: pd.DataFrame, split_name: str) -> Dict[str, float]:
    summary = {
        "fold": split_name,
        "n_samples": int(len(frame)),
        "mean_src_len": float(frame["src_len_tok"].mean()) if len(frame) else 0.0,
        "mean_tgt_len": float(frame["tgt_len_tok"].mean()) if len(frame) else 0.0,
        "mean_gap_ratio": float(frame["gap_ratio"].mean()) if len(frame) else 0.0,
        "mean_num_ratio": float(frame["num_ratio"].mean()) if len(frame) else 0.0,
        "mean_entity_ratio": float(frame["entity_ratio"].mean()) if len(frame) else 0.0,
        "mean_len_ratio_ref": float(frame["len_ratio_ref"].mean()) if len(frame) else 0.0,
        "mean_rare_token_ratio": float(frame["rare_token_ratio"].mean()) if len(frame) else 0.0,
    }
    if config.fold_group_col in frame.columns:
        summary["n_groups"] = int(frame[config.fold_group_col].nunique())
    for doc_type in _DOC_TYPES:
        summary[f"doc_type_{doc_type}_share"] = float((frame["doc_type"] == doc_type).mean()) if len(frame) else 0.0
    top_docs = frame["doc_type"].value_counts(normalize=True).head(3)
    summary["doc_type_top3"] = "; ".join(f"{k}:{v:.2f}" for k, v in top_docs.items())
    if config.data_source_col in frame.columns:
        normalized_sources = frame[config.data_source_col].fillna("official").astype(str).apply(normalize_data_source_label)
        for source_name in _DATA_SOURCES:
            summary[f"data_source_{source_name}_share"] = float((normalized_sources == source_name).mean()) if len(frame) else 0.0
        top_sources = normalized_sources.value_counts(normalize=True).head(3)
        summary["data_source_top3"] = "; ".join(f"{k}:{v:.2f}" for k, v in top_sources.items())
    return summary


sample_metadata_df = build_sample_metadata(df)
for col in sample_metadata_df.columns:
    if col not in df.columns:
        df[col] = sample_metadata_df[col]
df[config.data_source_col] = sample_metadata_df["data_source"]

metadata_path = os.path.join(OUTPUT_ROOT_DIR, "sample_metadata.csv")
os.makedirs(OUTPUT_ROOT_DIR, exist_ok=True)
df.to_csv(metadata_path, index=False)
print(f"   🧾 Sample metadata saved: {metadata_path}")
print_data_source_stats(df, "Full", config.data_source_col)

# ============================================================
# CELL 5: CREATE DATASET
# ============================================================

from datasets import Dataset, DatasetDict
from transformers import AutoTokenizer

print("\n🔤 Loading tokenizer...")
# 直接查找本地 HF 缓存快照路径，绕过 hub 解析
import glob as _glob
_cache_pattern = os.path.expanduser(f"/root/huggingface_cache/hub/models--{config.model_name.replace('/', '--')}/snapshots/*/config.json")
_cache_hits = _glob.glob(_cache_pattern)
if _cache_hits:
    _resolved_model_path = os.path.dirname(_cache_hits[0])
    print(f"   ✓ 使用本地缓存: {_resolved_model_path}")
else:
    _resolved_model_path = config.model_name
    print(f"   ⚠️ 未找到本地缓存，使用 hub ID: {_resolved_model_path}")

_planned_output_dir = resolve_run_output_dir(config)
_resume_checkpoint_path = resolve_trainer_resume_checkpoint(
    _planned_output_dir,
    RESUME_FROM_CHECKPOINT,
)
_tokenizer_load_path = _resolved_model_path
if _resume_checkpoint_path and os.path.exists(os.path.join(_resume_checkpoint_path, "tokenizer_config.json")):
    _tokenizer_load_path = _resume_checkpoint_path
    print(f"   ♻️ Tokenizer 将从续训 checkpoint 读取: {_tokenizer_load_path}")

# 修复 tokenizer_config.json 中 extra_special_tokens 格式问题
# 旧版 transformers 保存为 list，新版要求 dict → 自动转换
_tok_cfg_path = os.path.join(_tokenizer_load_path, "tokenizer_config.json")
if os.path.exists(_tok_cfg_path):
    import json as _json_mod
    with open(_tok_cfg_path) as _f:
        _tok_cfg = _json_mod.load(_f)
    _est = _tok_cfg.get("extra_special_tokens")
    if isinstance(_est, list):
        _tok_cfg["extra_special_tokens"] = {t: t for t in _est}
        with open(_tok_cfg_path, "w") as _f:
            _json_mod.dump(_tok_cfg, _f, indent=2, ensure_ascii=False)
        print(f"   🔧 修复 tokenizer_config.json: extra_special_tokens list→dict ({len(_est)} tokens)")

tokenizer = AutoTokenizer.from_pretrained(_tokenizer_load_path, local_files_only=True)

# Split data
if config.num_folds > 1:
    # 多 Fold：按 oare_id 分组，并基于 metadata 做启发式分层平衡
    if config.balance_eval_ocr_ratio:
        print("   ℹ️ balance_eval_ocr_ratio 仅在单次 holdout 验证集模式下生效；当前为多 fold，继续使用常规 split。")
    groups = df[config.fold_group_col] if config.fold_group_col in df.columns else None
    if groups is not None:
        n_groups = groups.nunique()
        actual_folds = min(config.num_folds, n_groups)
        if actual_folds < config.num_folds:
            print(f"\n⚠️ 警告: 组数量({n_groups}) 小于 num_folds({config.num_folds})，自动将 n_splits 降为 {actual_folds}")
            if CURRENT_FOLD >= actual_folds:
                print(f"⚠️ 当前 fold({CURRENT_FOLD}) >= 实际最大 fold 数({actual_folds})，无数据可训，直接退出。")
                sys.exit(0)
        else:
            actual_folds = config.num_folds

        if MULTIFOLD_USE_GROUP_STRATIFIED:
            splits = build_group_stratified_splits(
                df,
                group_col=config.fold_group_col,
                n_splits=actual_folds,
                random_seed=config.random_seed,
            )
            print(
                f"   Group-stratified greedy split: fold {CURRENT_FOLD+1}/{actual_folds} "
                f"(group_col={config.fold_group_col})"
            )
        else:
            from sklearn.model_selection import GroupKFold
            gkf = GroupKFold(n_splits=actual_folds)
            splits = list(gkf.split(df, groups=groups))
            print(f"   GroupKFold: fold {CURRENT_FOLD+1}/{actual_folds} (group_col={config.fold_group_col})")

        train_idx, eval_idx = splits[CURRENT_FOLD]
        train_df = df.iloc[train_idx].copy()
        eval_df = df.iloc[eval_idx].copy()
        fold_split_records = splits
    else:
        from sklearn.model_selection import KFold
        kf = KFold(n_splits=config.num_folds, shuffle=True, random_state=config.random_seed)
        splits = list(kf.split(df))
        train_idx, eval_idx = splits[CURRENT_FOLD]
        train_df = df.iloc[train_idx].copy()
        eval_df = df.iloc[eval_idx].copy()
        print(f"   KFold: fold {CURRENT_FOLD+1}/{config.num_folds} (无分组列，纯随机)")
        fold_split_records = splits
else:
    # 单次划分（默认）— 按 oare_id 分组，防止同一文档的不同句子泄露到验证集
    # 仅当周期性 eval 明确关闭时才跳过 holdout 划分。
    _effective_test_size = config.test_size
    if not RUNTIME_EVAL_ENABLED:
        _effective_test_size = 0
        print(f"   ℹ️ Eval 关闭 → 跳过 eval 划分，全量训练")
    if _effective_test_size == 0 or _effective_test_size is None:
        # test_size=0: 全量训练，不划分验证集
        train_df = df.copy()
        eval_df = df.sample(min(50, len(df)), random_state=config.random_seed).copy()
        print(f"   ⚠️ test_size=0: 全量训练，eval 使用 {len(eval_df)} 条采样（仅供监控，不做早停）")
    elif config.fold_group_col in df.columns:
        if MULTIFOLD_USE_GROUP_STRATIFIED:
            if config.balance_eval_ocr_ratio and config.data_source_col in df.columns:
                train_idx, eval_idx, source_balance_details = build_source_balanced_holdout(
                    df,
                    group_col=config.fold_group_col,
                    source_col=config.data_source_col,
                    test_size=config.test_size,
                    target_ocr_ratio=config.target_eval_ocr_ratio,
                    random_seed=config.random_seed,
                )
                chosen_fold_idx = int(source_balance_details.get("ocr_fold_idx", 0))
                holdout_folds = int(max(
                    source_balance_details.get("ocr_holdout_folds", 1.0),
                    source_balance_details.get("official_holdout_folds", 1.0),
                ))
            else:
                train_idx, eval_idx, chosen_fold_idx, holdout_folds = build_group_stratified_holdout(
                    df,
                    group_col=config.fold_group_col,
                    test_size=config.test_size,
                    random_seed=config.random_seed,
                )
                source_balance_details = {
                    "used_balance": 0.0,
                    "target_ocr_ratio": float(config.target_eval_ocr_ratio),
                    "actual_ocr_ratio": float(
                        df.iloc[eval_idx][config.data_source_col].apply(normalize_data_source_label).eq("ocr").mean()
                    ) if config.data_source_col in df.columns and len(eval_idx) else 0.0,
                }
            train_df = df.iloc[train_idx].copy()
            eval_df = df.iloc[eval_idx].copy()
            n_train_groups = train_df[config.fold_group_col].nunique()
            n_eval_groups = eval_df[config.fold_group_col].nunique()
            overlap = set(train_df[config.fold_group_col]) & set(eval_df[config.fold_group_col])
            actual_eval_ratio = len(eval_df) / max(len(df), 1)
            if source_balance_details.get("used_balance", 0.0) >= 0.5:
                print(
                    f"   Source-balanced group holdout: "
                    f"(group_col={config.fold_group_col}, target_test_size={config.test_size:.3f}, "
                    f"actual_eval_ratio={actual_eval_ratio:.3f}, target_ocr_ratio={config.target_eval_ocr_ratio:.2f}, "
                    f"actual_ocr_ratio={source_balance_details.get('actual_ocr_ratio', 0.0):.3f}, overlap={len(overlap)})"
                )
                print(
                    f"   Requested eval mix: ocr≈{int(source_balance_details.get('desired_ocr_eval', 0))}, "
                    f"official≈{int(source_balance_details.get('desired_official_eval', 0))}"
                )
            else:
                print(
                    f"   Group-stratified holdout: selected pseudo-fold {chosen_fold_idx+1}/{holdout_folds} "
                    f"(group_col={config.fold_group_col}, target_test_size={config.test_size:.3f}, "
                    f"actual_eval_ratio={actual_eval_ratio:.3f}, overlap={len(overlap)})"
                )
            print(f"   Groups: {n_train_groups} train groups, {n_eval_groups} eval groups")
        else:
            from sklearn.model_selection import GroupShuffleSplit
            gss = GroupShuffleSplit(n_splits=1, test_size=config.test_size, random_state=config.random_seed)
            train_idx, eval_idx = next(gss.split(df, groups=df[config.fold_group_col]))
            train_df = df.iloc[train_idx].copy()
            eval_df = df.iloc[eval_idx].copy()
            n_train_groups = df.iloc[train_idx][config.fold_group_col].nunique()
            n_eval_groups = df.iloc[eval_idx][config.fold_group_col].nunique()
            overlap = set(train_df[config.fold_group_col]) & set(eval_df[config.fold_group_col])
            print(f"   GroupShuffleSplit: {n_train_groups} train groups, {n_eval_groups} eval groups, overlap={len(overlap)}")
    else:
        from sklearn.model_selection import train_test_split
        train_df, eval_df = train_test_split(df, test_size=config.test_size, random_state=config.random_seed)

# Ensure eval set only contains official (clean) data — move noisy samples back to train
if config.data_source_col in eval_df.columns:
    _eval_is_official = eval_df[config.data_source_col].apply(normalize_data_source_label).eq("official")
    _n_noisy_eval = (~_eval_is_official).sum()
    if _n_noisy_eval > 0:
        print(f"   🔒 Eval 仅保留 official 数据: 移除 {_n_noisy_eval} 条非官方样本 → 训练集")
        train_df = pd.concat([train_df, eval_df[~_eval_is_official]], ignore_index=True)
        eval_df = eval_df[_eval_is_official].copy()

# Fix transliteration-level leakage: remove eval samples whose TL appears in train
if "transliteration" in train_df.columns and "transliteration" in eval_df.columns:
    train_tls = set(train_df["transliteration"])
    eval_tl_overlap = eval_df["transliteration"].isin(train_tls)
    n_overlap = eval_tl_overlap.sum()
    if n_overlap > 0:
        print(f"   ⚠️ Removing {n_overlap} eval samples with TL overlap (formulaic phrases across documents)")
        eval_df = eval_df[~eval_tl_overlap].copy()

print(f"   Train: {len(train_df)}, Eval: {len(eval_df)}")
print_data_source_stats(train_df, "Train", config.data_source_col)
print_data_source_stats(eval_df, "Eval", config.data_source_col)

# Save train/eval splits with all key columns
_split_save_cols = [c for c in ["oare_id", "transliteration", "translation", "data_source", "uncertainty",
                                 "input_text", "target_text"] if c in train_df.columns]
_train_split_path = os.path.join(OUTPUT_DIR, "split_train.csv")
_eval_split_path = os.path.join(OUTPUT_DIR, "split_eval.csv")
train_df[_split_save_cols].to_csv(_train_split_path, index=False)
eval_df[_split_save_cols].to_csv(_eval_split_path, index=False)
print(f"   💾 Split saved: {_train_split_path} ({len(train_df)} rows)")
print(f"   💾 Split saved: {_eval_split_path} ({len(eval_df)} rows)")

if config.num_folds > 1 and fold_split_records:
    diag_rows = []
    for fold_idx, (_, fold_eval_idx) in enumerate(fold_split_records):
        fold_eval_df = df.iloc[fold_eval_idx].copy()
