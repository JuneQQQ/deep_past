# CELL 8: TRAINING SETUP
# ============================================================

from transformers import Seq2SeqTrainingArguments, Seq2SeqTrainer, DataCollatorForSeq2Seq, TrainerCallback, EarlyStoppingCallback

# EMA Callback (只负责更新，不负责切换)
class EMACallback(TrainerCallback):
    """EMA 回调：仅 rank 0 维护 Shadow Weights，节省其他 rank 的 CPU RAM。"""
    
    def __init__(self, decay: float):
        self.decay = decay
        self.ema_state_dict = None  # 仅 rank 0 非 None
        self.step_count = 0
    
    def on_train_begin(self, args, state, control, model=None, **kwargs):
        if model is not None and _is_main_process():
            # 仅 rank 0 初始化 EMA 参数 (放在 CPU 节省显存)
            self.ema_state_dict = {
                k: v.data.clone().detach().to('cpu')
                for k, v in model.named_parameters()
            }
            print(f"   📊 EMA 初始化完成 (decay={self.decay}, params={len(self.ema_state_dict)}, rank0_only=True)")
        return control
    
    def on_step_end(self, args, state, control, model=None, **kwargs):
        if model is not None and self.ema_state_dict is not None:
            self.step_count += 1
            # 动态 decay 策略 (Warmup)
            decay = min(self.decay, (1 + self.step_count) / (EMA_WARMUP_STEPS + self.step_count))
            
            with torch.no_grad():
                for name, param in model.named_parameters():
                    if name in self.ema_state_dict:
                        # 移动到 GPU 进行计算，算完放回 CPU
                        ema_param = self.ema_state_dict[name].to(param.device)
                        ema_param.mul_(decay).add_(param.data, alpha=1 - decay)
                        self.ema_state_dict[name] = ema_param.cpu()
        return control
    
    @property
    def has_ema(self) -> bool:
        """仅 rank 0 持有 EMA state dict。"""
        return self.ema_state_dict is not None


# Dynamic token-budget batch sampler
from train_utils import DynamicTokenBatchSampler


# EMATrainer (负责 Swap-Eval-Restore + Curriculum Learning)
class EMATrainer(Seq2SeqTrainer):
    """自定义 Trainer：评估时切换到 EMA 参数，支持 Curriculum Learning 和 R-Drop"""
    
    def __init__(self, ema_callback=None, curriculum_until_epoch=0, *args, **kwargs):
        # 暂时移除 tokenizer 以避免 TypeError (某些旧/新版本兼容性问题)
        tokenizer = kwargs.pop('tokenizer', None)
        train_data_collator = kwargs.pop('train_data_collator', None)
        eval_data_collator = kwargs.get('data_collator', None)
        
        super().__init__(*args, **kwargs)
        
        # 手动设置 tokenizer
        if tokenizer is not None:
            self.tokenizer = tokenizer
            
        self.ema_callback = ema_callback
        self.curriculum_until_epoch = curriculum_until_epoch  # 前 N epoch 禁用 shuffle
        self.eval_data_collator = eval_data_collator or self.data_collator
        self.train_data_collator = train_data_collator or self.data_collator
        self.data_collator = self.eval_data_collator
        self._train_token_acc_correct = 0
        self._train_token_acc_total = 0
        self._eval_token_acc_correct = 0
        self._eval_token_acc_total = 0

    def _accumulate_train_token_accuracy(self, logits, labels):
        correct_tokens, valid_tokens = _token_accuracy_counts(logits, labels)
        self._train_token_acc_correct += correct_tokens
        self._train_token_acc_total += valid_tokens

    def _accumulate_eval_token_accuracy(self, logits, labels):
        correct_tokens, valid_tokens = _token_accuracy_counts(logits, labels)
        self._eval_token_acc_correct += correct_tokens
        self._eval_token_acc_total += valid_tokens

    def log(self, logs, *args, **kwargs):
        logs = dict(logs)
        if 'loss' in logs and 'eval_loss' not in logs:
            # Training step log
            if self._train_token_acc_total > 0:
                logs['train_token_acc'] = self._train_token_acc_correct / self._train_token_acc_total
            self._train_token_acc_correct = 0
            self._train_token_acc_total = 0
        if 'eval_loss' in logs:
            # Eval step log — inject eval_token_acc accumulated during eval forward passes
            if self._eval_token_acc_total > 0:
                logs['eval_token_acc'] = self._eval_token_acc_correct / self._eval_token_acc_total
            self._eval_token_acc_correct = 0
            self._eval_token_acc_total = 0
        return super().log(logs, *args, **kwargs)

    def _compute_supervised_loss(self, logits, labels, use_dft=False, label_smoothing=0.0):
        token_logits = logits.contiguous()
        token_labels = labels.contiguous()

        if token_labels.numel() == 0:
            return token_logits.sum() * 0.0

        valid_mask = token_labels.ne(-100)
        safe_labels = torch.where(valid_mask, token_labels, torch.zeros_like(token_labels))
        log_probs = F.log_softmax(token_logits.float(), dim=-1)
        nll_loss = -log_probs.gather(-1, safe_labels.unsqueeze(-1)).squeeze(-1)

        if label_smoothing > 0.0:
            smooth_loss = -log_probs.mean(dim=-1)
            token_loss = (1.0 - label_smoothing) * nll_loss + label_smoothing * smooth_loss
        else:
            token_loss = nll_loss

        token_loss = token_loss.to(token_logits.dtype)
        valid_mask_f = valid_mask.to(token_loss.dtype)

        if use_dft:
            token_counts = valid_mask_f.sum(dim=-1).clamp(min=1.0)
            seq_nll = (nll_loss.to(token_loss.dtype) * valid_mask_f).sum(dim=-1) / token_counts
            seq_conf = torch.exp(-seq_nll.float()).clamp_(0.0, 1.0)
            seq_weights = (1.0 - seq_conf).pow(config.dft_gamma).detach()
            seq_weights = seq_weights / seq_weights.mean().clamp(min=1e-6)
            seq_weights = seq_weights.clamp(min=config.dft_min_weight, max=config.dft_max_weight)

            if config.dft_warmup_steps > 0:
                current_step = self.state.global_step if self.state else 0
                warmup_ratio = min(1.0, current_step / max(config.dft_warmup_steps, 1))
                seq_weights = 1.0 + (seq_weights - 1.0) * warmup_ratio

            token_loss = token_loss * seq_weights.to(token_loss.dtype).unsqueeze(-1)

        valid_count = valid_mask_f.sum().clamp(min=1.0)
        return (token_loss * valid_mask_f).sum() / valid_count
    
    class _CoverageCapture:
        """Context manager: captures cross-attention from ONE decoder layer.

        Instead of setting ``output_attentions=True`` globally (which disables
        SDPA for ALL layers and causes OOM on byte-level models), we monkey-
        patch only the target decoder cross-attention module so that:
        - Only 1 layer falls back to naive attention (to return weights).
        - All other layers keep using SDPA (fast, memory-efficient).
        - Memory overhead: O(B*H*Td*Te) for 1 layer instead of ~24 layers.
        """

        def __init__(self, model, layer_index=-1):
            _real = model.module if hasattr(model, 'module') else model
            self._block = _real.decoder.block[layer_index]
            self._target = self._block.layer[1].EncDecAttention
            self._orig_forward = self._target.forward
            self.cross_attn = None

        def __enter__(self):
            import functools
            outer = self

            @functools.wraps(self._orig_forward)
            def _patched(*args, **kwargs):
                kwargs['output_attentions'] = True
                result = outer._orig_forward(*args, **kwargs)
                # T5Attention returns: (attn_out, present_kv, pos_bias[, attn_weights])
                if len(result) > 3:
                    outer.cross_attn = result[3]
                return result

            self._target.forward = _patched
            return self

        def __exit__(self, *exc):
            self._target.forward = self._orig_forward
            return False

    def compute_loss(self, model, inputs, return_outputs=False, num_items_in_batch=None):
        """R-Drop 正则化（终极优化版）
        
        优化点：
        1. Batched Forward: 输入 cat 一次前向，Dropout 自动给出不同掩码，速度 ~2x
        2. log_target=True: 避免 .exp() 在 FP16/BF16 下数值下溢
        3. float mask: 布尔→浮点，兼容 BetterTransformer 等严格算子
        4. KL clamp + alpha warmup: 防止训练初期梯度爆炸
        """
        labels = inputs.get('labels')
        _need_coverage = config.use_coverage_loss and model.training and labels is not None
        if not config.use_rdrop and not config.use_dft and not _need_coverage:
            loss, outputs = super().compute_loss(
                model,
                dict(inputs),
                return_outputs=True,
                num_items_in_batch=num_items_in_batch,
            )
            if labels is not None:
                _logits = _extract_logits_from_outputs(outputs)
                if model.training:
                    self._accumulate_train_token_accuracy(_logits, labels)
                else:
                    self._accumulate_eval_token_accuracy(_logits, labels)
            if return_outputs:
                return loss, outputs
            return loss

        if labels is None:
            return super().compute_loss(model, inputs, return_outputs, num_items_in_batch)

        if not config.use_rdrop:
            _fwd_kwargs = dict(inputs)
            _cov_cap = None
            if _need_coverage:
                _cov_cap = self._CoverageCapture(model, _cov_cfg.layer_index)
                _cov_cap.__enter__()
            outputs = model(**_fwd_kwargs)
            if _cov_cap is not None:
                _cov_cap.__exit__(None, None, None)
            loss = self._compute_supervised_loss(
                outputs.logits,
                labels,
                use_dft=config.use_dft,
                label_smoothing=config.label_smoothing_factor,
            )
            if _cov_cap is not None and _cov_cap.cross_attn is not None:
                _cov_raw = compute_coverage_loss((_cov_cap.cross_attn,), labels, _cov_cfg)
                _step = self.state.global_step if self.state else 0
                _cov_alpha = _cov_cfg.alpha * min(1.0, _step / max(_cov_cfg.warmup_steps, 1))
                loss = loss + _cov_alpha * _cov_raw
                _cov_cap.cross_attn = None
            if model.training:
                self._accumulate_train_token_accuracy(outputs.logits, labels)
            else:
                self._accumulate_eval_token_accuracy(outputs.logits, labels)
            if return_outputs:
                outputs.loss = loss
                return loss, outputs
            return loss
        
        # 多卡 device_map='auto' 不兼容（position_bias 设备冲突）
        if hasattr(model, 'hf_device_map'):
            if not getattr(self, '_rdrop_multi_gpu_warned', False):
                print("   ⚠️ R-Drop 在多卡 device_map='auto' 下不兼容，已降级为标准 CE loss")
                self._rdrop_multi_gpu_warned = True
            outputs = model(**inputs)
            loss = self._compute_supervised_loss(
                outputs.logits,
                labels,
                use_dft=config.use_dft,
                label_smoothing=config.label_smoothing_factor,
            )
            if model.training:
                self._accumulate_train_token_accuracy(outputs.logits, labels)
            else:
                self._accumulate_eval_token_accuracy(outputs.logits, labels)
            if return_outputs:
                outputs.loss = loss
                return loss, outputs
            return loss
        
        # Batched Forward: 沿 batch 维度复制输入，一次前向得到两份独立 Dropout 结果
        inputs_doubled = {
            k: torch.cat([v, v], dim=0) if isinstance(v, torch.Tensor) else v
            for k, v in inputs.items()
        }
        _cov_cap = None
        if _need_coverage:
            _cov_cap = self._CoverageCapture(model, _cov_cfg.layer_index)
            _cov_cap.__enter__()
        outputs = model(**inputs_doubled)
        if _cov_cap is not None:
            _cov_cap.__exit__(None, None, None)
        
        # 从中间切开，恢复两份输出
        logits1, logits2 = outputs.logits.chunk(2, dim=0)  # (B, T, V) each
        
        ce_loss = 0.5 * (
            self._compute_supervised_loss(
                logits1,
                labels,
                use_dft=config.use_dft,
                label_smoothing=config.label_smoothing_factor,
            )
            + self._compute_supervised_loss(
                logits2,
                labels,
                use_dft=config.use_dft,
                label_smoothing=config.label_smoothing_factor,
            )
        )
        
        # KL 散度计算
        mask = (labels != -100)  # (B, T)
        float_mask = mask.to(logits1.dtype)  # 类型安全
        n_valid = float_mask.sum().clamp(min=1)
        
        # log_softmax（数值稳定）
        log_p = F.log_softmax(logits1, dim=-1)
        log_q = F.log_softmax(logits2, dim=-1)
        
        # detach 目标分布，KL 只约束一致性不干扰 CE 梯度
        log_p_target = log_p.detach()
        log_q_target = log_q.detach()
        
        # log_target=True: 直接用 log 概率计算 KL，避免 .exp() 的 FP16 下溢
        kl_pq = F.kl_div(log_q, log_p_target, reduction='none', log_target=True).sum(dim=-1)  # (B, T)
        kl_qp = F.kl_div(log_p, log_q_target, reduction='none', log_target=True).sum(dim=-1)  # (B, T)
        
        # clamp 防止异常峰值
        kl_pq = kl_pq.clamp(max=100.0)
        kl_qp = kl_qp.clamp(max=100.0)
        
        kl_loss = 0.5 * ((kl_pq * float_mask).sum() + (kl_qp * float_mask).sum()) / n_valid
        
        # Alpha warmup: 前 500 步线性增长
        rdrop_warmup_steps = 500
        current_step = self.state.global_step if self.state else 0
        alpha = config.rdrop_alpha * min(1.0, current_step / max(rdrop_warmup_steps, 1))
        
        loss = ce_loss + alpha * kl_loss

        # Coverage loss (R-Drop path: use first half of doubled cross-attentions)
        if _cov_cap is not None and _cov_cap.cross_attn is not None:
            _cross_half = _cov_cap.cross_attn.chunk(2, dim=0)[0]
            _cov_raw = compute_coverage_loss((_cross_half,), labels, _cov_cfg)
            _cov_alpha = _cov_cfg.alpha * min(1.0, current_step / max(_cov_cfg.warmup_steps, 1))
            loss = loss + _cov_alpha * _cov_raw
            _cov_cap.cross_attn = None

        if model.training:
            self._accumulate_train_token_accuracy(logits1, labels)
        else:
            self._accumulate_eval_token_accuracy(logits1, labels)

        if return_outputs:
            import copy
            outputs_single = copy.copy(outputs)
            outputs_single.logits = logits1
            outputs_single.loss = loss
            return loss, outputs_single
        return loss
    
    def get_train_dataloader(self):
        """重写以支持 Curriculum Learning（前 N epoch 禁用 shuffle，之后恢复）"""
        current_epoch = self.state.epoch if self.state and self.state.epoch is not None else 0
        train_collator = self.train_data_collator
        in_curriculum = self.curriculum_until_epoch > 0 and current_epoch < self.curriculum_until_epoch
        use_sequential_order = config.use_desc_length_stress_test or in_curriculum

        if config.max_tokens_per_batch > 0:
            from torch.utils.data import DataLoader

            batch_sampler = DynamicTokenBatchSampler(
                self.train_dataset,
                max_tokens=config.max_tokens_per_batch,
                shuffle=not use_sequential_order,
                drop_last=self.args.dataloader_drop_last,
                seed=config.random_seed,
                bucket_size=config.dynamic_batch_bucket_size,
                max_examples=config.dynamic_batch_max_examples,
            )
            if not getattr(self, "_dynamic_batch_sampler_logged", False):
                batch_stats = batch_sampler.stats()
                print(
                    "   📦 Dynamic token batch:"
                    f" max_tokens={config.max_tokens_per_batch},"
                    f" avg_batch={batch_stats['avg_batch_size']:.2f},"
                    f" max_batch={int(batch_stats['max_batch_size'])},"
                    f" avg_tokens={batch_stats['avg_batch_tokens']:.1f},"
                    f" fill={batch_stats['mean_fill_ratio']*100:.1f}%"
                )
                self._dynamic_batch_sampler_logged = True
            return DataLoader(
                self.train_dataset,
                batch_sampler=batch_sampler,
                collate_fn=train_collator,
                num_workers=self.args.dataloader_num_workers,
            )

        if use_sequential_order:
            from torch.utils.data import DataLoader, SequentialSampler
            return DataLoader(
                self.train_dataset,
                batch_size=self.args.per_device_train_batch_size,
                sampler=SequentialSampler(self.train_dataset),
                collate_fn=train_collator,
                drop_last=self.args.dataloader_drop_last,
                num_workers=self.args.dataloader_num_workers,
            )
        orig_collator = self.data_collator
        self.data_collator = train_collator
        try:
            return super().get_train_dataloader()
        finally:
            self.data_collator = orig_collator

    def get_eval_dataloader(self, eval_dataset=None):
        """评估阶段使用独立 worker 配置，避免 tokenize/collate 压在主线程上。"""
        # 临时覆盖相关参数，构造完后恢复
        orig_collator = self.data_collator
        orig_nw = self.args.dataloader_num_workers
        orig_pf = self.args.dataloader_prefetch_factor
        orig_pw = self.args.dataloader_persistent_workers
        self.data_collator = self.eval_data_collator
        eval_num_workers = max(int(getattr(config, "eval_dataloader_num_workers", orig_nw)), 0)
        self.args.dataloader_num_workers = eval_num_workers
        self.args.dataloader_prefetch_factor = 2 if eval_num_workers > 0 else None
        self.args.dataloader_persistent_workers = bool(eval_num_workers > 0)
        try:
            return super().get_eval_dataloader(eval_dataset)
        finally:
            self.data_collator = orig_collator
            self.args.dataloader_num_workers = orig_nw
            self.args.dataloader_prefetch_factor = orig_pf
            self.args.dataloader_persistent_workers = orig_pw

    def _ema_broadcast_params(self):
        """DDP: 将 rank 0 的模型参数广播到所有 rank，确保 EMA swap 后各 rank 一致。"""
        try:
            import torch.distributed as dist
            if dist.is_initialized() and dist.get_world_size() > 1:
                for param in self.model.parameters():
                    dist.broadcast(param.data, src=0)
        except Exception:
            pass

    def evaluate(self, eval_dataset=None, ignore_keys=None, metric_key_prefix="eval"):
        # 0. 启动 collator 输入缓存（用于记录模型实际输入）
        if hasattr(self, 'data_collator') and hasattr(self.data_collator, 'collecting_eval_inputs'):
            self.data_collator.eval_inputs_buffer = []
            self.data_collator.collecting_eval_inputs = True
        
        # 1. 切换到 EMA 参数
        #    rank 0 持有 ema_state_dict，交换后广播到所有 rank
        if self.ema_callback is not None:
            if self.ema_callback.has_ema:
                print(f"\n   🔄 [Eval] 切换到 EMA 参数进行评估...")
                with torch.no_grad():
                    for name, param in self.model.named_parameters():
                        if name in self.ema_callback.ema_state_dict:
                            train_data_cpu = param.data.clone().cpu()
                            param.data.copy_(self.ema_callback.ema_state_dict[name].to(param.device))
                            self.ema_callback.ema_state_dict[name] = train_data_cpu
            self._ema_broadcast_params()
            self._ema_swapped = True
        
        # 2. 执行评估 (此时所有 rank 的模型都是 EMA 状态)
        with optimized_generation_context(self.model):
            metrics = super().evaluate(eval_dataset, ignore_keys, metric_key_prefix)
        
        # 3. 恢复原始参数
        #    rank 0 交换回 train 参数，广播到所有 rank
        if self.ema_callback is not None and getattr(self, '_ema_swapped', False):
            if self.ema_callback.has_ema:
                print(f"   💾 [Eval] 恢复原始参数继续训练...")
                with torch.no_grad():
                    for name, param in self.model.named_parameters():
                        if name in self.ema_callback.ema_state_dict:
                            ema_data_cpu = param.data.clone().cpu()
                            param.data.copy_(self.ema_callback.ema_state_dict[name].to(param.device))
                            self.ema_callback.ema_state_dict[name] = ema_data_cpu
            self._ema_broadcast_params()
            self._ema_swapped = False
        # 3.5 清理 eval 阶段的显存碎片（generate 的 KV-cache/beam buffers 碎片化显存池）
        gc.collect()
        torch.cuda.empty_cache()
            
        # 4. 停止 collator 输入缓存
        if hasattr(self, 'data_collator') and hasattr(self.data_collator, 'collecting_eval_inputs'):
            self.data_collator.collecting_eval_inputs = False
        
        return metrics

    def save_model(self, output_dir=None, _internal_call=False):
        """重写 save_model 以在保存时使用 EMA 参数。
        仅 rank 0 做 swap（只有 rank 0 实际写文件），不需要广播。"""
        # 1. Rank 0 切换到 EMA 参数
        if self.ema_callback is not None and self.ema_callback.has_ema:
            if _is_main_process(): print(f"   💾 [Save] 切换到 EMA 参数进行保存...")
            with torch.no_grad():
                for name, param in self.model.named_parameters():
                    if name in self.ema_callback.ema_state_dict:
                        train_data_cpu = param.data.clone().cpu()
                        param.data.copy_(self.ema_callback.ema_state_dict[name].to(param.device))
                        self.ema_callback.ema_state_dict[name] = train_data_cpu
            self._ema_swapped = True
            
        # 2. 临时卸载 boundary wrapper，避免 HF save_pretrained 误判 shared weights
        #    BoundaryAwareEmbeddingWrapper 把 shared.weight 挂为 original_embed，
        #    导致 tied-weight 检测发现意外的共享路径而报错。
        _raw_model = getattr(self.model, "module", self.model)
        _enc_wrapper = getattr(getattr(_raw_model, "encoder", None), "embed_tokens", None)
        _dec_wrapper = getattr(getattr(_raw_model, "decoder", None), "embed_tokens", None)
        _boundary_unwrapped = False
        try:
            if _boundary_wrapper is not None and _enc_wrapper is _boundary_wrapper:
                _raw_model.encoder.embed_tokens = _boundary_wrapper.original_embed
                if _dec_wrapper is _boundary_wrapper:
                    _raw_model.decoder.embed_tokens = _boundary_wrapper.original_embed
                _boundary_unwrapped = True

            # 2.1 执行保存 (HF Trainer 仅 rank 0 写文件)
            super().save_model(output_dir, _internal_call)

        finally:
            # 2.2 恢复 boundary wrapper
            if _boundary_unwrapped:
                _raw_model.encoder.embed_tokens = _boundary_wrapper
                if _dec_wrapper is _boundary_wrapper:
                    _raw_model.decoder.embed_tokens = _boundary_wrapper
        
        # 2.5 保存 boundary-aware side embedding（如果已安装）
        if _is_main_process() and _boundary_wrapper is not None:
            _save_dir = output_dir or self.args.output_dir
            _saved_path = save_side_embedding(self.model, _save_dir)
            if _saved_path:
                print(f"   💾 [Save] Boundary side embedding → {_saved_path}")
        # 2.6 保存 latent bottleneck 权重（如果已安装）
        if _is_main_process() and _bottleneck_layer is not None:
            _save_dir = output_dir or self.args.output_dir
            _saved_path = save_bottleneck_weights(self.model, _save_dir)
            if _saved_path:
                print(f"   💾 [Save] Latent bottleneck → {_saved_path}")
        
        # 3. Rank 0 恢复原始参数
        if self.ema_callback is not None and getattr(self, '_ema_swapped', False):
            if _is_main_process(): print(f"   💾 [Save] 恢复原始参数继续训练...")
            with torch.no_grad():
                for name, param in self.model.named_parameters():
                    if name in self.ema_callback.ema_state_dict:
                        ema_data_cpu = param.data.clone().cpu()
                        param.data.copy_(self.ema_callback.ema_state_dict[name].to(param.device))
                        self.ema_callback.ema_state_dict[name] = ema_data_cpu
            # 注意：save_model 不做 broadcast。save 通常紧跟 evaluate 之后调用，
            # evaluate 已经做了 broadcast 恢复。save_model 中的 swap/restore 仅影响
            # rank 0（只有 rank 0 实际写文件），其他 rank 参数未被改变。
            self._ema_swapped = False

# Data collator with dynamic simulate_damage and placeholder masking
class DynamicDamageCollator(DataCollatorForSeq2Seq):
    """
    动态数据整理器：在每个 batch 生成时动态模拟数据损坏、应用提示或 RAG 注入。
    """
    def __init__(self, tokenizer, model=None, padding=True, max_length=None, pad_to_multiple_of=None, label_pad_token_id=-100, return_tensors="pt", use_damage=True, placeholder_service=None):
        super().__init__(tokenizer, model, padding, max_length, pad_to_multiple_of, label_pad_token_id, return_tensors)
        self.use_damage = use_damage
        self.placeholder_service = placeholder_service
        self.collecting_eval_inputs = False
        self.eval_inputs_buffer = []
        # 添加统计计数器
        self.stats = {
            'total_samples': 0,
            'rag_injected': 0,
            'ocr_noise_applied': 0,
            'ocr_noise_applied_on_ocr': 0,
            'hint_applied': 0,
            'placeholder_applied': 0,
            'sumerogram_injected': 0,
            'month_hint_applied': 0,
        }
        self._aug_sample_log = []  # 句子级注入详情缓冲
        self._AUG_LOG_CAP = 200   # 每个 eval 周期最多记录条数
    
    def _count_gaps(self, text):
        """统计文本中的 Gap 数量"""
        if not text:
            return 0
        import re
        return len(re.findall(r'<gap>', text, re.I))
    
    def _compute_gap_penalty(self, src_text, tgt_text):
        """
        计算 Gap 不对等惩罚：差异越大，越不适合应用 damage
        返回: True=应该跳过 damage, False=可以 damage
        """
        src_gaps = self._count_gaps(src_text)
        tgt_gaps = self._count_gaps(tgt_text)
        # 如果差异 > 2，跳过 damage（避免雪上加霜）
        return abs(src_gaps - tgt_gaps) > 2
    
    def __call__(self, features):
        import random
        
        for feature in features:
            raw_input = feature.get('raw_input')
            raw_target = feature.get('raw_target')
            raw_data_source = feature.get('raw_data_source', 'official')
            
            if raw_input:
                # 分离 prefix 和实际内容
                content = _strip_any_task_prefix(raw_input)
                # 识别当前样本使用的前缀（用于最终重新拼接）
                _used_prefix = raw_input[:len(raw_input) - len(content)] if content != raw_input else config.task_prefix
                is_eval = self.collecting_eval_inputs
                
                # 检查 Gap 不对等
                skip_damage = self._compute_gap_penalty(content, raw_target)
                
                # 1. 动态应用损坏模拟（Gap 不对等时跳过）
                if self.use_damage and config.use_simulate_damage and not skip_damage:
                    content = simulate_damage(content, config.damage_prob, config.damage_span_prob)
                    # Meta prefix 模式下，损坏模拟可能改变完整度 → 重建前缀
                    if config.use_meta_prefix:
                        _used_prefix = _build_meta_prefix(content, raw_data_source)

                if not is_eval and config.use_simulate_ocr_noise:
                    source_label = normalize_data_source_label(raw_data_source)
                    noise_prob = (
                        config.ocr_noise_prob_on_ocr
                        if source_label == "ocr"
                        else config.ocr_noise_prob
                    )
                    noised_content = simulate_ocr_noise(content, noise_prob)
                    if noised_content != content:
                        content = noised_content
                        self.stats['ocr_noise_applied'] += 1
                        if source_label == "ocr":
                            self.stats['ocr_noise_applied_on_ocr'] += 1
                
                # 2. 专名处理 (hint / placeholder)
                # 训练时随机应用（数据增强），评估时 100% 应用（对齐 infer.py 行为）
                _aug_tags = []  # 本样本的注入标签
                if config.name_handling_mode == 'placeholder' and self.placeholder_service:
                    if is_eval or random.random() < config.placeholder_ratio:
                        content, raw_target, _ph_map = self.placeholder_service.apply_placeholders(
                            content, raw_target
                        )
                        if _ph_map:
                            self.stats['placeholder_applied'] += 1
                            _aug_tags.append(f"PH:{','.join(f'{t}={v[1]}' for t,v in _ph_map.items())}")
                elif config.name_handling_mode == 'hint' and (_lexicon or _calibrated_lexicon):
                    if is_eval or random.random() < config.hint_ratio:
                        _content_before_hint = content
                        if is_eval:
                            # 评估时：用校准词典（与推理一致，val 预测 test）
                            lex = _calibrated_lexicon if _calibrated_lexicon else _lexicon
                            content = _apply_hints(content, lex)
                        else:
                            # 训练时：60% per-sample（从 TR 提取），40% 校准词典
                            if raw_target and random.random() < 0.6:
                                content = _apply_hints_persample(content, raw_target)
                            else:
                                lex = _calibrated_lexicon if _calibrated_lexicon else _lexicon
                                content = _apply_hints(content, lex)
                        if content != _content_before_hint:
                            self.stats['hint_applied'] += 1
                            # 提取注入的 hint 前缀
                            _hint_prefix = content[:content.find('] ')+1] if '] ' in content else ''
                            _aug_tags.append(f"Hint:{_hint_prefix}")
                
                # 2.5 月份 hint（独立子开关，不依赖 name_handling_mode）
                if config.use_month_hints:
                    _content_before_mh = content
                    content = _apply_month_hints(content)
                    if content != _content_before_mh:
                        self.stats['month_hint_applied'] += 1
                        _aug_tags.append("MonthHint")

                # 2.6 Sumerogram 词义注入
                if _sumerogram_glossary:
                    _content_before_sg = content
                    content = _inject_sumerogram_hints(content, _sumerogram_glossary, max_hints=config.max_sumerogram_hints)
                    if content != _content_before_sg:
                        self.stats['sumerogram_injected'] += 1
                        # 提取 Sumerogram 前缀
                        _sg_prefix = content[:content.find('] ')+1] if '] ' in content else ''
                        _aug_tags.append(f"Sumerogram:{_sg_prefix}")
                
                # 3. RAG 示例注入（离线预计算缓存，O(1) 查表）
                #    格式：自然序列拼接（ByT5 不理解 [Example] 等指令格式）
                rag_prefix = ""
                if config.use_rag and _rag_cache and random.random() < config.rag_prob:
                    examples = _rag_cache.get(content)
                    if examples:
                        parts = [f"{ex['source']} | {ex['target']}" for ex in examples]
                        rag_prefix = " || ".join(parts) + " || "
                        self.stats['rag_injected'] += 1
                        _aug_tags.append(f"RAG:{len(examples)}ex")
                
                self.stats['total_samples'] += 1
                
                # 句子级注入详情记录
                if _aug_tags and len(self._aug_sample_log) < self._AUG_LOG_CAP:
                    self._aug_sample_log.append({
                        'src': _strip_any_task_prefix(raw_input)[:120],
                        'final': content[:120],
                        'tags': _aug_tags,
                    })
                
                # 重新 tokenize 输入
                final_input = rag_prefix + _used_prefix + content
                if self.collecting_eval_inputs:
                    self.eval_inputs_buffer.append(final_input)
                new_inputs = self.tokenizer(
                    final_input,
                    max_length=config.max_input_length,
                    padding=False,
                    truncation=True,
                )
                feature['input_ids'] = new_inputs['input_ids']
                feature['attention_mask'] = new_inputs['attention_mask']
                
                # 重新 tokenize 目标（如果被修改）
                if raw_target:
                    new_labels = self.tokenizer(
                        raw_target,
                        max_length=config.max_target_length,
                        padding=False,
                        truncation=True,
                    )
                    feature['labels'] = new_labels['input_ids']
        
        # 移除 raw_* 字段（不需要传给模型）
        for feature in features:
            feature.pop('raw_input', None)
            feature.pop('raw_target', None)
            feature.pop('raw_data_source', None)
        
        return super().__call__(features)

# 初始化 PlaceholderService（如果 placeholder 模式）
_placeholder_svc = None
if config.name_handling_mode == 'placeholder':
    # [NOTE: Deleted get_placeholder_service import for notebook compatibility]
    _placeholder_svc = get_placeholder_service(_onomasticon, _lexicon)
    print(f"   📌 Placeholder 模式 (ratio={config.placeholder_ratio}, lexicon={len(_lexicon)} 条映射)")
elif config.name_handling_mode == 'hint':
    print(f"   📌 Hint 模式 (hint_ratio={config.hint_ratio}, max_hints={config.max_hints_per_sample}, lexicon={len(_lexicon)} 条映射)")
else:
    print(f"   📌 专名处理: 关闭")
if _sumerogram_glossary:
    print(f"   📌 Sumerogram 注入: 开启 ({len(_sumerogram_glossary)} entries, max={config.max_sumerogram_hints})")
else:
    print("   📌 Sumerogram 注入: 关闭")
if config.use_rag and _rag_cache:
    print(f"   📌 RAG 示例注入: 开启 (cache={len(_rag_cache)}, prob={config.rag_prob})")
elif config.use_rag:
    print(f"   📌 RAG 示例注入: 请求开启，但 cache 不可用")

eval_data_collator = DynamicDamageCollator(
    tokenizer, model, 
    use_damage=True, 
    placeholder_service=_placeholder_svc
)

train_data_collator = eval_data_collator
print("   📦 Train collator: dynamic damage/hint/RAG/sumerogram aware")


def _extract_logits_from_outputs(outputs):
    if outputs is None:
        return None
    if isinstance(outputs, dict):
        return outputs.get("logits")
    if hasattr(outputs, "logits"):
        return outputs.logits
    if isinstance(outputs, (tuple, list)) and len(outputs) > 1:
        return outputs[1]
    return None


def _token_accuracy_counts(logits, labels) -> Tuple[int, int]:
    if logits is None or labels is None:
        return 0, 0

    with torch.no_grad():
        valid_mask = labels.ne(-100)
        valid_tokens = int(valid_mask.sum().item())
        if valid_tokens <= 0:
            return 0, 0

        preds = logits.argmax(dim=-1)
        correct_tokens = int(((preds == labels) & valid_mask).sum().item())
        return correct_tokens, valid_tokens


def compute_teacher_forced_metrics_on_dataset(
    model,
    dataset,
    collator,
    batch_size: int,
    *,
    num_workers: int | None = None,
) -> Dict[str, float]:
    """在 eval mode 下对给定数据集计算 teacher-forced loss/token acc，不做生成。"""
    if dataset is None or len(dataset) == 0:
        return {
            "loss": float("nan"),
            "token_acc": float("nan"),
            "correct_tokens": 0.0,
            "valid_tokens": 0.0,
            "num_examples": 0.0,
        }

    from torch.utils.data import DataLoader, SequentialSampler

    device = next(model.parameters()).device
    prev_collecting = getattr(collator, "collecting_eval_inputs", False)
    prev_buffer = getattr(collator, "eval_inputs_buffer", None)

    if hasattr(collator, "collecting_eval_inputs"):
        # 强制走 eval 路径，保证 hint/placeholder 与正式评估保持一致。
        collator.collecting_eval_inputs = True
    if hasattr(collator, "eval_inputs_buffer"):
        collator.eval_inputs_buffer = []

    dataloader = DataLoader(
        dataset,
        batch_size=max(int(batch_size), 1),
        sampler=SequentialSampler(dataset),
        collate_fn=collator,
        num_workers=max(
            int(
                config.eval_dataloader_num_workers
                if num_workers is None
                else num_workers
            ),
            0,
        ),
    )

    total_loss = 0.0
    total_examples = 0
    total_correct_tokens = 0
    total_valid_tokens = 0
    for batch in dataloader:
        tensor_batch = {
            key: value.to(device)
            for key, value in batch.items()
            if isinstance(value, torch.Tensor)
        }
        with torch.inference_mode():
            outputs = model(**tensor_batch)
        batch_size_cur = int(tensor_batch["input_ids"].size(0))
        total_loss += float(outputs.loss.detach().item()) * batch_size_cur
        total_examples += batch_size_cur
        correct_tokens, valid_tokens = _token_accuracy_counts(
            _extract_logits_from_outputs(outputs),
            tensor_batch.get("labels"),
        )
        total_correct_tokens += correct_tokens
        total_valid_tokens += valid_tokens

    if hasattr(collator, "collecting_eval_inputs"):
        collator.collecting_eval_inputs = prev_collecting
    if hasattr(collator, "eval_inputs_buffer"):
        collator.eval_inputs_buffer = prev_buffer if prev_buffer is not None else []

    return {
        "loss": total_loss / max(total_examples, 1),
        "token_acc": (
            total_correct_tokens / total_valid_tokens
            if total_valid_tokens > 0 else float("nan")
        ),
        "correct_tokens": float(total_correct_tokens),
        "valid_tokens": float(total_valid_tokens),
        "num_examples": float(total_examples),
    }


def compute_teacher_forced_loss_on_dataset(model, dataset, collator, batch_size: int) -> float:
    """兼容旧调用方：仅返回 teacher-forced loss。"""
    return compute_teacher_forced_metrics_on_dataset(
        model,
        dataset,
        collator,
        batch_size,
    )["loss"]

custom_loss_handles_label_smoothing = config.use_rdrop or config.use_dft
trainer_label_smoothing = 0.0 if custom_loss_handles_label_smoothing else config.label_smoothing_factor
effective_label_smoothing = config.label_smoothing_factor

# Training arguments
_training_args_kwargs = dict(
    output_dir=OUTPUT_DIR,
    
    # Training schedule
    num_train_epochs=config.num_epochs,
    per_device_train_batch_size=config.train_batch_size,
    per_device_eval_batch_size=config.eval_batch_size,
    gradient_accumulation_steps=config.gradient_accumulation,
    
    # Learning rate
    learning_rate=config.learning_rate,
    warmup_ratio=config.warmup_ratio,
    lr_scheduler_type=config.lr_scheduler_type,
    weight_decay=config.weight_decay,
    
    # 精度控制：仅允许 bf16 或 fp32（fp16 对 ByT5 数值不稳定，已禁用）
    bf16=config.use_bf16,
    fp16=False,
    
    # Evaluation / saving policy is selected automatically from runtime mode.
    eval_strategy="no" if not RUNTIME_EVAL_ENABLED else config.eval_strategy,
    eval_steps=(
        config.eval_steps
        if (RUNTIME_EVAL_ENABLED and str(config.eval_strategy).lower() == "steps")
        else None
    ),
    eval_delay=config.eval_steps if (not RUN_INITIAL_EVAL and RUNTIME_EVAL_ENABLED) else 0,
    load_best_model_at_end=RUNTIME_LOAD_BEST_MODEL_AT_END,
    
    # DataLoader (eval 阶段强制设为 0，防止多进程导致 eval_inputs_buffer 无法同步到主进程记录)
    dataloader_num_workers=config.dataloader_num_workers,
    eval_do_concat_batches=False,
    dataloader_prefetch_factor=2 if config.dataloader_num_workers > 0 else None,
    dataloader_persistent_workers=True if config.dataloader_num_workers > 0 else False,
    save_strategy=config.save_strategy,
    save_steps=config.save_steps,
    save_total_limit=config.save_total_limit,
    save_only_model=RUNTIME_SAVE_ONLY_MODEL,
    metric_for_best_model=METRIC_FOR_BEST_MODEL,
    greater_is_better=(
        False if METRIC_FOR_BEST_MODEL.replace("eval_", "") == "loss"
        else config.greater_is_better
    ),
    
    # Logging
    logging_steps=config.logging_steps,
    logging_dir=os.path.join(OUTPUT_DIR, "logs"),
    report_to=config.report_to,
    
    # Generation for eval (FSDP 下 generate 不兼容分片，关闭以保留 eval_loss)
    predict_with_generate=(config.predict_with_generate and not IS_FSDP_RUNTIME),
    generation_max_length=config.max_target_length,
    generation_num_beams=TRAIN_EVAL_NUM_BEAMS,
    include_for_metrics=["inputs"],  # 保存模型实际输入到 predictions.csv（含 HINTS 等）
    
    # Other
    remove_unused_columns=config.remove_unused_columns,
    optim=config.optim,
    gradient_checkpointing=config.gradient_checkpointing,
    gradient_checkpointing_kwargs={"use_reentrant": False},
    
    # 高级优化
    label_smoothing_factor=trainer_label_smoothing,
)

# FSDP 配置（非空时注入，内联 dict 无需外部文件）
if config.fsdp:
    _training_args_kwargs["fsdp"] = config.fsdp
    _training_args_kwargs["fsdp_config"] = config.fsdp_config
    # FSDP 模式：
    # - gradient_checkpointing=False：Trainer 禁止同时开启 HF gradient_checkpointing 和
    #   FSDP activation_checkpointing（会抛 ValueError），必须关闭 HF 侧。
    # - activation_checkpointing=True 在 fsdp_config 中（避免 AllGather 冗余）。
    # - T5 兼容性通过下方 monkey-patch 修复（use_reentrant=False）。
    _training_args_kwargs["gradient_checkpointing"] = False

# DDP: R-Drop 双 forward 导致 shared embedding 无梯度，需要 find_unused_parameters
if config.use_rdrop:
    _training_args_kwargs["ddp_find_unused_parameters"] = True

_seq2seq_args_params = inspect.signature(Seq2SeqTrainingArguments.__init__).parameters
if "group_by_length" in _seq2seq_args_params:
    _training_args_kwargs["group_by_length"] = config.group_by_length
elif "sortish_sampler" in _seq2seq_args_params:
    _training_args_kwargs["sortish_sampler"] = config.group_by_length

_unsupported_training_args = sorted(
    key for key in _training_args_kwargs.keys()
    if key not in _seq2seq_args_params
)
if _unsupported_training_args:
    print(f"   ⚠️ Dropping unsupported training args for transformers {transformers.__version__}: {', '.join(_unsupported_training_args)}")
for _key in _unsupported_training_args:
    _training_args_kwargs.pop(_key, None)

training_args = Seq2SeqTrainingArguments(**_training_args_kwargs)

# 根据消融开关构建回调列表和 Trainer
ema_callback = None
callbacks = []
if config.use_ema:
    ema_callback = EMACallback(decay=config.ema_decay)
    callbacks.append(ema_callback)
    print(f"   📊 EMA 已启用 (decay={config.ema_decay})")

if RUNTIME_EARLY_STOPPING:
    early_stopping_cb = EarlyStoppingCallback(
        early_stopping_patience=EARLY_STOPPING_PATIENCE,
        early_stopping_threshold=EARLY_STOPPING_THRESHOLD
    )
    callbacks.append(early_stopping_cb)
    print(f"   ⏱️ Early Stopping 已启用 (patience={EARLY_STOPPING_PATIENCE})")

# FSDP + T5 activation_checkpointing 兼容性修复：
# 根因：FSDP activation_checkpointing=True 时，HF Trainer 不调用 gradient_checkpointing_enable()，
# 因此 model.config.use_cache 保持默认 True。T5Stack (decoder).forward 会创建 DynamicCache 并
# 在每个 Block 中填充 KV 缓存。CheckpointWrapper 以引用方式捕获这个可变 Python 对象。
# backward recompute 时，同一个已填充的 cache 被传入 T5Block.forward 再次 update()，
# 导致 key_states 长度翻倍（277→554），而 position_bias 仍为 277 → 维度不匹配崩溃。
#
# 修复：显式关闭 use_cache，使 T5Stack.forward 中 past_key_values 始终为 None，
# cache.update() 永远不会被调用，从根本上消除 recompute 时的 KV 积累问题。
if IS_FSDP_RUNTIME and config.fsdp_config.get("activation_checkpointing"):
    model.config.use_cache = False
    if hasattr(model, "generation_config") and model.generation_config is not None:
        model.generation_config.use_cache = False
    print("   🔧 [FSDP] model.config.use_cache=False (防止 T5 DynamicCache recompute 时 KV 长度翻倍)")

# Trainer (使用 EMATrainer 实现 Swap-Eval-Restore + Curriculum Learning)
_trainer_kwargs = dict(
    ema_callback=ema_callback,  # 传入 EMA callback
    curriculum_until_epoch=config.curriculum_epochs if config.use_curriculum else 0,
    model=model,
    args=training_args,
    train_dataset=train_dataset,
    eval_dataset=eval_dataset,
    data_collator=eval_data_collator,
    train_data_collator=train_data_collator,
    compute_metrics=(None if IS_FSDP_RUNTIME else compute_metrics),
    callbacks=callbacks if callbacks else None,
)
_trainer_params = inspect.signature(EMATrainer.__init__).parameters
if "processing_class" in _trainer_params:
    _trainer_kwargs["processing_class"] = tokenizer
elif "tokenizer" in _trainer_params:
    _trainer_kwargs["tokenizer"] = tokenizer

trainer = EMATrainer(**_trainer_kwargs)
# transformers 5.x: T5 的 **kwargs 导致 model_accepts_loss_kwargs=True，
# 但 label_smoother 不做 num_items_in_batch 缩放，需要手动关闭以确保
# training_step 正确除以 gradient_accumulation_steps，否则梯度和 logged loss 均被放大 grad_accum 倍。
trainer.model_accepts_loss_kwargs = False

# DDP + gradient checkpointing:
# 旧方案: static_graph=True — 但与 R-Drop 所需的 find_unused_parameters=True 互斥，
# PyTorch DDP 不允许两者同时开启，导致仍报 "Expected to mark a variable ready only once"。
# 新方案: gradient_checkpointing_kwargs={"use_reentrant": False}（已在 training_args 中设置），
# 非重入 checkpoint 不会在 backward 中重放 forward，从根本上消除参数被标记两次的问题，
# 且与 find_unused_parameters=True 完全兼容。
if IS_MULTI_CARD and not IS_FSDP_RUNTIME and config.gradient_checkpointing:
    print("   🔧 [DDP] use_reentrant=False (非重入 gradient checkpointing，兼容 find_unused_parameters)")

# HF Trainer 会在首个训练 step 内因 gradient checkpointing 自动把 use_cache 关掉，
# 这里提前关闭，避免每个 rank 都重复打印 warning。
if config.gradient_checkpointing and getattr(model.config, "use_cache", None):
    model.config.use_cache = False
    if hasattr(model, "generation_config") and model.generation_config is not None:
        model.generation_config.use_cache = False
    print("   🔧 model.config.use_cache=False (gradient checkpointing 训练期禁用 KV cache)")

print("\n⚙️ Training configuration:")
print(f"   Epochs: {config.num_epochs}")
if config.max_tokens_per_batch > 0:
    print(
        f"   Train batch size: dynamic by tokens "
        f"(max_tokens={config.max_tokens_per_batch}, grad_accum={config.gradient_accumulation})"
    )
    if config.dynamic_batch_max_examples > 0:
        print(f"      hard max examples / batch: {config.dynamic_batch_max_examples}")
else:
    print(f"   Train batch size: {config.train_batch_size} (effective: {config.train_batch_size * config.gradient_accumulation})")
print(f"   Eval batch size:  {config.eval_batch_size}")
print(f"   Learning rate: {config.learning_rate}")
print(f"   Precision: {'bf16' if config.use_bf16 else 'fp32'}")
print(
    f"   Runtime mode: world_size={RUNTIME_WORLD_SIZE}  "
    f"multi_card={IS_MULTI_CARD}  fsdp_runtime={IS_FSDP_RUNTIME}"
)
print(
    f"   Resolved policy: eval_strategy={training_args.eval_strategy}  "
    f"load_best_model_at_end={training_args.load_best_model_at_end}  "
    f"save_only_model={training_args.save_only_model}  "
    f"early_stopping={RUNTIME_EARLY_STOPPING}"
)
if RUNTIME_POLICY_NOTES:
    print("   Auto policy changes:")
    for _note in RUNTIME_POLICY_NOTES:
        print(f"      - {_note}")
print(f"   DFT: {config.use_dft}")
if config.use_dft:
    print(
        f"   DFT mode: {config.dft_mode} "
        f"(gamma={config.dft_gamma}, weight=[{config.dft_min_weight}, {config.dft_max_weight}], warmup={config.dft_warmup_steps})"
    )
print(
    f"   Label smoothing (effective): {effective_label_smoothing} "
    f"({'custom loss' if custom_loss_handles_label_smoothing else 'trainer'})"
)

# ============================================================
# CELL 9: TRAIN!
# ============================================================

print("\n" + "="*60)
print("🚀 STARTING TRAINING")
print("="*60)

import time as _time_mod
from datetime import datetime, timezone, timedelta
_tz_shanghai = timezone(timedelta(hours=8))
_training_wall_start = _time_mod.time()
print(f"   启动时间: {datetime.now(_tz_shanghai).strftime('%Y-%m-%d %H:%M:%S')} (上海)")

# AGGRESSIVE DISK CLEANUP before training

def clear_disk_space():
    """Clear old checkpoints."""
    if _resume_checkpoint_path:
        print("   ♻️ 检测到自动续训，保留现有 checkpoints。")
        gc.collect()
        torch.cuda.empty_cache()
        return
    if os.path.exists(OUTPUT_DIR):
        for item in os.listdir(OUTPUT_DIR):
            item_path = os.path.join(OUTPUT_DIR, item)
            if item.startswith("checkpoint-") and os.path.isdir(item_path):
                shutil.rmtree(item_path, ignore_errors=True)
        print("   Cleared old checkpoints")
    gc.collect()
    torch.cuda.empty_cache()


def cleanup_resume_checkpoints(output_dir: str, keep_paths: List[str]) -> None:
    """只保留当前 checkpoint 和最佳 checkpoint，控制磁盘占用同时保留自动续训能力。"""
    if not os.path.isdir(output_dir):
        return

    keep_realpaths = {
        os.path.realpath(path)
        for path in keep_paths
        if path and os.path.isdir(path)
    }

    checkpoint_dirs = sorted(
        [
            os.path.join(output_dir, item)
            for item in os.listdir(output_dir)
            if item.startswith("checkpoint-") and os.path.isdir(os.path.join(output_dir, item))
        ],
        key=_checkpoint_step,
    )

    for checkpoint_dir in checkpoint_dirs:
        if os.path.realpath(checkpoint_dir) in keep_realpaths:
            continue
        shutil.rmtree(checkpoint_dir, ignore_errors=True)
        print(f"   🗑️ Deleted old checkpoint: {os.path.basename(checkpoint_dir)}")

os.makedirs(OUTPUT_DIR, exist_ok=True)
clear_disk_space()
cleanup_output_root_model_artifacts(OUTPUT_DIR)

# Load a few test samples for demo translations
test_csv_path = getattr(config, "test_csv", None)
if test_csv_path and os.path.exists(test_csv_path):
    test_samples_df = pd.read_csv(test_csv_path)
    DEMO_SAMPLES = test_samples_df['transliteration'].head(DEMO_SAMPLE_COUNT).tolist()
else:
    DEMO_SAMPLES = [DEMO_FALLBACK]

class DiskSpaceCallback(TrainerCallback):
    """Callback to manage disk space and show demo translations."""
    
    def __init__(self, output_dir, model, tokenizer, demo_samples):
        self.output_dir = output_dir
        self.model = model
        self.tokenizer = tokenizer
        self.demo_samples = demo_samples
        self.best_metric = None
        self.best_metric_name = None
        self.best_metric_direction = None
        self.best_checkpoint = None
        self._pending_best_step = None
    
    def on_save(self, args, state, control, **kwargs):
        """同步写入配置文件，并只保留 current/best 两个 checkpoint。"""
        if not _is_main_process():
            return control
        current_ckpt = os.path.join(self.output_dir, f"checkpoint-{state.global_step}")
        if self._pending_best_step == state.global_step and os.path.isdir(current_ckpt):
            self.best_checkpoint = current_ckpt
            self._pending_best_step = None
        for target_dir in (current_ckpt, self.best_checkpoint):
            if target_dir is not None and os.path.isdir(target_dir):
                sync_checkpoint_sidecars(target_dir, config)

        cleanup_resume_checkpoints(
            self.output_dir,
            keep_paths=[self.best_checkpoint, current_ckpt],
        )
        
        # Clear cache
        gc.collect()
        torch.cuda.empty_cache()
        return control
    
    def on_train_end(self, args, state, control, **kwargs):
        """训练结束后对训练集采样推理"""
        if not _is_main_process():
            return control
        if TRAIN_PREDICT_SAMPLE_COUNT > 0 and 'train_df' in globals():
            print(f"\n{'─'*60}")
            print(f"📊 训练结束，采样 {TRAIN_PREDICT_SAMPLE_COUNT} 条训练数据推理...")
            print(f"{'─'*60}")
            self._log_train_predictions(state)
        return control

    def _log_train_predictions(self, state):
        """训练结束后对训练集采样推理，记录原始输入输出（无后处理）"""
        import csv as _csv
        
        n = TRAIN_PREDICT_SAMPLE_COUNT
        sample_df = train_df.sample(min(n, len(train_df)), random_state=42)
        
        if _is_distributed:
            print("   ⏭️ 多卡模式，跳过 train predictions")
            return

        self.model.eval()
        device = next(self.model.parameters()).device
        _pred_model = self.model.module if hasattr(self.model, 'module') else self.model
        
        rows = []
        batch_size = 8
        input_texts = sample_df['input_text'].tolist()
        target_texts = sample_df['target_text'].tolist()
        
        for start in range(0, len(input_texts), batch_size):
            batch_inputs = input_texts[start:start+batch_size]
            batch_targets = target_texts[start:start+batch_size]
            
            tokens = self.tokenizer(
                batch_inputs, return_tensors="pt", padding=True,
                truncation=True, max_length=config.max_input_length
            )
            tokens = {k: v.to(device) for k, v in tokens.items()}
            
            with torch.no_grad():
                outputs = _pred_model.generate(
                    **tokens,
                    **build_standard_eval_generate_kwargs(),
                )
            
            decoded = self.tokenizer.batch_decode(outputs, skip_special_tokens=True)
            
            for inp, tgt, raw_pred in zip(batch_inputs, batch_targets, decoded):
                rows.append([inp, raw_pred, tgt])
        
        # 写入 CSV（覆盖写，训练结束只写一次）
        train_preds_csv = os.path.join(self.output_dir, "train_predictions.csv")
        try:
            with open(train_preds_csv, 'w', newline='', encoding='utf-8') as f:
                writer = _csv.writer(f)
                writer.writerow(['model_input', 'raw_model_output', 'reference'])
                writer.writerows(rows)
                f.flush()
                os.fsync(f.fileno())
            
            print(f"   📄 Train predictions: {len(rows)} samples → {train_preds_csv}")
        except Exception as e:
            print(f"   ⚠️ Failed to save train_predictions.csv: {e}")
    
    def on_evaluate(self, args, state, control, metrics=None, **kwargs):
        """Track best checkpoint, show demo translations, and log to CSV."""
        if not _is_main_process():
            return control
        global _last_eval_predictions
        if metrics:
            metric_name = _metric_name_for_best_model(args)
            current_metric = _extract_metric_value(metrics, metric_name, 0.0)
            current_epoch = state.epoch if state.epoch is not None else 0.0
            
            # 1. 从 state.log_history 提取最近的 train loss
            train_loss = None
            train_token_acc = None
            for entry in reversed(state.log_history):
                if 'loss' in entry and 'eval_loss' not in entry:
                    train_loss = entry['loss']
                    train_token_acc = entry.get('train_token_acc')
                    break
            eval_loss = metrics.get('eval_loss', 0)
            train_probe_loss = None
            train_probe_token_acc = None
            train_probe_time = None
            eval_token_acc = None
            eval_tf_time = None
            # DDP/FSDP: compute_teacher_forced_metrics_on_dataset 在 rank 0 单独
            # 调用 model.forward()，但 DDP/FSDP 需要所有 rank 同步参与 → 会死锁。
            # on_evaluate 仅 rank 0 执行，其他 rank 已 return，无法参与 DDP forward。
            # 跳过 train_probe 和 eval_token_acc，只用 Trainer 内置的 eval_loss。
            if not IS_FSDP_RUNTIME and not IS_MULTI_CARD:
                if (
                    config.compute_train_probe_metrics
                    and TRAIN_PROBE_EVAL_SAMPLES > 0
                    and 'train_probe_dataset' in globals()
                    and train_probe_dataset is not None
                ):
                    probe_t0 = time.perf_counter()
                    try:
                        train_probe_metrics = compute_teacher_forced_metrics_on_dataset(
                            self.model,
                            train_probe_dataset,
                            kwargs.get('data_collator') or eval_data_collator,
                            args.per_device_eval_batch_size,
                            num_workers=config.eval_dataloader_num_workers,
                        )
                        train_probe_loss = train_probe_metrics['loss']
                        train_probe_token_acc = train_probe_metrics['token_acc']
                        train_probe_time = time.perf_counter() - probe_t0
                        metrics['train_probe_loss'] = train_probe_loss
                        metrics['train_probe_token_acc'] = train_probe_token_acc
                    except Exception as e:
                        print(f"   ⚠️ train_probe_loss 计算失败: {e}")
                
                if config.compute_eval_token_acc and 'eval_dataset' in globals() and eval_dataset is not None:
                    eval_t0 = time.perf_counter()
                    try:
                        eval_tf_metrics = compute_teacher_forced_metrics_on_dataset(
                            self.model,
                            eval_dataset,
                            kwargs.get('data_collator') or eval_data_collator,
                            args.per_device_eval_batch_size,
                            num_workers=config.eval_dataloader_num_workers,
                        )
                        eval_token_acc = eval_tf_metrics['token_acc']
                        eval_tf_time = time.perf_counter() - eval_t0
                        metrics['eval_token_acc'] = eval_token_acc
                    except Exception as e:
                        print(f"   ⚠️ eval_token_acc 计算失败: {e}")
            if train_token_acc is not None:
                metrics['train_token_acc'] = train_token_acc
            
            # 提取训练期增强统计
            aug_stats_str = ""
            try:
                # 获取 DataCollator 的统计
                collator_obj = kwargs.get('data_collator') or eval_data_collator
                if hasattr(collator_obj, 'stats'):
                    collator_stats = collator_obj.stats
                    total = collator_stats.get('total_samples', 0)
                    aug_parts = []
                    if total > 0:
                        if config.use_rag:
                            injected = collator_stats.get('rag_injected', 0)
                            rag_rate = (injected / total) * 100
                            aug_parts.append(f"RAG {injected}/{total} ({rag_rate:.1f}%)")
                        else:
                            aug_parts.append("RAG OFF")
                    if total > 0 and config.use_simulate_ocr_noise:
                        ocr_applied = collator_stats.get('ocr_noise_applied', 0)
                        ocr_rate = (ocr_applied / total) * 100
                        ocr_on_ocr = collator_stats.get('ocr_noise_applied_on_ocr', 0)
                        if ocr_on_ocr > 0:
                            aug_parts.append(
                                f"OCR-noise {ocr_applied}/{total} ({ocr_rate:.1f}%, ocr_src={ocr_on_ocr})"
                            )
                        else:
                            aug_parts.append(f"OCR-noise {ocr_applied}/{total} ({ocr_rate:.1f}%)")
                    if total > 0:
                        if config.name_handling_mode == 'hint':
                            _h = collator_stats.get('hint_applied', 0)
                            aug_parts.append(f"Hint {_h}/{total} ({_h/total*100:.1f}%)")
                        elif config.name_handling_mode == 'placeholder':
                            _p = collator_stats.get('placeholder_applied', 0)
                            aug_parts.append(f"Placeholder {_p}/{total} ({_p/total*100:.1f}%)")
                        else:
                            aug_parts.append(f"Hint OFF(mode={config.name_handling_mode})")
                        if _sumerogram_glossary:
                            _sg = collator_stats.get('sumerogram_injected', 0)
                            aug_parts.append(f"Sumerogram {_sg}/{total} ({_sg/total*100:.1f}%)")
                        else:
                            aug_parts.append("Sumerogram OFF")
                        if config.use_month_hints:
                            _mh = collator_stats.get('month_hint_applied', 0)
                            aug_parts.append(f"MonthHint {_mh}/{total} ({_mh/total*100:.1f}%)")
                        else:
                            aug_parts.append("MonthHint OFF")
                    if aug_parts:
                        aug_stats_str = f"│ {' | '.join(aug_parts)}"

                    if total > 0:
                        for _k in collator_stats:
                            collator_stats[_k] = 0
            except Exception:
                pass
            
            # 打印指标（醒目）
            _bleu = metrics.get('eval_bleu', 0)
            _chrf = metrics.get('eval_chrf', 0)
            _geom = metrics.get('eval_geom_mean', 0)
            print(f"\n   ┌─── Step {state.global_step} (epoch {current_epoch:.1f}) ───┐")
            if IS_FSDP_RUNTIME:
                print(f"   │ [FSDP] eval_loss only (no generate)    │")
            else:
                print(f"   │ BLEU={_bleu:>6.2f}  chrF++={_chrf:>6.2f}  geom={_geom:>6.2f} │")
            if train_loss is not None and train_probe_loss is not None:
                print(
                    f"   │ loss: train={train_loss:.4f} probe={train_probe_loss:.4f} val={eval_loss:.4f} │"
                )
                print(
                    f"   │ gap: train-val={train_loss - eval_loss:+.4f}  probe-val={train_probe_loss - eval_loss:+.4f} │"
                )
            elif train_loss is not None:
                print(
                    f"   │ loss: train={train_loss:.4f} val={eval_loss:.4f}" +
                    (f" gap={train_loss - eval_loss:+.4f}" if train_loss is not None else "") + " │"
                )
            else:
                print(f"   │ loss: val={eval_loss:.4f}{'':>30}│")
            if any(v is not None for v in (train_token_acc, train_probe_token_acc, eval_token_acc)):
                tok_acc_parts = []
                if train_token_acc is not None:
                    tok_acc_parts.append(f"train={train_token_acc:.4f}")
                if train_probe_token_acc is not None:
                    tok_acc_parts.append(f"probe={train_probe_token_acc:.4f}")
                if eval_token_acc is not None:
                    tok_acc_parts.append(f"val={eval_token_acc:.4f}")
                print(f"   │ tok_acc: {'  '.join(tok_acc_parts)} │")
            if train_probe_loss is not None and train_probe_time is not None:
                eval_tf_suffix = (
                    f" eval_tf={eval_tf_time:>5.2f}s"
                    if eval_tf_time is not None else ""
                )
                print(
                    f"   │ train_probe: n={len(train_probe_dataset):>3}  time={train_probe_time:>5.2f}s{eval_tf_suffix} │"
                )
            elif eval_tf_time is not None:
                print(f"   │ eval_tf: time={eval_tf_time:>5.2f}s{'':>24}│")
            if aug_stats_str:
                # 如果太长，分行显示
                if len(aug_stats_str) > 44:
                    _aug_items = aug_stats_str[2:].split(' | ')  # strip leading "│ "
                    _line = "│"
                    for _ai in _aug_items:
                        if len(_line) + len(_ai) + 3 > 44:
                            print(f"   {_line:<44}│")
                            _line = "│  " + _ai
                        else:
                            _line = _line + " " + _ai + " |" if _line != "│" else "│ " + _ai + " |"
                    _line = _line.rstrip(' |')
                    print(f"   {_line:<44}│")
                else:
                    print(f"   {aug_stats_str:<44}│")
            print(f"   └{'─'*43}┘")

            # 句子级注入详情：写入文件 + 控制台打印几条示例
            try:
                collator_obj_log = kwargs.get('data_collator') or eval_data_collator
                if hasattr(collator_obj_log, '_aug_sample_log') and collator_obj_log._aug_sample_log:
                    _samples = collator_obj_log._aug_sample_log
                    # 写入文件
                    _aug_log_path = os.path.join(OUTPUT_DIR, "augmentation_samples.log")
                    with open(_aug_log_path, 'a', encoding='utf-8') as _af:
                        _af.write(f"\n{'='*60}\n")
                        _af.write(f"Step {state.global_step} | {len(_samples)} augmented samples\n")
                        _af.write(f"{'='*60}\n")
                        for _s in _samples:
                            _af.write(f"  TAGS: {' | '.join(_s['tags'])}\n")
                            _af.write(f"  SRC:  {_s['src']}\n")
                            _af.write(f"  OUT:  {_s['final']}\n\n")
                    # 控制台打印最多 5 条示例
                    _n_show = min(5, len(_samples))
                    print(f"   📝 Augmentation samples ({len(_samples)} logged → {_aug_log_path}):")
                    import random as _rnd_aug
                    _show_indices = _rnd_aug.sample(range(len(_samples)), _n_show) if len(_samples) > _n_show else range(len(_samples))
                    for _si in _show_indices:
                        _s = _samples[_si]
                        print(f"      [{' '.join(_s['tags'])}]")
                        print(f"        ← {_s['src'][:90]}")
                        print(f"        → {_s['final'][:90]}")
                    # 清空缓冲
                    collator_obj_log._aug_sample_log = []
            except Exception:
                pass

            doc_type_rows = []
            seen_doc_types = set()
            for doc_type in _DOC_TYPES:
                count_key = f"eval_doc_{doc_type}_count"
                if count_key in metrics and metrics[count_key] > 0:
                    seen_doc_types.add(doc_type)
                    doc_type_rows.append(
                        (
                            doc_type,
                            int(metrics[count_key]),
                            metrics.get(f"eval_doc_{doc_type}_bleu", 0.0),
                            metrics.get(f"eval_doc_{doc_type}_chrf", 0.0),
                            metrics.get(f"eval_doc_{doc_type}_geom", 0.0),
                            metrics.get(f"eval_doc_{doc_type}_len_ratio", 0.0),
                        )
                    )
            extra_doc_types = sorted(
                key[len("eval_doc_"):-len("_count")]
                for key, value in metrics.items()
                if key.startswith("eval_doc_") and key.endswith("_count") and value > 0
                and key[len("eval_doc_"):-len("_count")] not in seen_doc_types
            )
            for doc_type in extra_doc_types:
                doc_type_rows.append(
                    (
                        doc_type,
                        int(metrics.get(f"eval_doc_{doc_type}_count", 0)),
                        metrics.get(f"eval_doc_{doc_type}_bleu", 0.0),
                        metrics.get(f"eval_doc_{doc_type}_chrf", 0.0),
                        metrics.get(f"eval_doc_{doc_type}_geom", 0.0),
                        metrics.get(f"eval_doc_{doc_type}_len_ratio", 0.0),
                    )
                )

            if doc_type_rows:
                print("   Category metrics:")
                for doc_type, count, bleu_v, chrf_v, geom_v, len_ratio_v in doc_type_rows:
                    print(
                        f"   - {doc_type:<11} n={count:>4}  "
                        f"BLEU={bleu_v:>6.2f}  chrF++={chrf_v:>6.2f}  "
                        f"geom={geom_v:>6.2f}  len={len_ratio_v:>5.2f}"
                    )

            source_rows = []
            seen_sources = set()
            for source_name in _DATA_SOURCES:
                count_key = f"eval_source_{source_name}_count"
                if count_key in metrics and metrics[count_key] > 0:
                    seen_sources.add(source_name)
                    source_rows.append(
                        (
                            source_name,
                            int(metrics[count_key]),
                            metrics.get(f"eval_source_{source_name}_bleu", 0.0),
                            metrics.get(f"eval_source_{source_name}_chrf", 0.0),
                            metrics.get(f"eval_source_{source_name}_geom", 0.0),
                            metrics.get(f"eval_source_{source_name}_len_ratio", 0.0),
                        )
                    )
            extra_sources = sorted(
                key[len("eval_source_"):-len("_count")]
                for key, value in metrics.items()
                if key.startswith("eval_source_") and key.endswith("_count") and value > 0
                and key[len("eval_source_"):-len("_count")] not in seen_sources
            )
            for source_name in extra_sources:
                source_rows.append(
                    (
                        source_name,
                        int(metrics.get(f"eval_source_{source_name}_count", 0)),
                        metrics.get(f"eval_source_{source_name}_bleu", 0.0),
                        metrics.get(f"eval_source_{source_name}_chrf", 0.0),
                        metrics.get(f"eval_source_{source_name}_geom", 0.0),
                        metrics.get(f"eval_source_{source_name}_len_ratio", 0.0),
                    )
                )

            if source_rows:
                print("   Source metrics:")
                for source_name, count, bleu_v, chrf_v, geom_v, len_ratio_v in source_rows:
                    print(
                        f"   - {source_name:<11} n={count:>4}  "
                        f"BLEU={bleu_v:>6.2f}  chrF++={chrf_v:>6.2f}  "
                        f"geom={geom_v:>6.2f}  len={len_ratio_v:>5.2f}"
                    )
            
            # 记录指标到 CSV
            metrics_csv = os.path.join(self.output_dir, "eval_history.csv")
            csv_exists = os.path.exists(metrics_csv)
            with open(metrics_csv, 'a', newline='', encoding='utf-8') as f:
                import csv
                writer = csv.writer(f)
                if not csv_exists:
                    writer.writerow([
                        'step',
                        'epoch',
                        'train_loss',
                        'train_token_acc',
                        'train_probe_loss',
                        'train_probe_token_acc',
                        'eval_loss',
                        'eval_token_acc',
                        'bleu',
                        'chrf',
                        'geom_mean',
                    ])
                writer.writerow([
                    state.global_step,
                    f"{current_epoch:.2f}",
                    f"{train_loss:.4f}" if train_loss is not None else "",
                    f"{train_token_acc:.4f}" if train_token_acc is not None else "",
                    f"{train_probe_loss:.4f}" if train_probe_loss is not None else "",
                    f"{train_probe_token_acc:.4f}" if train_probe_token_acc is not None else "",
                    f"{eval_loss:.4f}",
                    f"{eval_token_acc:.4f}" if eval_token_acc is not None else "",
                    f"{metrics.get('eval_bleu', 0):.4f}",
                    f"{metrics.get('eval_chrf', 0):.4f}",
                    f"{metrics.get('eval_geom_mean', 0):.4f}",
                ])
                f.flush()
            
            # 2. 保存详细预测到 CSV（含完整处理流程）
            model_inputs, raw_preds, raw_labels, preds, labels = prediction_store.get()
            if SAVE_EVAL_PREDICTIONS and preds:
                preds_csv = os.path.join(self.output_dir, "predictions.csv")
                csv_exists = os.path.exists(preds_csv)
                
                _tag_re = re.compile(r'\[\[[EN]\d{3}\]\]')
                
                try:
                    t_pred_csv = time.perf_counter()
                    with open(preds_csv, 'a', newline='', encoding='utf-8') as f:
                        import csv
                        writer = csv.writer(f)
                        if not csv_exists:
                            writer.writerow([
                                'step',
                                'transliteration',        # 原始输入（eval_df 中的音译）
                                'data_source',            # 样本来源（official / ocr）
                                'model_input',            # 模型实际输入（含 task_prefix + hint/placeholder）
                                'raw_model_output',       # 模型直接解码输出（未后处理）
                                'prediction',             # 后处理后的预测（normalize_for_eval）
                                'raw_reference',          # 参考文本直接解码（可能含占位符标签）
                                'reference',              # 后处理后的参考
                                'has_placeholder_tags',   # 原始输出/参考中是否含 [[E/N]] 标签
                                'pred_changed',           # 后处理是否改变了预测
                                'ref_changed',            # 后处理是否改变了参考
                            ])
                        
                        rows = []
                        for i in range(len(preds)):
                            try:
                                orig = eval_df.iloc[i]['transliteration'] if 'eval_df' in globals() and i < len(eval_df) else ""
                            except:
                                orig = ""
                            try:
                                data_source = (
                                    normalize_data_source_label(eval_df.iloc[i][config.data_source_col])
                                    if 'eval_df' in globals()
                                    and i < len(eval_df)
                                    and config.data_source_col in eval_df.columns
                                    else "official"
                                )
                            except:
                                data_source = "official"
                            
                            mi = model_inputs[i] if i < len(model_inputs) else ""
                            rp = raw_preds[i] if i < len(raw_preds) else ""
                            rl = raw_labels[i] if i < len(raw_labels) else ""
                            p = preds[i]
                            r = labels[i]
                            
                            # 检测占位符标签
                            has_tags = bool(_tag_re.search(rp) or _tag_re.search(rl))
                            # 检测后处理是否有变化
                            pred_changed = (rp != p)
                            ref_changed = (rl != r)
                            
                            rows.append([
                                state.global_step,
                                orig,
                                data_source,
                                mi,
                                rp,
                                p,
                                rl,
                                r,
                                has_tags,
                                pred_changed,
                                ref_changed,
                            ])
                        
                        writer.writerows(rows)
                        f.flush()
                        
                    print(f"   📄 Appended {len(rows)} predictions (11 cols) to: {preds_csv}")
                    if LOG_EVAL_TIMING:
                        print(f"   ⏱️ predictions.csv write: {time.perf_counter() - t_pred_csv:.2f}s")
                except Exception as e:
                    print(f"   ⚠️ Failed to save predictions: {e}")
            
            # 3. Worst-10 样本日志（按 sentence-level chrF++ 排序）
            scores = getattr(prediction_store, 'per_sample_scores', [])
            if SAVE_WORST_EVAL_SAMPLES and preds and labels and scores:
                import numpy as np
                indices = np.argsort(scores)[:10]  # 最差的 10 个
                
                worst_csv = os.path.join(self.output_dir, "worst10.csv")
                worst_csv_exists = os.path.exists(worst_csv)
                
                print(f"\n{'─'*60}")
                print(f"🔻 WORST 10 SAMPLES (Step {state.global_step})")
                print(f"{'─'*60}")
                
                worst_rows = []
                for rank, i in enumerate(indices):
                    i = int(i)
                    try:
                        orig_t = eval_df.iloc[i]['transliteration'] if 'eval_df' in globals() and i < len(eval_df) else ""
                    except:
                        orig_t = ""
                    
                    mi = model_inputs[i] if i < len(model_inputs) else ""
                    rp = raw_preds[i] if i < len(raw_preds) else ""
                    rl = raw_labels[i] if i < len(raw_labels) else ""
                    p = preds[i] if i < len(preds) else ""
                    r = labels[i] if i < len(labels) else ""
                    sc = scores[i] if i < len(scores) else 0.0
                    
                    print(f"\n  [{rank+1}] chrF++={sc:.2f}")
                    print(f"    原文:     {str(orig_t)[:150]}")
                    print(f"    参考译文: {r[:150]}")
                    print(f"    模型输出: {rp[:150]}")
                    if rp != p:
                        print(f"    后处理后: {p[:150]}")
                    
                    worst_rows.append([
                        state.global_step, rank+1, i, sc,
                        str(orig_t)[:500], mi[:500], rp[:500], p[:500], rl[:500], r[:500],
                    ])
                
                # 追加写入 worst10.csv
                try:
                    import csv
                    with open(worst_csv, 'a', newline='', encoding='utf-8') as f:
                        writer = csv.writer(f)
                        if not worst_csv_exists:
                            writer.writerow([
                                'step', 'rank', 'sample_idx', 'chrf_score',
                                'transliteration', 'model_input', 'raw_output',
                                'postprocessed_output', 'raw_reference', 'reference',
                            ])
                        writer.writerows(worst_rows)
                except Exception as e:
                    print(f"   ⚠️ Failed to save worst10.csv: {e}")
                
                print(f"{'─'*60}")
            
            # 4. 错误类型分析
            if preds and labels:
                error_analyzer.analyze(preds, labels)
                error_analyzer.print_report(step=state.global_step)
            
            # 5. 训练集采样推理 → 已移至 on_train_end
            
            # Print demo translations
            print(f"\n{'─'*60}")
            metric_direction = _metric_direction_label(args)
            print(
                f"📝 DEMO TRANSLATIONS (Step {state.global_step}, tracked {metric_name} "
                f"[{metric_direction} is better]: {current_metric:.2f})"
            )
            print(f"{'─'*60}")
            
            self.model.eval()
            device = next(self.model.parameters()).device
            
            
            if _is_distributed:
                print("   ⏭️ 多卡模式，跳过 demo 翻译")
            else:
              _demo_model = self.model.module if hasattr(self.model, 'module') else self.model
              for i, sample in enumerate(self.demo_samples[:DEMO_SHOW_COUNT]):
                    # 先对原始测试文本做 prepare_data 预处理（gap/限定词/分数等）
                    preprocessed = preprocess_transliteration(sample)
                    input_text = preprocess_input(preprocessed)
                    
                    # 专名处理 (hint / placeholder)
                    mapping = {}
                    _eval_content = _strip_any_task_prefix(input_text)
                    _eval_prefix = input_text[:len(input_text) - len(_eval_content)] if _eval_content != input_text else config.task_prefix
                    
                    if config.name_handling_mode == 'placeholder' and _placeholder_svc:
                        masked_content, _, mapping = _placeholder_svc.apply_placeholders(_eval_content)
                        input_text = _eval_prefix + masked_content
                    elif config.name_handling_mode == 'hint' and _lexicon:
                        _eval_content = _apply_hints(_eval_content, _lexicon)
                        input_text = _eval_prefix + _eval_content
                    
                    # 月份 hint（独立子开关）
                    if config.use_month_hints:
                        _eval_content = _strip_any_task_prefix(input_text)
                        _eval_content = _apply_month_hints(_eval_content)
                        input_text = _eval_prefix + _eval_content

                    # Sumerogram 词义注入
                    if _sumerogram_glossary:
                        _eval_content = _strip_any_task_prefix(input_text)
                        _eval_content = _inject_sumerogram_hints(_eval_content, _sumerogram_glossary, max_hints=config.max_sumerogram_hints)
                        input_text = _eval_prefix + _eval_content
                    
                    inputs = self.tokenizer(
                        input_text, 
                        return_tensors="pt", 
                        padding=True, 
                        truncation=True,
                        max_length=config.max_input_length
                    )
                    inputs = {k: v.to(device) for k, v in inputs.items()}
                    
                    with torch.no_grad():
                        outputs = _demo_model.generate(
                            **inputs,
                            **build_standard_eval_generate_kwargs(),
                        )
                    
                    decoded = self.tokenizer.decode(outputs[0], skip_special_tokens=True)
                    
                    # 回填占位符（如果有）
                    if mapping and _placeholder_svc:
                        decoded = _placeholder_svc.restore(decoded, mapping)
                    
                    decoded = postprocess_output(decoded, _onomasticon)
                    
                    print(f"\n[{i+1}] 原始输入:  {sample}")
                    if preprocessed != sample:
                        print(f"    预处理后:  {preprocessed}")
                    if mapping:
                        print(f"    掩码后:    {_strip_any_task_prefix(input_text)}") 
                        print(f"    占位符映射: {mapping}")
                    raw_output = self.tokenizer.decode(outputs[0], skip_special_tokens=True)
                    print(f"    模型输出:  {raw_output}")
                    if decoded != raw_output:
                        print(f"    后处理后:  {decoded}")
            
            print(f"{'─'*60}\n")
            
            # Track best
            if _is_better_metric(current_metric, self.best_metric, args):
                self.best_metric = current_metric
                self.best_metric_name = metric_name
                self.best_metric_direction = metric_direction
                self._pending_best_step = state.global_step
                candidate_checkpoint = os.path.join(self.output_dir, f"checkpoint-{state.global_step}")
                if os.path.isdir(candidate_checkpoint):
                    self.best_checkpoint = candidate_checkpoint
                    self._pending_best_step = None
                print(f"   ⭐ New best {metric_name} ({metric_direction} is better): {current_metric:.4f}")
            
            self.model.train()
        
        return control

# Add the callback
disk_space_callback = DiskSpaceCallback(
    OUTPUT_DIR,
    model,
    tokenizer,
    DEMO_SAMPLES
)
trainer.add_callback(disk_space_callback)

_is_distributed = int(os.environ.get("LOCAL_RANK", -1)) >= 0
_is_fsdp = bool(config.fsdp)
if RUN_INITIAL_EVAL and RUNTIME_EVAL_ENABLED:
    if _is_fsdp:
        # FSDP: 跳过 initial eval（generate() 在 FSDP 下显存开销大，易 OOM）
        # 第一个常规 eval step 会自动提供 baseline
        if _is_main_process():
            print("   ⏭️ FSDP 模式，跳过 initial eval（首次常规 eval step 自动提供 baseline）")
    else:
        # 单卡 / DDP：所有 rank 均参与 boundary eval（内部自动分片 + gather）
        initial_eval_results = run_boundary_eval("initial", eval_df)
        if _is_main_process():
            print_eval_breakdown(initial_eval_results)
            tracked_metric = _metric_name_for_best_model(training_args)
            if f"eval_{tracked_metric}" in initial_eval_results or tracked_metric in initial_eval_results:
                tracked_value = _extract_metric_value(initial_eval_results, tracked_metric, 0.0)
                print(f"   Initial {tracked_metric}: {tracked_value:.4f}")
            else:
                print("   Initial loss: N/A (boundary eval 不计算 eval_loss)")

# Train
train_result = trainer.train(resume_from_checkpoint=_resume_checkpoint_path)

_training_wall_end = _time_mod.time()
_training_wall_secs = _training_wall_end - _training_wall_start
_training_wall_hrs = _training_wall_secs / 3600
print(f"\n⏱️  训练耗时: {_training_wall_secs:.0f}s ({_training_wall_hrs:.2f}h)")

# ============================================================
# 创建 best_checkpoint 符号链接（不再将模型文件拷贝到 OUTPUT_DIR 根目录）
# ============================================================
retained_checkpoints = sorted(
    [
        item for item in os.listdir(OUTPUT_DIR)
        if item.startswith("checkpoint-") and os.path.isdir(os.path.join(OUTPUT_DIR, item))
    ],
    key=lambda item: _checkpoint_step(item),
)

# 确定 best checkpoint 路径
_best_ckpt_path = getattr(disk_space_callback, 'best_checkpoint', None)
if not _best_ckpt_path or not os.path.isdir(_best_ckpt_path):
    # fallback: 用最新的 checkpoint
    if retained_checkpoints:
        _best_ckpt_path = os.path.join(OUTPUT_DIR, retained_checkpoints[-1])
    else:
        _best_ckpt_path = None

if _best_ckpt_path and os.path.isdir(_best_ckpt_path):
    _symlink_path = os.path.join(OUTPUT_DIR, "best_checkpoint")
    # 清理旧链接
    if os.path.islink(_symlink_path):
        os.remove(_symlink_path)
    elif os.path.exists(_symlink_path):
        shutil.rmtree(_symlink_path)
    os.symlink(os.path.basename(_best_ckpt_path), _symlink_path)
    sync_checkpoint_sidecars(_best_ckpt_path, config)
    sync_checkpoint_sidecars(_symlink_path, config)
    print(f"\n💾 best_checkpoint → {os.path.basename(_best_ckpt_path)}")
else:
    print("\n⚠️ No checkpoint found to symlink as best_checkpoint")

if retained_checkpoints:
    print("♻️ Retained checkpoints:")
    for item in retained_checkpoints:
        print(f"   {item}")
else:
    print("♻️ No resumable checkpoints retained.")

cleanup_output_root_model_artifacts(OUTPUT_DIR)
print("   ✓ Saved: checkpoints are self-contained; output root keeps only logs/metadata/best_checkpoint")

# Log training results
print("\n📊 Training Results:")
print(f"   Total steps: {train_result.global_step}")
print(f"   Training loss: {train_result.training_loss:.4f}")

# ============================================================
# CELL 10: EVALUATE ON FULL DATASET
# ============================================================

if _is_main_process():
    print("\n" + "="*60)
    print("📈 FINAL MULTI-MODE EVALUATION")
    print("="*60)

# Evaluate with all decode modes
if _is_fsdp:
    # FSDP: 无法做 beam+MBR multi-mode eval，跳过
    if _is_main_process():
        print("   ⏭️ FSDP 模式，跳过 final multi-mode eval（beam+MBR 不兼容 FSDP 分片）")
    eval_results = {}
else:
    # 单卡 / DDP：所有 rank 均参与 multi-mode eval（各函数内部自动分片 + gather）
    eval_results = run_multi_mode_eval("final", eval_df)

_final_bleu = eval_results.get('eval_bleu', 0)
_final_chrf = eval_results.get('eval_chrf', 0)
_final_geom = eval_results.get('eval_geom_mean', 0)
_tracked_metric_name = _metric_name_for_best_model(training_args)
_tracked_metric_direction = _metric_direction_label(training_args)
_final_tracked_value = None
if (
    _tracked_metric_name in eval_results
    or f"eval_{_tracked_metric_name}" in eval_results
):
    _final_tracked_value = _extract_metric_value(eval_results, _tracked_metric_name)

print(f"\n{'█'*60}")
print(f"█{'':^58}█")
print(f"█{'📊  FINAL METRICS  📊':^58}█")
print(f"█{'':^58}█")
print(f"█   {'BLEU':>10}: {_final_bleu:>8.2f}{'':>36}█")
print(f"█   {'chrF++':>10}: {_final_chrf:>8.2f}{'':>36}█")
print(f"█   {'geom_mean':>10}: {_final_geom:>8.2f}{'':>36}█")
if _final_tracked_value is not None:
    print(
        f"█   {_tracked_metric_name:>10}: {_final_tracked_value:>8.4f}  "
        f"← tracked metric ({_tracked_metric_direction} better){'':>2}█"
    )
else:
    print(
        f"█   {_tracked_metric_name:>10}: {'N/A':>8}  "
        f"← tracked by Trainer only, boundary eval has no {_tracked_metric_name}{'':>1}█"
    )
print(f"█{'':^58}█")
print(f"█   Config: {config.dtype} | {config.model_name.split('/')[-1]} | {os.path.basename(config.train_csv)}{'':>2}█")
print(
    f"█   Hint: {config.name_handling_mode} | SG: {config.use_sumerogram_glossary} | "
    f"RAG: {config.use_rag}{'':>4}█"
)
print(f"█{'':^58}█")
print(f"{'█'*60}")

_final_doc_type_rows = []
for _doc_type in _DOC_TYPES:
    _count = int(eval_results.get(f"eval_doc_{_doc_type}_count", 0))
    if _count > 0:
        _final_doc_type_rows.append(
            (
                _doc_type,
                _count,
                eval_results.get(f"eval_doc_{_doc_type}_bleu", 0.0),
                eval_results.get(f"eval_doc_{_doc_type}_chrf", 0.0),
                eval_results.get(f"eval_doc_{_doc_type}_geom", 0.0),
                eval_results.get(f"eval_doc_{_doc_type}_len_ratio", 0.0),
            )
        )
if _final_doc_type_rows:
    print("   Category metrics:")
    for _doc_type, _count, _bleu_v, _chrf_v, _geom_v, _len_ratio_v in _final_doc_type_rows:
        print(
            f"   - {_doc_type:<11} n={_count:>4}  "
            f"BLEU={_bleu_v:>6.2f}  chrF++={_chrf_v:>6.2f}  "
            f"geom={_geom_v:>6.2f}  len={_len_ratio_v:>5.2f}"
        )

_final_source_rows = []
for _source_name in _DATA_SOURCES:
    _count = int(eval_results.get(f"eval_source_{_source_name}_count", 0))
    if _count > 0:
        _final_source_rows.append(
            (
                _source_name,
                _count,
                eval_results.get(f"eval_source_{_source_name}_bleu", 0.0),
                eval_results.get(f"eval_source_{_source_name}_chrf", 0.0),
                eval_results.get(f"eval_source_{_source_name}_geom", 0.0),
                eval_results.get(f"eval_source_{_source_name}_len_ratio", 0.0),
            )
        )
if _final_source_rows:
    print("   Source metrics:")
    for _source_name, _count, _bleu_v, _chrf_v, _geom_v, _len_ratio_v in _final_source_rows:
        print(
            f"   - {_source_name:<11} n={_count:>4}  "
            f"BLEU={_bleu_v:>6.2f}  chrF++={_chrf_v:>6.2f}  "
            f"geom={_geom_v:>6.2f}  len={_len_ratio_v:>5.2f}"
        )

# ============================================================
# CELL 11: QUICK INFERENCE TEST
# ============================================================

print("\n" + "="*60)
print("🧪 INFERENCE TEST (standard eval generate path)")
print("="*60)

# Load the trained model
model.eval()
model = model.to("cuda" if torch.cuda.is_available() else "cpu")

print("\nTest Translations:")
for sample in DEFAULT_TEST_SAMPLES:
    input_text = preprocess_input(sample)
    inputs = tokenizer(input_text, return_tensors="pt", padding=True, truncation=True)
    inputs = {k: v.to(model.device) for k, v in inputs.items()}
    
    with torch.no_grad():
        outputs = model.generate(
            **inputs,
            **build_standard_eval_generate_kwargs(),
        )
    
    decoded = tokenizer.decode(outputs[0], skip_special_tokens=True)
    decoded = postprocess_output(decoded)
    
    print(f"\n  Input:  {sample}")
    print(f"  Output: {decoded}")

_total_wall_secs = _time_mod.time() - _training_wall_start
_total_wall_hrs = _total_wall_secs / 3600
print(f"\n⏱️  总耗时（含保存/评估/上传）: {_total_wall_secs:.0f}s ({_total_wall_hrs:.2f}h)")
print(f"   结束时间: {datetime.now(_tz_shanghai).strftime('%Y-%m-%d %H:%M:%S')} (上海)")
print("\n" + "="*60)
print("🎉 TRAINING COMPLETE!")
print("="*60)
