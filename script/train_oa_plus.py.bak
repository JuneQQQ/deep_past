# Sumerogram 词义注入（内嵌实现）
_SUMEROGRAM_TOKEN_RE = re.compile(
    r'(?<![a-záàéèíìúù])'
    r'([A-ZÁÀÉÈÍÌÚÙŠṢṬḪ][A-ZÁÀÉÈÍÌÚÙŠṢṬḪ₀-₉0-9.]+)'
    r'(?![a-záàéèíìúù])'
)
_SUMEROGRAM_HIGH_FREQ_SKIP = {'KÙ.BABBAR', 'DUMU', 'GÍN', 'GÍN.TA'}
_SUMEROGRAM_GLOSSARY_TOKEN_RE = re.compile(
    r'^[A-ZÁÀÉÈÍÌÚÙŠṢṬḪ][A-ZÁÀÉÈÍÌÚÙŠṢṬḪ₀-₉0-9.]*$'
)
_OUTPUT_ROOT_MODEL_ARTIFACTS = {
    "added_tokens.json",
    "config.json",
    "generation_config.json",
    "merges.txt",
    "model.safetensors",
    "model.safetensors.index.json",
    "pytorch_model.bin",
    "pytorch_model.bin.index.json",
    "sentencepiece.bpe.model",
    "special_tokens_map.json",
    "spiece.model",
    "tokenizer.json",
    "tokenizer_config.json",
    "training_args.bin",
    "vocab.json",
}


def _inject_sumerogram_hints(text: str, glossary: dict, max_hints: int = 6) -> str:
    """Inject [GAL=chief; É.GAL=palace] prefix based on detected Sumerograms."""
    if not isinstance(text, str) or not text.strip() or not glossary:
        return text
    hints, seen = [], set()
    for m in _SUMEROGRAM_TOKEN_RE.finditer(text):
        if len(hints) >= max_hints:
            break
        tok = m.group(1)
        if tok in seen or tok in _SUMEROGRAM_HIGH_FREQ_SKIP:
            continue
        seen.add(tok)
        entry = glossary.get(tok) or glossary.get(re.sub(r'[₀-₉0-9]+$', '', tok))
        if entry:
            hints.append(f"{tok}={entry[1]}")
    if not hints:
        return text
    return "[" + "; ".join(hints) + "] " + text


def _load_serialized_sumerogram_glossary(path: str) -> Dict[str, Tuple[str, str]]:
    """Load {token: [reading, gloss]} or {token: {reading/gloss...}} JSON."""
    with open(path, "r", encoding="utf-8") as f:
        raw = json.load(f)
    if not isinstance(raw, dict):
        raise ValueError(f"expected dict glossary, got {type(raw).__name__}")

    glossary: Dict[str, Tuple[str, str]] = {}
    for token, value in raw.items():
        if isinstance(value, dict):
            reading = (
                value.get("akkadian")
                or value.get("reading")
                or value.get("akkadian_reading")
                or ""
            )
            gloss = (
                value.get("english")
                or value.get("gloss")
                or value.get("meaning")
                or value.get("english_gloss")
                or ""
            )
        elif isinstance(value, (list, tuple)) and len(value) >= 2:
            reading, gloss = value[0], value[1]
        else:
            raise ValueError(f"unsupported glossary entry for {token!r}: {type(value).__name__}")

        token = str(token).strip()
        reading = str(reading or "").strip()
        gloss = str(gloss or "").strip()
        if token and gloss and _SUMEROGRAM_GLOSSARY_TOKEN_RE.fullmatch(token):
            glossary[token] = (reading or token, gloss)
    return glossary


def build_sumerogram_glossary(
    lexicon_csv: str,
    output_path: str | None = None,
) -> Dict[str, Tuple[str, str]]:
    """Build a strict Sumerogram glossary with explicit English glosses only."""
    if _build_strict_sumerogram_glossary is None:
        raise RuntimeError(
            f"strict Sumerogram builder unavailable: {_STRICT_SG_IMPORT_ERROR}"
        )

    raw_glossary = _build_strict_sumerogram_glossary(lexicon_csv, output_path=None)
    glossary: Dict[str, Tuple[str, str]] = {}
    for token, value in raw_glossary.items():
        if not isinstance(value, (list, tuple)) or len(value) < 2:
            continue
        reading = str(value[0] or "").strip()
        gloss = str(value[1] or "").strip()
        token = str(token or "").strip()
        if token and gloss and _SUMEROGRAM_GLOSSARY_TOKEN_RE.fullmatch(token):
            glossary[token] = (reading or token, gloss)

    glossary = dict(sorted(glossary.items()))
    if output_path:
        with open(output_path, "w", encoding="utf-8") as f:
            json.dump(
                {k: [v[0], v[1]] for k, v in glossary.items()},
                f,
                ensure_ascii=False,
                indent=2,
            )
    return glossary


def ensure_sumerogram_glossary_json(config) -> str | None:
    """Ensure data/sumerogram_glossary.json matches the strict builder output."""
    sg_path = os.path.join(config.data_dir, "sumerogram_glossary.json")
    existing_glossary = None
    if os.path.exists(sg_path):
        try:
            existing_glossary = _load_serialized_sumerogram_glossary(sg_path)
        except Exception as e:
            print(f"   ⚠️ Failed to load existing sumerogram_glossary.json: {e}")

    try:
        glossary = build_sumerogram_glossary(config.lexicon_csv)
    except Exception as e:
        if existing_glossary:
            print(
                f"   ⚠️ Strict Sumerogram rebuild failed, keeping existing glossary: {e}"
            )
            return sg_path
        print(f"   ⚠️ Failed to build strict sumerogram_glossary.json: {e}")
        return None

    if existing_glossary == glossary:
        return sg_path

    os.makedirs(config.data_dir, exist_ok=True)
    with open(sg_path, "w", encoding="utf-8") as f:
        json.dump({k: [v[0], v[1]] for k, v in glossary.items()}, f, ensure_ascii=False, indent=2)
    action = "Refreshed" if existing_glossary is not None else "Built"
    print(f"   📚 {action} strict sumerogram_glossary.json: {len(glossary)} entries")
    return sg_path


def ensure_correction_vocab_json(config) -> str | None:
    """Ensure data/correction_vocab.json exists, building it if needed."""
    cv_path = os.path.join(config.data_dir, "correction_vocab.json")
    if os.path.exists(cv_path):
        return cv_path

    try:
        import sys as _sys_cv

        _script_dir = os.path.dirname(os.path.abspath(__file__))
        if _script_dir not in _sys_cv.path:
            _sys_cv.path.insert(0, _script_dir)
        from build_correction_vocab import build_combined_vocabulary

        vocab = build_combined_vocabulary(config.train_csv, config.lexicon_csv)
        os.makedirs(config.data_dir, exist_ok=True)
        with open(cv_path, "w", encoding="utf-8") as f:
            json.dump(vocab, f, ensure_ascii=False)
        print(f"   📚 Built correction_vocab.json: {len(vocab)} tokens")
        return cv_path
    except Exception as e:
        print(f"   ⚠️ Failed to build correction_vocab.json: {e}")
        return None


def sync_checkpoint_sidecars(target_dir: str, config, *, include_training_config: bool = True) -> None:
    """Keep each checkpoint self-contained for infer.py and packaging."""
    if not target_dir or not os.path.isdir(target_dir):
        return

    if include_training_config:
        cfg_path = os.path.join(target_dir, "training_config.json")
        with open(cfg_path, "w", encoding="utf-8") as f:
            json.dump(config.to_dict(), f, indent=4, ensure_ascii=False)

    cal_src = os.path.join(config.data_dir, "calibrated_lexicon.json")
    if os.path.exists(cal_src):
        shutil.copy2(cal_src, os.path.join(target_dir, "calibrated_lexicon.json"))

    sg_src = ensure_sumerogram_glossary_json(config)
    if sg_src and os.path.exists(sg_src):
        shutil.copy2(sg_src, os.path.join(target_dir, "sumerogram_glossary.json"))

    cv_src = ensure_correction_vocab_json(config)
    if cv_src and os.path.exists(cv_src):
        shutil.copy2(cv_src, os.path.join(target_dir, "correction_vocab.json"))


def cleanup_output_root_model_artifacts(output_dir: str) -> None:
    """Keep the run root free of direct model/tokenizer artifacts."""
    if not os.path.isdir(output_dir):
        return

    removed = []
    for name in sorted(_OUTPUT_ROOT_MODEL_ARTIFACTS):
        path = os.path.join(output_dir, name)
        if not os.path.lexists(path):
            continue
        try:
            if os.path.isdir(path) and not os.path.islink(path):
                shutil.rmtree(path, ignore_errors=True)
            else:
                os.remove(path)
            removed.append(name)
        except Exception as e:
            print(f"   ⚠️ Failed to remove root artifact {path}: {e}")

    if removed:
        print(f"   🧹 Removed root-level model artifacts: {', '.join(removed)}")


