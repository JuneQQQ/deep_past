# 支持多文件加权输入："path1:weight1,path2:weight2,..."
# 权重控制该数据集的采样倍率（1.0=原样，2.0=上采样2倍，0.5=下采样一半）
def _load_weighted_csvs(csv_spec: str) -> pd.DataFrame:
    """加载一个或多个 CSV，支持 path:weight 格式。"""
    parts = [p.strip() for p in csv_spec.split(',') if p.strip()]
    dfs = []
    for part in parts:
        if ':' in part and not part.startswith('/'):
            # 格式: path:weight（但要排除 Windows 盘符 C:\）
            path, weight_str = part.rsplit(':', 1)
            try:
                weight = float(weight_str)
            except ValueError:
                path, weight = part, 1.0
        elif ':' in part:
            # 可能是 /abs/path:weight
            last_colon = part.rfind(':')
            path_candidate = part[:last_colon]
            weight_candidate = part[last_colon+1:]
            try:
                weight = float(weight_candidate)
                path = path_candidate
            except ValueError:
                path, weight = part, 1.0
        else:
            path, weight = part, 1.0
        
        if not os.path.exists(path):
            print(f"   ⚠️ 文件不存在，跳过: {path}")
            continue
        
        sub_df = pd.read_csv(path)
        n_orig = len(sub_df)
        
        # 加权：>1 上采样，<1 下采样
        if weight > 1.0:
            n_target = int(n_orig * weight)
            sub_df = sub_df.sample(n=n_target, replace=True, random_state=42).reset_index(drop=True)
        elif 0 < weight < 1.0:
            n_target = max(1, int(n_orig * weight))
            sub_df = sub_df.sample(n=n_target, replace=False, random_state=42).reset_index(drop=True)
        
        sub_df['_source_file'] = os.path.basename(path)
        dfs.append(sub_df)
        print(f"   📂 {os.path.basename(path)}: {n_orig} 条 × {weight:.1f} = {len(sub_df)} 条")
    
    if not dfs:
        raise FileNotFoundError(f"无法加载任何训练数据: {csv_spec}")
    return pd.concat(dfs, ignore_index=True)

df = _load_weighted_csvs(config.train_csv)
