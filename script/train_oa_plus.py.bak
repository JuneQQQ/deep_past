class Config:
    """消融实验配置类 - 所有参数集中管理"""

    def __init__(self):
        # ========== 路径配置 ==========
        local_root = "/data/lsb/deep_past"
        # local_root = "/root/projects/deep_past"
        self.root_dir = local_root
        self.data_dir = os.path.join(self.root_dir, "data")
        # 训练数据：支持多文件加权输入，格式 "path1:weight1,path2:weight2,..."
        # weight=1.0 原样, >1.0 上采样, <1.0 下采样；单文件可省略 :weight
        # ── 消融实验权值设计 ──
        # 基线 (A): 仅 main           → 验证单数据源基准
        # 实验 (B): main + synth       → 验证合成数据增益
        # 实验 (C): main + synth + akt8 + data_t  → 验证 OA 域内扩充增益
        # 实验 (D): C + archibab       → 验证 OB 跨方言迁移增益
        # 实验 (E): D + cdli           → 验证多语言/多方言全量增益
        # 当前配置 = 实验 E（OA + archibab + cdli）
        self.train_csv = ",".join([
            os.path.join(self.data_dir, "qwen_sentence_aligned_clean.csv"),                                         # [A] OA 核心 ×1.0 (5046条)
            os.path.join(self.data_dir, "archibab/archibab_akk_en_clean.csv") + ":0.15",                            # [D] OB 辅助 ×0.15 (157条, 零重叠)
            os.path.join(self.data_dir, "cdli/cdli_clean.csv") + ":0.05",                                           # [E] 多方言 ×0.05 (123条, 81%SUX+OA/OB/OAkk)
            # os.path.join(self.data_dir, "synth/qwen_sentence_aligned_targeted_synth.csv") + ":1.0",                 # [B] 合成数据 ×1.0 (337条, 数值/月份/商业术语)
            # os.path.join(self.root_dir, "output/akt8_mineru_ocr_extract/qwen_sentence_aligned_akt8.csv") + ":0.3",  # [C] AKT8 OCR ×0.3 (244条, OA域, 6%新内容)
            # os.path.join(self.data_dir, "data_t/akkadian_corpus_clean.csv") + ":0.1",                               # [C] OA 文档级 ×0.1 (153条, 84%重叠)
        ])
        # self.test_csv = os.path.join(self.data_dir, "test.csv")
        self.lexicon_csv = os.path.join(self.data_dir, "OA_Lexicon_eBL.csv")
        # 手动切分的长文档数据（优先替换同 oare_id 的样本，空字符串=不启用）
        # self.train_code_splits = os.path.join(self.data_dir, "train_manual_code_splits.csv")
        self.train_code_splits = os.path.join("")

        # ========== 模型配置 ==========
        # self.model_name = "/root/autodl-tmp/google-byt5-xxl"
        self.model_name = "/data/lsb/deep_past/output/model_20260317_015133/checkpoint-9600"
        # self.model_name = "google/byt5-small"
        # self.model_name = "google/byt5-xl"       # 3.7B — DDP 可用（单卡 ~7.4GB bf16）
        # self.model_name = "google/byt5-xxl"      # 13B — 需要 FSDP（单卡放不下）
        # self.model_name = "/data/lsb/deep_past/example/model/byt5-akkadian-mbr-v2-pytorch-default-v1"
        self.task_prefix = "translate Old Assyrian to English: "  # 默认前缀（无 dialect 列时使用）

        # Meta prefix: 极简 2 字母前缀替代冗长的 task_prefix
        # 格式: "XY " — X=来源(O/N), Y=完整度(I/D), 总计 3 bytes
        # 设为 True 时 task_prefix 和 DIALECT_PREFIX_MAP 被忽略
        self.use_meta_prefix = True
        
        # ========== 训练参数 ==========
        self.num_epochs = 100
        self.train_batch_size = 16
        self.eval_batch_size = 16*4
        self.gradient_accumulation = 1  # 有效 batch = train_batch_size * gradient_accumulation
        self.max_tokens_per_batch = 0  # 0=关闭；>0 时按 token 预算动态组 train batch
        self.dynamic_batch_bucket_size = 128  # 随机打散后分桶排序，降低 padding 浪费
        self.dynamic_batch_max_examples = 0  # 0=不设上限；>0 时限制单个 batch 最大样本数
        # self.learning_rate = 2e-5
        self.learning_rate = 1e-4
        self.warmup_ratio = 0.01
        self.weight_decay = 0.01
        
        # ========== 层冻结 ==========
        # byt5-base:  encoder=18层, decoder=6层
        # byt5-large: encoder=36层, decoder=12层
        # 建议保持 encoder:decoder ≈ 3:1 的冻结比例
        # 轻量微调: base(9,3) / large(18,6)  中等: base(12,4) / large(24,8)
        self.freeze_encoder_layers = 0  # 冻结 encoder 底部 N 层（0=不冻结）
        self.freeze_decoder_layers = 0  # 冻结 decoder 底部 N 层（0=不冻结）
        
        # ========== 序列长度 ==========
        self.max_input_length = 512
        self.max_target_length = 512
        
        # ========== 高频训练优化开关 ==========
        self.use_desc_length_stress_test = False  # 按样本长度从长到短训练，优先暴露 OOM
        self.use_dft = False
        self.dft_mode = "sequence_focal"
        self.dft_gamma = 1.0
        self.dft_min_weight = 0.25
        self.dft_max_weight = 2.0
        self.dft_warmup_steps = 500
        
        # ========== 生成参数 (仅验证/推理阶段使用，训练阶段用 teacher forcing) ==========
        self.num_beams = 1
        self.length_penalty = 1.3
        self.repetition_penalty = 1.2
        self.no_repeat_ngram_size = 0
        
        # ========== 评估和保存 ==========
        self.eval_steps = 200
        self.save_steps = 20000
        self.logging_steps = 10
        self.save_total_limit = 3
        
        # ========== 优化器和调度器 ==========
        # adamw_bnb_8bit 需要 CUDA，无 GPU 时回退到 adamw_torch
        self.optim = "adamw_bnb_8bit" if torch.cuda.is_available() else "adamw_torch"
        self.lr_scheduler_type = "cosine"
        self.dataloader_num_workers = 4
        # eval 默认沿用多 worker，避免生成阶段前的 tokenize/collate 成为主线程瓶颈
        self.eval_dataloader_num_workers = self.dataloader_num_workers if torch.cuda.is_available() else 0
        self.gradient_checkpointing = True
        self.report_to = "none"
        
        # ========== Trainer 行为 ==========
        self.eval_strategy = "steps"
        self.save_strategy = "steps"
        self.load_best_model_at_end = True
        self.greater_is_better = False
        self.predict_with_generate = True
        self.remove_unused_columns = False
        self.eval_enable_generation_cache = True
        self.compute_eval_token_acc = False
        self.compute_train_probe_metrics = False
        
        # ========== 数据策略 ==========
        self.test_size = 0.1
        self.random_seed = 42
        self.data_source_col = "data_source"
        self.balance_eval_ocr_ratio = True
        self.target_eval_ocr_ratio = 0.5

        # ========== 多 Fold 训练 ==========
        self.num_folds = 1          # 1=单次划分（默认），>1=K-Fold 交叉验证
        self.fold_group_col = "oare_id"  # 按此列分组，防止同一文档泄露到验证集

        # ==========================================================
        # 训练/消融开关
        # ==========================================================

        # 精度: "fp32" / "bf16"
        self.dtype = "bf16"

        # EMA (指数移动平均)
        self.use_ema = True
        self.ema_decay = 0.999

        # Curriculum Learning (先短后长，仅前 N 个 epoch)
        self.use_curriculum = False
        self.curriculum_epochs = 8  # 前 N 个 epoch 按长度排序，之后恢复正常 shuffle

        # 模拟泥板损坏（数据增强）
        self.use_simulate_damage = False
        self.damage_prob = 0.1  # 10% 数据触发损坏
        self.damage_span_prob = 0.7  # 70% Span (多词删除), 30% 单词 (<gap>)


        self.use_simulate_ocr_noise = False
        self.ocr_noise_prob = 0.18          # clean/official 样本的 OCR 噪声概率
        self.ocr_noise_prob_on_ocr = 0.06   # 已是 OCR 来源的样本只做轻度再噪声

        # 专名处理模式: "hint" / "placeholder" / "none"
        self.name_handling_mode = "none"  # hint=词典提示, placeholder=标签替换, none=不处理
        self.placeholder_ratio = 0.5  # placeholder 模式下，50% 样本使用占位符
        self.hint_ratio = 0.5  # hint 模式下，50% 样本注入词典提示
        self.max_hints_per_sample = 10  # hint 模式下，每个样本最多提示数
        self.use_month_hints = False  # 月份 hint 子开关：识别音译中的月名形式并添加 hint
        
        self.use_sumerogram_glossary = True  # Sumerogram 词义注入：[GAL=chief; É.GAL=palace] 等
        self.max_sumerogram_hints = 6  # 每个样本最多注入几个 Sumerogram 词义提示

        # RAG 示例注入 (Retrieval-Augmented Generation)
        # 基于英文翻译 TF-IDF 相似度检索最多 N 个干净示例，注入到 prompt
        self.use_rag = False
        self.rag_max_examples = 2       # 最多检索几条示例
        self.rag_prob = 0.5             # 每个样本有多少概率注入 RAG 示例
        self.rag_min_translation_len = 20   # 示例的英文翻译最短字符数（过滤太短的）
        self.rag_max_example_bytes = 150    # 单条示例最大字节数（防止占用太多 token 预算）
        self.rag_budget_ratio = 0.20    # RAG 示例总字节预算占 max_input_length 的比例（≤20% 防 Attention 稀释）

        # ========== 高级优化 (SOTA Configuration) ==========
        # R-Drop (Regularized Dropout) - 同一输入 Dropout 两次 + KL 一致性约束
        # 压制 ByT5 "结巴"（of the the the）和截断幻觉，提升生成稳定性
        # 开启时建议关闭 label_smoothing（两者正则化冲突）
        # alpha 建议 0.5-1.0（ByT5 vocab=384 分布集中，不宜过大）
        self.use_rdrop = True
        self.rdrop_alpha = 0.7  # KL 散度权重（论文 NMT 推荐 5.0，ByT5 推荐 0.5-1.0）
        # Label Smoothing - 允许同义词不确定性
        self.label_smoothing_factor = 0 # 对齐高分 Example，提升 MBR 候选多样性

        # 桶排序 - 配合动态 padding
        self.group_by_length = False  # 长度相近的样本在一起

        #######################  模型部分 ###########################################
        # Boundary-aware Side Embedding (模型结构消融)
        # 在 Encoder byte embedding 旁注入角色标签 side embedding，
        # 使模型在第一层即可感知阿卡德语音译的符号学边界。
        self.use_boundary_aware = False          # 总开关
        self.boundary_combine_mode = "add"     # "add" | "gate" | "scale"
        self.boundary_use_punctuation = True     # - = . :
        self.boundary_use_boundary = True        # { } ( ) [ ]
        self.boundary_use_damage = True          # <gap>, [x x x], ...
        self.boundary_use_numeric = True         # 0-9, ½, ⅔
        self.boundary_freeze_base_embed = False  # 冻结原始 byte embedding
        self.boundary_freeze_side_embed = False  # 冻结 side embedding
        self.boundary_init_std = 0.01            # side embedding 初始标准差
        self.boundary_patch_decoder = False       # 是否也给 decoder 加 side embedding

        # Latent Bottleneck (模型结构消融)
        # 在 Encoder 第 k 层后插入 Stride-2 Conv 瓶颈，将序列长度减半。
        # 浅层保持字节分辨率（音节级），深层在压缩空间运行（更高语义密度）。
        self.use_latent_bottleneck =  False       # 总开关
        self.bottleneck_after_layer = 4           # 在第 k 层之后插入（0-indexed）
        self.bottleneck_stride = 2                # 压缩步长
        self.bottleneck_kernel_size = 2           # 卷积核大小
        self.bottleneck_use_residual = True       # 均值池化残差
        self.bottleneck_use_layernorm = True      # 压缩后 LayerNorm
        self.bottleneck_init_std = 0.02           # 卷积核初始标准差
        self.bottleneck_freeze = False            # 冻结瓶颈层

        # Hybrid Attention (模型结构消融)
        # 局部滑动窗口 + 全局锚点混合注意力，零新参数。
        # 普通字节只看附近 W 个 token（音节级聚合），
        # BOUNDARY/DAMAGE/NUMERIC token 拥有全序列视野。
        self.use_hybrid_attention = False         # 总开关
        self.hybrid_window_size = 15              # 局部窗口半径
        self.hybrid_global_roles = (3, 4, 5)     # BOUNDARY, DAMAGE, NUMERIC
        self.hybrid_global_every_n = 0            # 额外每隔 N 个 token 设全局锚点（0=禁用）

        # Coverage Loss (训练正则化消融)
        # 从 Decoder cross-attention 计算覆盖率惩罚，压制复读机和漏翻。
        # 零新参数——纯 Loss 正则项，在 compute_loss 中外挂。
        self.use_coverage_loss = False            # 总开关
        self.coverage_alpha = 0.1                 # coverage loss 权重
        self.coverage_warmup_steps = 500          # 线性预热步数
        self.coverage_layer_index = -1            # 使用哪层 decoder cross-attn（-1=最后一层）

        # ==========================================================
        # 多卡 / FSDP 配置
        # ==========================================================
        # 单卡 / DDP: 保持默认（fsdp=""），启动命令:
        #   python script/train.py                              # 单卡
        #   torchrun --nproc_per_node=N script/train.py         # N 卡 DDP
        #
        # FSDP (byt5-xxl 13B 等大模型，单卡放不下):
        #   self.fsdp = "full_shard auto_wrap"
        #   torchrun --nproc_per_node=N script/train.py
        #
        # 注意: 多卡时有效 batch = train_batch_size × gradient_accumulation × GPU数
        self.fsdp = ""           # 空字符串 = 关闭 FSDP（DDP 或单卡）
        # self.fsdp = "full_shard auto_wrap"
        self.fsdp_config = {     # FSDP 分片配置（内联 dict，仅 fsdp 非空时生效）
            "fsdp_transformer_layer_cls_to_wrap": ["T5Block"],
            "fsdp_backward_prefetch": "backward_pre",
            "fsdp_forward_prefetch": False,
            "fsdp_use_orig_params": True,
            "fsdp_cpu_ram_efficient_loading": True,
            "fsdp_sync_module_states": True,
            "fsdp_state_dict_type": "FULL_STATE_DICT",
            "fsdp_offload_params": False,
            "fsdp_sharding_strategy": "FULL_SHARD",
            "fsdp_auto_wrap_policy": "TRANSFORMER_BASED_WRAP",
            # 注意: min_num_params 与 transformer_layer_cls_to_wrap 互斥，不能同时设置
            "activation_checkpointing": True,   # FSDP 激活检查点：避免 AllGather 冗余（T5 兼容性由下方 model.config.use_cache=False 保证）
        }
        
    # 精度辅助属性
    @property
    def use_bf16(self): return self.dtype == "bf16"
    
    def to_dict(self):
        """转换为字典用于日志"""
        return {k: str(v) if not isinstance(v, (int, float, bool, str)) else v 
                for k, v in self.__dict__.items()}
    
    def print_ablation_status(self):
        """打印消融开关状态"""
        print("\n🔬 消融开关状态:")
        print(f"   dtype: {self.dtype}")
        print(f"   use_meta_prefix: {self.use_meta_prefix} ({'OI/OD/NI/ND' if self.use_meta_prefix else 'dialect-based task_prefix'})")
        print(f"   use_ema: {self.use_ema} (decay={self.ema_decay})")
        print(f"   use_curriculum: {self.use_curriculum} (epochs={self.curriculum_epochs})")
        print(
            f"   use_early_stopping: {USE_EARLY_STOPPING} "
            f"(effective={RUNTIME_EARLY_STOPPING}, "
            f"load_best_model_at_end={RUNTIME_LOAD_BEST_MODEL_AT_END}, "
            f"save_only_model={RUNTIME_SAVE_ONLY_MODEL})"
        )
        print(f"   use_geom_mean: {USE_GEOM_MEAN}")
        print(
            f"   eval_workers: {self.eval_dataloader_num_workers}  "
            f"gen_cache: {self.eval_enable_generation_cache}  "
            f"eval_token_acc: {self.compute_eval_token_acc}  "
            f"train_probe_metrics: {self.compute_train_probe_metrics}"
        )
        print(f"   use_dft: {self.use_dft}")
        if self.use_dft:
            print(
                f"      dft_mode: {self.dft_mode} "
                f"(gamma={self.dft_gamma}, weight=[{self.dft_min_weight}, {self.dft_max_weight}], warmup={self.dft_warmup_steps})"
            )
        print(
            f"   dynamic_token_batch: {self.max_tokens_per_batch > 0} "
            f"(max_tokens={self.max_tokens_per_batch}, bucket={self.dynamic_batch_bucket_size}, "
            f"max_examples={self.dynamic_batch_max_examples})"
        )
        print(f"   use_simulate_damage: {self.use_simulate_damage} (prob={self.damage_prob}, span={self.damage_span_prob})")
        print(
            f"   use_simulate_ocr_noise: {self.use_simulate_ocr_noise} "
            f"(official_prob={self.ocr_noise_prob}, ocr_prob={self.ocr_noise_prob_on_ocr})"
        )
        print(f"   name_handling_mode: {self.name_handling_mode}")
        if self.name_handling_mode == 'placeholder':
            print(f"      placeholder_ratio: {self.placeholder_ratio}")
        elif self.name_handling_mode == 'hint':
            print(f"      hint_ratio: {self.hint_ratio}")
            print(f"      max_hints_per_sample: {self.max_hints_per_sample}")
            print(f"      use_month_hints: {self.use_month_hints}")
        print("   预处理/质量过滤: 已移至 prepare_data.py")


config = Config()

# ========== 多卡兼容：rank 0 判定 ==========
def _is_main_process() -> bool:
    """DDP 兼容：仅 rank 0 返回 True；单卡始终 True。"""
    local_rank = int(os.environ.get("LOCAL_RANK", -1))
    return local_rank <= 0

def _is_fsdp_model(model) -> bool:
    """Check if model is wrapped by FSDP."""
    try:
        from torch.distributed.fsdp import FullyShardedDataParallel as FSDP
        return isinstance(model, FSDP)
    except ImportError:
        return False

# ========== 分布式 Eval 辅助函数 ==========
def _dist_eval_info() -> tuple:
    """返回 (rank, world_size)，单卡时返回 (0, 1)。"""
    try:
        import torch.distributed as dist
        if dist.is_initialized():
            return dist.get_rank(), dist.get_world_size()
    except Exception:
        pass
    return 0, 1

def _dist_eval_shard(data_list: list, rank: int, world_size: int) -> tuple:
    """将列表按连续分块分配给各 rank，返回 (shard, start_idx)。"""
    n = len(data_list)
    chunk = math.ceil(n / world_size)
    start = rank * chunk
    end = min(start + chunk, n)
    return data_list[start:end], start

def _dist_eval_gather_predictions(local_preds: list, world_size: int) -> list:
    """将各 rank 的 prediction list 收集到所有 rank，按原始顺序拼接。
    单卡时直接返回。"""
    if world_size <= 1:
        return local_preds
    import torch.distributed as dist
    gathered = [None] * world_size
    dist.all_gather_object(gathered, local_preds)
    all_preds = []
    for preds in gathered:
        all_preds.extend(preds)
    return all_preds

def _unwrap_model_for_eval(mdl):
    """Unwrap DDP/FSDP wrapper，返回底层模型用于 generate()。"""
    return mdl.module if hasattr(mdl, 'module') else mdl

