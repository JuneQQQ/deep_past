# --- 模拟泥板损坏（数据增强）---
import random

# 创建独立的随机数生成器，使用固定种子确保可复现
_damage_rng = random.Random(config.random_seed)
_ocr_noise_rng = random.Random(config.random_seed + 7919)

def reset_damage_rng():
    """重置损坏随机数生成器（每个 epoch 开始时调用可确保一致性）"""
    global _damage_rng
    _damage_rng = random.Random(config.random_seed)


def reset_ocr_noise_rng():
    """重置 OCR 噪声随机数生成器。"""
    global _ocr_noise_rng
    _ocr_noise_rng = random.Random(config.random_seed + 7919)

def merge_consecutive_gaps(text):
    """合并连续的 gap 标记，确保不会出现连续 gap"""
    if not isinstance(text, str):
        return text
    prev = None
    while prev != text:
        prev = text
        text = re.sub(r'<gap>\s+<gap>', '<gap>', text)
    return text


def simulate_damage(text, damage_prob=0.1, span_prob=0.7):
    """
    模拟泥板物理损坏，增强模型鲁棒性
    使用固定种子的随机数生成器确保可复现
    
    Args:
        text: 原始阿卡德语转写
        damage_prob: 触发损坏的概率
        span_prob: Span 损坏 vs 单词损坏 (<gap>) 的比例
    
    Returns:
        可能被"损坏"的文本
    """
    global _damage_rng
    if not isinstance(text, str) or _damage_rng.random() > damage_prob:
        return text
    
    words = text.split()
    n = len(words)
    if n < 3:
        return text  # 太短的不做损坏
    
    # 找到可以安全替换的位置（前后都不是 gap）
    safe_indices = []
    for i in range(n):
        if '<' in words[i]:
            continue  # 跳过已有的 gap
        # 检查前后是否有 gap
        prev_is_gap = (i > 0 and '<' in words[i-1])
        next_is_gap = (i < n-1 and '<' in words[i+1])
        if not prev_is_gap and not next_is_gap:
            safe_indices.append(i)
    
    if not safe_indices:
        return text  # 没有安全位置
    
    if _damage_rng.random() < span_prob:
        # --- Span 损坏 ---
        # 找连续的安全位置
        consecutive = []
        for i, idx in enumerate(safe_indices):
            if i > 0 and safe_indices[i-1] == idx - 1:
                consecutive.append(idx)
            else:
                consecutive = [idx]
            if len(consecutive) >= 2:
                break
        
        if len(consecutive) >= 2:
            span_len = min(_damage_rng.randint(2, 5), len(consecutive))
            start = consecutive[0]
            new_words = words[:start] + ['<gap>'] + words[start + span_len:]
        else:
            return text  # 没有连续安全位置
    else:
        # --- 单词损坏 (<gap>) ---
        idx = _damage_rng.choice(safe_indices)
        words[idx] = '<gap>'
        new_words = words
    
    result = ' '.join(new_words)
    return merge_consecutive_gaps(result)  # 最终合并检查


_OCR_CHAR_SUBS = [
    ("ṭ", "m"),
    ("ṣ", "s"),
    ("š", "s"),
    ("ḫ", "h"),
    ("ú", "u"),
    ("ù", "u"),
    ("í", "i"),
    ("ì", "i"),
    ("á", "a"),
    ("à", "a"),
    ("é", "e"),
    ("è", "e"),
    ("₄", "4"),
]
_OCR_TOKEN_SUBS = [
    ("ṭup-pì", "mup-pì"),
    ("ṭup-pu", "mup-pu"),
    ("KÙ.BABBAR", "KÙ.B."),
    ("šu-ma", "su-ma"),
    ("a-na", "ana"),
]


def _normalize_ocr_noise_space(text: str) -> str:
    return re.sub(r"\s+", " ", str(text)).strip()


def _mutate_ocr_token(token: str, rng: random.Random) -> str:
    """轻量模拟 OCR 错读：字符混淆、连字符丢失、断词。"""
    if not isinstance(token, str) or not token or token == "<gap>" or "[[" in token or "]]" in token:
        return token

    original = token
    mutated = token

    for clean, noisy in _OCR_TOKEN_SUBS:
        if clean in mutated and rng.random() < 0.35:
            mutated = mutated.replace(clean, noisy)

    chars = list(mutated)
    for idx, ch in enumerate(chars):
        if rng.random() < 0.12:
            for src, dst in _OCR_CHAR_SUBS:
                if ch == src:
                    chars[idx] = dst
                    break
    mutated = "".join(chars)

    if "-" in mutated and rng.random() < 0.60:
        parts = [part for part in mutated.split("-") if part]
        if len(parts) >= 2:
            join_style = rng.choice(["space", "drop"])
            mutated = (" " if join_style == "space" else "").join(parts)

    if (
        mutated == original
        and rng.random() < 0.18
        and len(mutated) >= 4
        and "<" not in mutated
        and "{" not in mutated
        and "}" not in mutated
    ):
        cut = rng.randrange(1, len(mutated) - 1)
        mutated = mutated[:cut] + " " + mutated[cut:]

    return mutated


def simulate_ocr_noise(text: str, noise_prob: float) -> str:
    """动态模拟 OCR 噪声，提升 clean→OCR 场景鲁棒性。"""
    global _ocr_noise_rng
    if (
        not isinstance(text, str)
        or not text.strip()
        or noise_prob <= 0
        or _ocr_noise_rng.random() > noise_prob
    ):
        return text

    tokens = text.split()
    if len(tokens) < 2:
        return text

    noisy_tokens = list(tokens)
    changed = False
    eligible_indices = [
        idx for idx, token in enumerate(tokens)
        if token and token != "<gap>" and "[[" not in token and "]]" not in token
    ]
    if not eligible_indices:
        return text

    max_mutations = max(1, math.ceil(len(eligible_indices) * 0.35))
    mutated_count = 0
    for idx in eligible_indices:
        if mutated_count >= max_mutations:
            break
        if _ocr_noise_rng.random() >= 0.32:
            continue
        new_token = _mutate_ocr_token(noisy_tokens[idx], _ocr_noise_rng)
        if new_token != noisy_tokens[idx]:
            noisy_tokens[idx] = new_token
            mutated_count += 1
            changed = True

    if len(noisy_tokens) >= 3 and _ocr_noise_rng.random() < 0.10:
        insert_at = _ocr_noise_rng.randrange(1, len(noisy_tokens))
        noisy_tokens.insert(insert_at, "<gap>")
        changed = True
    elif len(noisy_tokens) >= 2 and _ocr_noise_rng.random() < 0.06:
        replace_candidates = [
            idx for idx, token in enumerate(noisy_tokens)
            if token and token != "<gap>" and "<" not in token
        ]
        if replace_candidates:
            replace_at = _ocr_noise_rng.choice(replace_candidates)
            noisy_tokens[replace_at] = "<gap>"
            changed = True

    if not changed:
        fallback_idx = _ocr_noise_rng.choice(eligible_indices)
        noisy_tokens[fallback_idx] = _mutate_ocr_token(noisy_tokens[fallback_idx], _ocr_noise_rng)

    noisy_text = _normalize_ocr_noise_space(" ".join(noisy_tokens))
    return merge_consecutive_gaps(noisy_text)


# --- 方言→前缀映射 ---
DIALECT_PREFIX_MAP = {
    "OA":       "translate Old Assyrian to English: ",
    "OB":       "translate Old Babylonian to English: ",
    "OAkk":     "translate Old Akkadian to English: ",
    "Sumerian": "translate Sumerian to English: ",
}

def normalize_data_source_label(value) -> str:
    """Normalize data_source column to 'official' or 'ocr'."""
    text = str(value).strip().lower()
    if text == "ocr":
        return "ocr"
    return "official"

# --- Meta prefix: 极简 2 字母前缀 [source][completeness] ---
_META_PREFIX_RE = re.compile(r'^[ONCBSX][ID] ')

def _is_damaged(text: str) -> bool:
    """判断阿卡德语转写是否含有破损标记。"""
    if '<gap>' in text:
        return True
    if '[' in text or ']' in text:
        return True
    if re.search(r'\bx\b', text, re.IGNORECASE):
        return True
    if '⸢' in text or '⸣' in text:
        return True
    if '...' in text:
        return True
    return False

def _build_meta_prefix(text: str, data_source: str = "official") -> str:
    """构建 2 字母 meta prefix: [source][completeness] + 空格。

    source:       O=official, N=noisy (ocr/synth/bt/unknown)
    completeness: I=intact, D=damaged
    """
    src = "O" if normalize_data_source_label(data_source) == "official" else "N"
    comp = "D" if _is_damaged(text) else "I"
    return f"{src}{comp} "

def _get_task_prefix(dialect: str = "", text: str = "", data_source: str = "official") -> str:
    """根据配置返回前缀。

    use_meta_prefix=True  → "OI " / "OD " / "NI " / "ND " (3 bytes)
    use_meta_prefix=False → 原始方言前缀 (~45 bytes)
    """
    if config.use_meta_prefix:
        return _build_meta_prefix(text, data_source)
    return DIALECT_PREFIX_MAP.get(str(dialect).strip(), config.task_prefix)

# 所有已知前缀（按长度降序排列，优先匹配最长前缀）
_ALL_TASK_PREFIXES = sorted(
    set(list(DIALECT_PREFIX_MAP.values()) + [config.task_prefix]),
    key=len, reverse=True
)

def _strip_any_task_prefix(text: str) -> str:
    """从输入文本中移除任何已知的任务前缀（兼容 meta prefix 和旧前缀），返回纯内容部分。"""
    # Meta prefix: 2 字符 + 空格
    if _META_PREFIX_RE.match(text):
        return text[3:]
    for prefix in _ALL_TASK_PREFIXES:
        if text.startswith(prefix):
            return text[len(prefix):]
    return text


# --- 预处理函数（数据已由 prepare_data.py 预处理，这里只添加 task_prefix）---
def preprocess_input(text, dialect="", data_source="official"):
    """添加任务前缀，可选模拟损坏。支持按 dialect 选择不同前缀。"""
    if not isinstance(text, str):
        text = ""
    
    # 训练时可选模拟泥板损坏
    if config.use_simulate_damage:
        text = simulate_damage(text, config.damage_prob, config.damage_span_prob)
    
    return _get_task_prefix(dialect, text, data_source) + text


# 阿卡德语高频功能词黑名单（这些词即使在词典里也不应作为 HINTS）
_HINT_MIN_FORM_LEN = 4  # 过短的 key 极易误匹配，跳过

# 已知阿卡德语语法后缀（只允许剥离这些，不做任意音节剥离）
