}

# 阿卡德语格变化后缀（用于 VIP 词干匹配的后缀剥离）
_CASE_SUFFIXES = [
    '-tám', '-tim', '-tum',
    '-am', '-im', '-um',
    '-šu', '-ša',
    '-ni', '-nu', '-né',
    '-m',
]

def _strip_akkadian_case(word: str) -> str:
    """剥离阿卡德语格变化后缀，返回词干"""
    for suf in _CASE_SUFFIXES:
        if word.endswith(suf):
            return word[:-len(suf)]
    return word

def _is_safe_stem(stem: str) -> bool:
    """词干至少包含一个连字符（≥2 个音节），避免单音节误触"""
    return stem.count('-') >= 1

