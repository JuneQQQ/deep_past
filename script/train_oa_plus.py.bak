import os, warnings
os.environ.setdefault("HF_HUB_OFFLINE", "1")
os.environ.setdefault("TRANSFORMERS_OFFLINE", "1")
os.environ.setdefault("HF_DATASETS_OFFLINE", "1")
os.environ.setdefault("DISABLE_TELEMETRY", "1")
os.environ.setdefault("HF_HUB_DISABLE_TELEMETRY", "1")
# DeepSpeed（被 accelerate 间接 import）在无 CUDA toolkit 环境下会崩溃。
# 我们使用 DDP 不需要 DeepSpeed 编译，但需要它能正常 import。
# 设置 CUDA_HOME 指向一个带有假 nvcc 的目录以绕过检查。
if "CUDA_HOME" not in os.environ and not os.path.exists("/usr/local/cuda"):
    _fake_cuda = "/tmp/_fake_cuda_home/bin"
    os.makedirs(_fake_cuda, exist_ok=True)
    _nvcc = os.path.join(_fake_cuda, "nvcc")
    if not os.path.exists(_nvcc):
        with open(_nvcc, "w") as _f:
            _f.write('#!/bin/sh\necho "Cuda compilation tools, release 12.8"')
        os.chmod(_nvcc, 0o755)
    os.environ["CUDA_HOME"] = "/tmp/_fake_cuda_home"
# T5 shared embedding (tied weights) 在 DDP 下梯度 strides 与 bucket view 不一致，
# 这是已知无害行为（仅影响 vocab_size×d_model 的小 tensor），过滤掉。
warnings.filterwarnings("ignore", message="Grad strides do not match bucket view strides")
os.environ["HF_ENDPOINT"] = "https://hf-mirror.com"
os.environ.setdefault("PYTORCH_CUDA_ALLOC_CONF", "expandable_segments:True")

